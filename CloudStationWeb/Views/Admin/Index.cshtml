@model List<CloudStationWeb.Models.ApplicationUser>
@{
    ViewData["Title"] = "Administración de Usuarios";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
    var roles = ViewBag.Roles as List<string>;
    var user2fa = ViewBag.User2fa as Dictionary<string, bool>;
    var userLastLogin = ViewBag.UserLastLogin as Dictionary<string, DateTime?>;
    var pendingUsers = ViewBag.PendingUsers as List<CloudStationWeb.Models.ApplicationUser> ?? new List<CloudStationWeb.Models.ApplicationUser>();
    var pendingRoles = ViewBag.PendingRoles as Dictionary<string, IList<string>> ?? new Dictionary<string, IList<string>>();
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var organismos = ViewBag.Organismos as List<CloudStationWeb.Models.CatalogItemInt> ?? new List<CloudStationWeb.Models.CatalogItemInt>();
    var centrosTrabajo = ViewBag.CentrosTrabajo as List<CloudStationWeb.Models.CentroTrabajo> ?? new List<CloudStationWeb.Models.CentroTrabajo>();
}

@section Styles {
<style>
    .admin-container {
        padding: 30px;
        max-width: 1200px;
        margin: 0 auto;
        min-height: calc(100vh - 50px);
        overflow: auto;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .admin-header h2 {
        font-size: 22px;
        font-weight: 600;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .admin-header h2 i { color: #3b82f6; }

    .btn-new-user {
        padding: 10px 20px;
        background: linear-gradient(135deg, #10b981, #059669);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-new-user:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(16,185,129,0.3); }

    .alert-success, .alert-error {
        padding: 12px 18px;
        border-radius: 10px;
        margin-bottom: 16px;
        font-size: 14px;
        animation: fadeIn 0.3s ease;
    }

    .alert-success {
        background: rgba(16, 185, 129, 0.12);
        border: 1px solid rgba(16,185,129,0.3);
        color: #6ee7b7;
    }

    .alert-error {
        background: rgba(239, 68, 68, 0.12);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5;
    }

    .users-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: rgba(20, 24, 33, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        overflow: hidden;
    }

    .users-table thead th {
        padding: 14px 18px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: rgba(255,255,255,0.5);
        background: rgba(255,255,255,0.03);
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .users-table tbody td {
        padding: 14px 18px;
        font-size: 14px;
        color: rgba(255,255,255,0.85);
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .users-table tbody tr:last-child td {
        border-bottom: none;
    }

    .users-table tbody tr:hover {
        background: rgba(255,255,255,0.03);
    }

    .role-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .role-Administrador { background: rgba(239, 68, 68, 0.15); color: #fca5a5; }
    .role-Operador { background: rgba(59, 130, 246, 0.15); color: #93c5fd; }
    .role-Visualizador { background: rgba(16, 185, 129, 0.15); color: #6ee7b7; }
    .role-SuperAdmin { background: rgba(245, 158, 11, 0.2); color: #fbbf24; }

    .status-active { color: #10b981; }
    .status-inactive { color: #ef4444; }

    .action-btn {
        padding: 6px 12px;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        background: rgba(255,255,255,0.05);
        color: rgba(255,255,255,0.7);
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s;
        font-family: 'Inter';
        margin-right: 4px;
    }

    .action-btn:hover { background: rgba(255,255,255,0.1); }
    .action-btn.danger { border-color: rgba(239,68,68,0.3); color: #fca5a5; }
    .action-btn.danger:hover { background: rgba(239,68,68,0.15); }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.6);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

    .modal-overlay.active { display: flex; }

    .modal-card {
        background: rgba(20, 24, 33, 0.95);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 18px;
        padding: 36px;
        width: 100%;
        max-width: 480px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        animation: modalIn 0.3s ease;
    }

    @@keyframes modalIn {
        from { opacity: 0; transform: scale(0.95) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .modal-card h3 {
        font-size: 18px;
        font-weight: 600;
        color: #fff;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .modal-card h3 i { color: #3b82f6; }

    .modal-group {
        margin-bottom: 16px;
    }

    .modal-group label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: rgba(255,255,255,0.7);
        margin-bottom: 6px;
    }

    .modal-group input, .modal-group select {
        width: 100%;
        padding: 10px 14px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        color: #fff;
        font-family: 'Inter';
        font-size: 14px;
        outline: none;
        transition: border-color 0.2s;
    }

    .modal-group select option { background: #1a1f2e; color: #fff; }

    .modal-group input:focus, .modal-group select:focus {
        border-color: rgba(59,130,246,0.5);
    }

    .modal-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 24px;
    }

    .modal-btn {
        padding: 10px 22px;
        border-radius: 10px;
        font-family: 'Inter';
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
    }

    .modal-btn.cancel {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.7);
    }

    .modal-btn.submit {
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        color: #fff;
    }

    .modal-btn:hover { transform: translateY(-1px); }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    /* Pending requests */
    .pending-section {
        margin-bottom: 28px;
        background: rgba(245, 158, 11, 0.06);
        border: 1px solid rgba(245, 158, 11, 0.15);
        border-radius: 14px;
        padding: 24px;
        animation: fadeIn 0.3s ease;
    }

    .pending-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        font-size: 16px;
        font-weight: 600;
        color: #f59e0b;
    }

    .pending-header .count-badge {
        background: #f59e0b;
        color: #000;
        width: 24px; height: 24px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
    }

    .pending-card {
        background: rgba(20, 24, 33, 0.6);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        padding: 18px 20px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 18px;
        transition: background 0.2s;
    }

    .pending-card:last-child { margin-bottom: 0; }
    .pending-card:hover { background: rgba(20, 24, 33, 0.8); }

    .pending-avatar {
        width: 44px; height: 44px;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
    }

    .pending-info { flex: 1; min-width: 0; }

    .pending-name {
        font-size: 14px;
        font-weight: 600;
        color: #fff;
    }

    .pending-meta {
        font-size: 12px;
        color: rgba(255,255,255,0.45);
        margin-top: 2px;
    }

    .pending-note {
        font-size: 12px;
        color: rgba(255,255,255,0.55);
        background: rgba(255,255,255,0.04);
        border-radius: 8px;
        padding: 8px 12px;
        margin-top: 6px;
        font-style: italic;
        max-width: 420px;
    }

    .pending-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .pending-actions select {
        padding: 7px 12px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        color: #fff;
        font-family: 'Inter';
        font-size: 12px;
        outline: none;
    }

    .pending-actions select option { background: #1a1f2e; }

    .btn-approve {
        padding: 8px 16px;
        background: linear-gradient(135deg, #10b981, #059669);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-family: 'Inter';
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-approve:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(16,185,129,0.3); }

    .btn-reject {
        padding: 8px 16px;
        background: rgba(239, 68, 68, 0.12);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5;
        border-radius: 8px;
        font-family: 'Inter';
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-reject:hover { background: rgba(239,68,68,0.2); }

    .inline-select {
        padding: 5px 8px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        color: rgba(255,255,255,0.8);
        font-family: 'Inter';
        font-size: 11px;
        outline: none;
        max-width: 150px;
        width: 100%;
        cursor: pointer;
        transition: border-color 0.2s;
    }
    .inline-select:hover { border-color: rgba(139,92,246,0.4); }
    .inline-select:focus { border-color: rgba(139,92,246,0.6); }
    .inline-select option { background: #1a1f2e; color: #fff; }
</style>
}

<div class="admin-container">
    <div class="admin-header">
        <h2><i class="users cog icon"></i>Administración de Usuarios</h2>
        <div style="display: flex; gap: 10px;">
            @if (isSuperAdmin)
            {
                <button class="btn-new-user" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);" onclick="openCatalogModal()">
                    <i class="database icon"></i> Catálogos
                </button>
            }
            <a href="@Url.Action("AuditLog", "Admin")" class="btn-new-user" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                <i class="clipboard list icon"></i> Bitácora
            </a>
            <button class="btn-new-user" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);" onclick="openEmailModal()">
                <i class="envelope icon"></i> Notificar
            </button>
            <button class="btn-new-user" onclick="openModal('create')">
                <i class="plus icon"></i> Nuevo Usuario
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success"><i class="check circle icon"></i> @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-error"><i class="exclamation circle icon"></i> @TempData["Error"]</div>
    }

    @if (pendingUsers.Any())
    {
        <div class="pending-section">
            <div class="pending-header">
                <i class="clock outline icon"></i>
                Solicitudes Pendientes
                <span class="count-badge">@pendingUsers.Count</span>
            </div>
            @foreach (var pu in pendingUsers)
            {
                var puRole = pendingRoles.ContainsKey(pu.Id) ? pendingRoles[pu.Id].FirstOrDefault() ?? "Visualizador" : "Visualizador";
                <div class="pending-card">
                    <div class="pending-avatar">@(pu.FullName.Length > 0 ? pu.FullName[0].ToString().ToUpper() : "?")</div>
                    <div class="pending-info">
                        <div class="pending-name">@pu.FullName <span style="color:rgba(255,255,255,0.35);font-weight:400;font-size:12px;">(@pu.UserName)</span></div>
                        <div class="pending-meta">
                            @(pu.Email ?? "Sin email") • Registrado @pu.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                        @if (!string.IsNullOrEmpty(pu.RegistrationNote))
                        {
                            <div class="pending-note">
                                <i class="quote left icon" style="font-size:10px;"></i> @pu.RegistrationNote
                            </div>
                        }
                    </div>
                    <div class="pending-actions">
                        <form method="post" asp-action="ApproveUser" style="display:flex;align-items:center;gap:8px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@pu.Id" />
                            <select name="role" title="Rol a asignar">
                                @if (roles != null)
                                {
                                    @foreach (var r in roles)
                                    {
                                        <option value="@r" selected="@(r == puRole)">@r</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn-approve" title="Aprobar solicitud">
                                <i class="check icon"></i> Aprobar
                            </button>
                        </form>
                        <button type="button" class="btn-reject" onclick="openRejectModal('@pu.Id', '@pu.FullName')" title="Rechazar solicitud">
                            <i class="times icon"></i> Rechazar
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <table class="users-table">
        <thead>
            <tr>
                <th>Usuario</th>
                <th>Nombre Completo</th>
                <th>Email</th>
                <th>Rol</th>
                <th>Organismo</th>
                <th>Centro Trabajo</th>
                <th>2FA</th>
                <th>Estado</th>
                <th>Último Acceso</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Where(u => u.IsApproved))
            {
                var role = userRoles![user.Id].FirstOrDefault() ?? "Sin rol";
                var has2fa = user2fa != null && user2fa.ContainsKey(user.Id) && user2fa[user.Id];
                var lastLogin = userLastLogin != null && userLastLogin.ContainsKey(user.Id) ? userLastLogin[user.Id] : null;
                var orgName = user.OrganismoId.HasValue ? organismos.FirstOrDefault(o => o.Id == user.OrganismoId)?.Nombre ?? "—" : "—";
                var ctName = user.CentroTrabajoId.HasValue ? centrosTrabajo.FirstOrDefault(c => c.Id == user.CentroTrabajoId)?.Nombre ?? "—" : "—";
                <tr>
                    <td><strong>@user.UserName</strong></td>
                    <td>@user.FullName</td>
                    <td style="color: rgba(255,255,255,0.5);">@user.Email</td>
                    <td>
                        <span class="role-badge role-@role">@role</span>
                    </td>
                    <td>
                        <select class="inline-select" onchange="changeOrganismo('@user.Id', this.value)" title="Asignar Organismo">
                            <option value="">— Sin asignar —</option>
                            @foreach (var org in organismos)
                            {
                                <option value="@org.Id" selected="@(user.OrganismoId == org.Id)">@org.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="inline-select" onchange="changeCentroTrabajo('@user.Id', this.value)" title="Asignar Centro de Trabajo">
                            <option value="">— Sin asignar —</option>
                            @foreach (var ct in centrosTrabajo)
                            {
                                <option value="@ct.Id" selected="@(user.CentroTrabajoId == ct.Id)">@ct.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        @if (has2fa)
                        {
                            <span style="color: #10b981;" title="2FA activo"><i class="shield alternate icon"></i></span>
                        }
                        else
                        {
                            <span style="color: rgba(255,255,255,0.2);" title="Sin 2FA"><i class="shield icon"></i></span>
                        }
                    </td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="status-active"><i class="circle icon" style="font-size:8px;"></i> Activo</span>
                        }
                        else
                        {
                            <span class="status-inactive"><i class="circle icon" style="font-size:8px;"></i> Inactivo</span>
                        }
                    </td>
                    <td style="color: rgba(255,255,255,0.4); font-size: 13px;">
                        @if (lastLogin.HasValue)
                        {
                            @lastLogin.Value.ToLocalTime().ToString("dd/MM HH:mm")
                        }
                        else
                        {
                            <span style="font-style:italic;">Nunca</span>
                        }
                    </td>
                    <td>
                        @if (user.UserName != "administrador")
                        {
                            <button class="action-btn" onclick="openModal('role', '@user.Id', '@role')" title="Cambiar Rol">
                                <i class="exchange icon"></i>
                            </button>
                            <form method="post" asp-action="ToggleUser" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="action-btn" title="@(user.IsActive ? "Desactivar" : "Activar")">
                                    <i class="@(user.IsActive ? "ban" : "check") icon"></i>
                                </button>
                            </form>
                            <button class="action-btn" onclick="openModal('password', '@user.Id')" title="Reset Contraseña">
                                <i class="key icon"></i>
                            </button>
                            <a href="@Url.Action("UserPermissions", "Admin", new { userId = user.Id })" class="action-btn" title="Asignar Productos">
                                <i class="folder icon"></i>
                            </a>
                            @if (has2fa)
                            {
                                <form method="post" asp-action="Toggle2fa" style="display:inline;" onsubmit="return confirm('¿Desactivar 2FA para este usuario?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="action-btn" title="Desactivar 2FA" style="color:#f59e0b;">
                                        <i class="shield alternate icon"></i>
                                    </button>
                                </form>
                            }
                            <button class="action-btn" onclick="openEmailModal('@user.Id', '@user.FullName', '@user.Email')" title="Enviar Correo" style="color:#8b5cf6;">
                                <i class="envelope icon"></i>
                            </button>
                            <form method="post" asp-action="DeleteUser" style="display:inline;" onsubmit="return confirm('¿Está seguro de eliminar este usuario?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="action-btn danger" title="Eliminar">
                                    <i class="trash icon"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <span style="color:rgba(255,255,255,0.3); font-size:12px;">Super Admin</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Create User Modal -->
<div id="createModal" class="modal-overlay">
    <div class="modal-card">
        <h3><i class="user plus icon"></i>Nuevo Usuario</h3>
        <form method="post" asp-action="CreateUser">
            @Html.AntiForgeryToken()
            <div class="modal-group">
                <label>Usuario *</label>
                <input type="text" name="username" required placeholder="Nombre de usuario" />
            </div>
            <div class="modal-group">
                <label>Nombre Completo</label>
                <input type="text" name="fullName" placeholder="Nombre completo" />
            </div>
            <div class="modal-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="correo@ejemplo.com" />
            </div>
            <div class="modal-group">
                <label>Contraseña *</label>
                <input type="password" name="password" required placeholder="Mínimo 8 caracteres" />
            </div>
            <div class="modal-group">
                <label>Rol *</label>
                <select name="role" required>
                    @if (roles != null)
                    {
                        @foreach (var r in roles)
                        {
                            <option value="@r">@r</option>
                        }
                    }
                </select>
            </div>
            <div class="modal-group">
                <label>Organismo</label>
                <select name="organismoId">
                    <option value="">— Sin asignar —</option>
                    @foreach (var org in organismos)
                    {
                        <option value="@org.Id">@org.Nombre</option>
                    }
                </select>
            </div>
            <div class="modal-group">
                <label>Centro de Trabajo</label>
                <select name="centroTrabajoId">
                    <option value="">— Sin asignar —</option>
                    @foreach (var ct in centrosTrabajo)
                    {
                        <option value="@ct.Id">@ct.Nombre</option>
                    }
                </select>
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn cancel" onclick="closeModal('createModal')">Cancelar</button>
                <button type="submit" class="modal-btn submit">Crear Usuario</button>
            </div>
        </form>
    </div>
</div>

<!-- Change Role Modal -->
<div id="roleModal" class="modal-overlay">
    <div class="modal-card">
        <h3><i class="exchange icon"></i>Cambiar Rol</h3>
        <form method="post" asp-action="ChangeRole">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="roleUserId" />
            <div class="modal-group">
                <label>Nuevo Rol</label>
                <select name="newRole" id="roleSelect" required>
                    @if (roles != null)
                    {
                        @foreach (var r in roles)
                        {
                            <option value="@r">@r</option>
                        }
                    }
                </select>
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn cancel" onclick="closeModal('roleModal')">Cancelar</button>
                <button type="submit" class="modal-btn submit">Cambiar Rol</button>
            </div>
        </form>
    </div>
</div>

<!-- Reset Password Modal -->
<div id="passwordModal" class="modal-overlay">
    <div class="modal-card">
        <h3><i class="key icon"></i>Restablecer Contraseña</h3>
        <form method="post" asp-action="ResetPassword">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="passwordUserId" />
            <div class="modal-group">
                <label>Nueva Contraseña</label>
                <input type="password" name="newPassword" required placeholder="Mínimo 8 caracteres" />
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn cancel" onclick="closeModal('passwordModal')">Cancelar</button>
                <button type="submit" class="modal-btn submit">Restablecer</button>
            </div>
        </form>
    </div>
</div>

<!-- Send Email Modal -->
<div id="emailModal" class="modal-overlay">
    <div class="modal-card" style="max-width:540px;">
        <h3><i class="envelope icon" style="color:#8b5cf6;"></i>Enviar Notificación</h3>
        <p id="emailRecipientInfo" style="color:rgba(255,255,255,0.6);font-size:13px;margin-bottom:18px;"></p>
        <form method="post" asp-action="SendNotification">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="emailUserId" />
            <input type="hidden" name="sendToAll" id="emailSendToAll" value="false" />
            <div class="modal-group">
                <label>Destinatario</label>
                <div style="display:flex;gap:10px;margin-bottom:12px;">
                    <button type="button" id="btnSingle" class="action-btn" style="flex:1;padding:8px;font-size:13px;background:rgba(139,92,246,0.15);border-color:rgba(139,92,246,0.4);color:#a78bfa;" onclick="setEmailMode(false)">Usuario específico</button>
                    <button type="button" id="btnAll" class="action-btn" style="flex:1;padding:8px;font-size:13px;" onclick="setEmailMode(true)">Todos los usuarios</button>
                </div>
            </div>
            <div class="modal-group">
                <label>Asunto *</label>
                <input type="text" name="subject" id="emailSubject" required placeholder="Asunto del correo" />
            </div>
            <div class="modal-group">
                <label>Mensaje *</label>
                <textarea name="message" id="emailMessage" required placeholder="Escriba el mensaje para el usuario..." style="width:100%;min-height:120px;padding:12px 16px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;color:#fff;font-family:'Inter';font-size:14px;outline:none;resize:vertical;"></textarea>
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn cancel" onclick="closeModal('emailModal')">Cancelar</button>
                <button type="submit" class="modal-btn submit" style="background:linear-gradient(135deg, #6366f1, #8b5cf6);"><i class="paper plane icon"></i> Enviar</button>
            </div>
        </form>
    </div>
</div>

<!-- Reject User Modal -->
<div id="rejectModal" class="modal-overlay">
    <div class="modal-card">
        <h3><i class="times circle icon" style="color:#ef4444;"></i>Rechazar Solicitud</h3>
        <p style="color:rgba(255,255,255,0.6);font-size:14px;margin-bottom:18px;">
            ¿Está seguro de rechazar la solicitud de <strong id="rejectUserName" style="color:#fff;"></strong>?
        </p>
        <form method="post" asp-action="RejectUser">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="rejectUserId" />
            <div class="modal-group">
                <label>Motivo del rechazo (opcional)</label>
                <input type="text" name="reason" placeholder="Ej: No pertenece al área autorizada" />
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn cancel" onclick="closeModal('rejectModal')">Cancelar</button>
                <button type="submit" class="modal-btn submit" style="background:linear-gradient(135deg, #ef4444, #dc2626);">Rechazar</button>
            </div>
        </form>
    </div>
</div>

<!-- Catalog Management Modal (SuperAdmin only) -->
<div id="catalogModal" class="modal-overlay">
    <div class="modal-card" style="max-width:680px;">
        <h3><i class="database icon" style="color:#8b5cf6;"></i>Gestión de Catálogos</h3>
        <div style="display:flex;gap:10px;margin-bottom:20px;">
            <button type="button" id="tabOrg" class="action-btn" style="flex:1;padding:10px;font-size:13px;font-weight:600;background:rgba(139,92,246,0.15);border-color:rgba(139,92,246,0.4);color:#a78bfa;" onclick="switchCatalogTab('org')">
                <i class="building icon"></i> Organismos
            </button>
            <button type="button" id="tabCt" class="action-btn" style="flex:1;padding:10px;font-size:13px;font-weight:600;" onclick="switchCatalogTab('ct')">
                <i class="briefcase icon"></i> Centros de Trabajo
            </button>
        </div>

        <!-- Organismos Tab -->
        <div id="orgTab">
            <div style="display:flex;gap:8px;margin-bottom:16px;">
                <input type="text" id="orgNombre" placeholder="Nombre del Organismo" style="flex:2;padding:10px 14px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;color:#fff;font-family:'Inter';font-size:14px;outline:none;" />
                <input type="text" id="orgIniciales" placeholder="Iniciales" style="flex:0.6;padding:10px 14px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;color:#fff;font-family:'Inter';font-size:14px;outline:none;text-transform:uppercase;" maxlength="10" />
                <input type="hidden" id="orgEditId" value="0" />
                <button type="button" class="modal-btn submit" style="white-space:nowrap;" onclick="saveOrganismo()"><i class="save icon"></i> Guardar</button>
            </div>
            <div id="orgList" style="max-height:320px;overflow-y:auto;"></div>
        </div>

        <!-- Centros de Trabajo Tab -->
        <div id="ctTab" style="display:none;">
            <div style="display:flex;gap:8px;margin-bottom:16px;">
                <input type="text" id="ctNombre" placeholder="Nombre del Centro de Trabajo" style="flex:1;padding:10px 14px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;color:#fff;font-family:'Inter';font-size:14px;outline:none;" />
                <input type="hidden" id="ctEditId" value="0" />
                <button type="button" class="modal-btn submit" style="white-space:nowrap;" onclick="saveCentroTrabajo()"><i class="save icon"></i> Guardar</button>
            </div>
            <div id="ctList" style="max-height:320px;overflow-y:auto;"></div>
        </div>

        <div class="modal-actions" style="margin-top:20px;">
            <button type="button" class="modal-btn cancel" onclick="closeModal('catalogModal')">Cerrar</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openModal(type, userId, currentRole) {
        if (type === 'create') {
            document.getElementById('createModal').classList.add('active');
        } else if (type === 'role') {
            document.getElementById('roleUserId').value = userId;
            document.getElementById('roleSelect').value = currentRole;
            document.getElementById('roleModal').classList.add('active');
        } else if (type === 'password') {
            document.getElementById('passwordUserId').value = userId;
            document.getElementById('passwordModal').classList.add('active');
        }
    }

    function openRejectModal(userId, fullName) {
        document.getElementById('rejectUserId').value = userId;
        document.getElementById('rejectUserName').textContent = fullName;
        document.getElementById('rejectModal').classList.add('active');
    }

    function openEmailModal(userId, fullName, email) {
        document.getElementById('emailSubject').value = '';
        document.getElementById('emailMessage').value = '';
        if (userId) {
            document.getElementById('emailUserId').value = userId;
            document.getElementById('emailSendToAll').value = 'false';
            document.getElementById('emailRecipientInfo').innerHTML = 'Para: <strong style="color:#fff;">' + fullName + '</strong> (' + (email || 'sin email') + ')';
            setEmailMode(false);
        } else {
            document.getElementById('emailUserId').value = '';
            document.getElementById('emailSendToAll').value = 'true';
            document.getElementById('emailRecipientInfo').innerHTML = 'Enviar notificación a <strong style="color:#fff;">todos los usuarios activos</strong> con email registrado.';
            setEmailMode(true);
        }
        document.getElementById('emailModal').classList.add('active');
    }

    function setEmailMode(all) {
        document.getElementById('emailSendToAll').value = all ? 'true' : 'false';
        var btnSingle = document.getElementById('btnSingle');
        var btnAll = document.getElementById('btnAll');
        if (all) {
            btnAll.style.background = 'rgba(139,92,246,0.15)';
            btnAll.style.borderColor = 'rgba(139,92,246,0.4)';
            btnAll.style.color = '#a78bfa';
            btnSingle.style.background = 'rgba(255,255,255,0.05)';
            btnSingle.style.borderColor = 'rgba(255,255,255,0.1)';
            btnSingle.style.color = 'rgba(255,255,255,0.7)';
            document.getElementById('emailRecipientInfo').innerHTML = 'Enviar notificación a <strong style="color:#fff;">todos los usuarios activos</strong> con email registrado.';
        } else {
            btnSingle.style.background = 'rgba(139,92,246,0.15)';
            btnSingle.style.borderColor = 'rgba(139,92,246,0.4)';
            btnSingle.style.color = '#a78bfa';
            btnAll.style.background = 'rgba(255,255,255,0.05)';
            btnAll.style.borderColor = 'rgba(255,255,255,0.1)';
            btnAll.style.color = 'rgba(255,255,255,0.7)';
        }
    }

    function closeModal(id) {
        document.getElementById(id).classList.remove('active');
    }

    // Close modal on overlay click
    document.querySelectorAll('.modal-overlay').forEach(m => {
        m.addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('active');
        });
    });

    // ─── Catalog Management ───
    function openCatalogModal() {
        switchCatalogTab('org');
        document.getElementById('catalogModal').classList.add('active');
    }

    function switchCatalogTab(tab) {
        var tabOrg = document.getElementById('tabOrg');
        var tabCt = document.getElementById('tabCt');
        var orgTab = document.getElementById('orgTab');
        var ctTab = document.getElementById('ctTab');
        if (tab === 'org') {
            tabOrg.style.background = 'rgba(139,92,246,0.15)';
            tabOrg.style.borderColor = 'rgba(139,92,246,0.4)';
            tabOrg.style.color = '#a78bfa';
            tabCt.style.background = 'rgba(255,255,255,0.05)';
            tabCt.style.borderColor = 'rgba(255,255,255,0.1)';
            tabCt.style.color = 'rgba(255,255,255,0.7)';
            orgTab.style.display = 'block';
            ctTab.style.display = 'none';
            loadOrganismos();
        } else {
            tabCt.style.background = 'rgba(139,92,246,0.15)';
            tabCt.style.borderColor = 'rgba(139,92,246,0.4)';
            tabCt.style.color = '#a78bfa';
            tabOrg.style.background = 'rgba(255,255,255,0.05)';
            tabOrg.style.borderColor = 'rgba(255,255,255,0.1)';
            tabOrg.style.color = 'rgba(255,255,255,0.7)';
            ctTab.style.display = 'block';
            orgTab.style.display = 'none';
            loadCentrosTrabajo();
        }
    }

    var antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    function loadOrganismos() {
        fetch('@Url.Action("Organismos", "Admin")').then(r => r.json()).then(data => {
            var html = '';
            data.forEach(function(o) {
                var statusColor = o.Activo ? '#10b981' : '#ef4444';
                var statusText = o.Activo ? 'Activo' : 'Inactivo';
                html += '<div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:rgba(255,255,255,0.03);border-radius:10px;margin-bottom:6px;border:1px solid rgba(255,255,255,0.05);">' +
                    '<div style="flex:1;"><strong style="color:#fff;">' + o.Nombre + '</strong> <span style="color:rgba(255,255,255,0.4);font-size:12px;">(' + o.Iniciales + ')</span></div>' +
                    '<span style="color:' + statusColor + ';font-size:12px;"><i class="circle icon" style="font-size:8px;"></i> ' + statusText + '</span>' +
                    '<button type="button" class="action-btn" onclick="editOrganismo(' + o.Id + ',\'' + o.Nombre.replace(/'/g, "\\'") + '\',\'' + o.Iniciales + '\')" title="Editar"><i class="edit icon"></i></button>' +
                    '<button type="button" class="action-btn" onclick="toggleOrganismo(' + o.Id + ')" title="' + (o.Activo ? 'Desactivar' : 'Activar') + '"><i class="' + (o.Activo ? 'ban' : 'check') + ' icon"></i></button>' +
                    '</div>';
            });
            document.getElementById('orgList').innerHTML = html || '<p style="color:rgba(255,255,255,0.4);text-align:center;">No hay organismos.</p>';
        });
    }

    function editOrganismo(id, nombre, iniciales) {
        document.getElementById('orgEditId').value = id;
        document.getElementById('orgNombre').value = nombre;
        document.getElementById('orgIniciales').value = iniciales;
    }

    function saveOrganismo() {
        var id = parseInt(document.getElementById('orgEditId').value) || 0;
        var nombre = document.getElementById('orgNombre').value.trim();
        var iniciales = document.getElementById('orgIniciales').value.trim();
        if (!nombre || !iniciales) { alert('Nombre e Iniciales son requeridos.'); return; }
        var form = new FormData();
        form.append('id', id);
        form.append('nombre', nombre);
        form.append('iniciales', iniciales);
        fetch('@Url.Action("SaveOrganismo", "Admin")', {
            method: 'POST',
            headers: { 'RequestVerificationToken': antiForgeryToken },
            body: form
        }).then(r => r.json()).then(res => {
            if (res.success) {
                document.getElementById('orgEditId').value = '0';
                document.getElementById('orgNombre').value = '';
                document.getElementById('orgIniciales').value = '';
                loadOrganismos();
            } else { alert(res.message || 'Error'); }
        });
    }

    function toggleOrganismo(id) {
        var form = new FormData();
        form.append('id', id);
        fetch('@Url.Action("ToggleOrganismo", "Admin")', {
            method: 'POST',
            headers: { 'RequestVerificationToken': antiForgeryToken },
            body: form
        }).then(r => r.json()).then(res => { if (res.success) loadOrganismos(); });
    }

    function loadCentrosTrabajo() {
        fetch('@Url.Action("CentrosTrabajo", "Admin")').then(r => r.json()).then(data => {
            var html = '';
            data.forEach(function(c) {
                var statusColor = c.activo ? '#10b981' : '#ef4444';
                var statusText = c.activo ? 'Activo' : 'Inactivo';
                html += '<div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:rgba(255,255,255,0.03);border-radius:10px;margin-bottom:6px;border:1px solid rgba(255,255,255,0.05);">' +
                    '<div style="flex:1;"><strong style="color:#fff;">' + c.nombre + '</strong></div>' +
                    '<span style="color:' + statusColor + ';font-size:12px;"><i class="circle icon" style="font-size:8px;"></i> ' + statusText + '</span>' +
                    '<button type="button" class="action-btn" onclick="editCentroTrabajo(' + c.id + ',\'' + c.nombre.replace(/'/g, "\\'") + '\')" title="Editar"><i class="edit icon"></i></button>' +
                    '<button type="button" class="action-btn" onclick="toggleCentroTrabajo(' + c.id + ')" title="' + (c.activo ? 'Desactivar' : 'Activar') + '"><i class="' + (c.activo ? 'ban' : 'check') + ' icon"></i></button>' +
                    '</div>';
            });
            document.getElementById('ctList').innerHTML = html || '<p style="color:rgba(255,255,255,0.4);text-align:center;">No hay centros de trabajo.</p>';
        });
    }

    function editCentroTrabajo(id, nombre) {
        document.getElementById('ctEditId').value = id;
        document.getElementById('ctNombre').value = nombre;
    }

    function saveCentroTrabajo() {
        var id = parseInt(document.getElementById('ctEditId').value) || 0;
        var nombre = document.getElementById('ctNombre').value.trim();
        if (!nombre) { alert('Nombre es requerido.'); return; }
        var form = new FormData();
        form.append('id', id);
        form.append('nombre', nombre);
        fetch('@Url.Action("SaveCentroTrabajo", "Admin")', {
            method: 'POST',
            headers: { 'RequestVerificationToken': antiForgeryToken },
            body: form
        }).then(r => r.json()).then(res => {
            if (res.success) {
                document.getElementById('ctEditId').value = '0';
                document.getElementById('ctNombre').value = '';
                loadCentrosTrabajo();
            } else { alert(res.message || 'Error'); }
        });
    }

    function toggleCentroTrabajo(id) {
        var form = new FormData();
        form.append('id', id);
        fetch('@Url.Action("ToggleCentroTrabajo", "Admin")', {
            method: 'POST',
            headers: { 'RequestVerificationToken': antiForgeryToken },
            body: form
        }).then(r => r.json()).then(res => { if (res.success) loadCentrosTrabajo(); });
    }

    // ─── Inline Organismo / CentroTrabajo assignment ───
    function changeOrganismo(userId, orgId) {
        var form = new FormData();
        form.append('userId', userId);
        if (orgId) form.append('organismoId', orgId);
        fetch('@Url.Action("ChangeOrganismo", "Admin")', {
            method: 'POST',
            headers: { 'RequestVerificationToken': antiForgeryToken },
            body: form
        }).then(r => r.json()).then(res => {
            if (!res.success) alert('Error al cambiar organismo');
        });
    }

    function changeCentroTrabajo(userId, ctId) {
        var form = new FormData();
        form.append('userId', userId);
        if (ctId) form.append('centroTrabajoId', ctId);
        fetch('@Url.Action("ChangeCentroTrabajo", "Admin")', {
            method: 'POST',
            headers: { 'RequestVerificationToken': antiForgeryToken },
            body: form
        }).then(r => r.json()).then(res => {
            if (!res.success) alert('Error al cambiar centro de trabajo');
        });
    }
</script>
}
