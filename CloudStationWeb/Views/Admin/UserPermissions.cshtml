@model List<CloudStationWeb.Models.DocumentProduct>
@{
    ViewData["Title"] = "Asignar Productos";
    var user = ViewBag.User as CloudStationWeb.Models.ApplicationUser;
    var assignedProductIds = ViewBag.AssignedProductIds as List<int> ?? new List<int>();
}

@section Styles {
<style>
    .perm-container {
        padding: 30px;
        max-width: 800px;
        margin: 0 auto;
        min-height: calc(100vh - 50px);
    }

    .perm-card {
        background: rgba(20, 24, 33, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }

    .perm-header {
        margin-bottom: 30px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        padding-bottom: 20px;
    }

    .perm-header h2 {
        font-size: 24px;
        color: #fff;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .perm-header p {
        color: rgba(255,255,255,0.5);
        margin: 8px 0 0 0;
        font-size: 14px;
    }

    .user-info {
        display: inline-flex;
        align-items: center;
        background: rgba(59, 130, 246, 0.15);
        color: #93c5fd;
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 13px;
    }

    .products-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-bottom: 30px;
        max-height: 400px;
        overflow-y: auto;
        padding-right: 10px;
    }

    .product-item {
        display: flex;
        align-items: center;
        padding: 14px 18px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .product-item:hover {
        background: rgba(255,255,255,0.06);
        border-color: rgba(59, 130, 246, 0.3);
    }

    .product-item.selected {
        background: rgba(59, 130, 246, 0.1);
        border-color: rgba(59, 130, 246, 0.5);
    }

    .product-item input[type="checkbox"] {
        width: 18px;
        height: 18px;
        margin-right: 15px;
        accent-color: #3b82f6;
        cursor: pointer;
    }

    .product-info {
        flex: 1;
    }

    .product-name {
        display: block;
        color: #fff;
        font-weight: 600;
        font-size: 15px;
    }

    .product-code {
        display: block;
        color: rgba(255,255,255,0.4);
        font-size: 12px;
        margin-top: 2px;
    }

    .form-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-save {
        padding: 12px 30px;
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-save:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 25px rgba(59, 130, 246, 0.4);
    }

    .btn-back {
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: color 0.2s;
    }

    .btn-back:hover {
        color: #fff;
    }

    /* Scrollbar Styling */
    .products-list::-webkit-scrollbar { width: 6px; }
    .products-list::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); }
    .products-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
</style>
}

<div class="perm-container">
    <div class="perm-card">
        <div class="perm-header">
            <a href="@Url.Action("Index")" class="btn-back">
                <i class="arrow left icon"></i> Volver a Usuarios
            </a>
            <h2 style="margin-top: 20px;">
                <i class="shield alternate icon" style="color: #3b82f6;"></i> 
                Asignación de Productos para <span class="user-info">@user?.UserName</span>
            </h2>
            <p>Seleccione los productos a los que este usuario tendrá acceso en el Repositorio.</p>
        </div>

        <form method="post" asp-action="UpdateUserPermissions">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@user?.Id" />

            <div class="products-list">
                @foreach (var prod in Model)
                {
                    var isSelected = assignedProductIds.Contains(prod.Id);
                    <label class="product-item @(isSelected ? "selected" : "")">
                        <input type="checkbox" name="productIds" value="@prod.Id" @(isSelected ? "checked" : "") />
                        <div class="product-info">
                            <span class="product-name">@prod.Name</span>
                            <span class="product-code">Código: @prod.Code | Prefijo: @prod.FilePrefix</span>
                        </div>
                    </label>
                }
            </div>

            <div class="form-actions">
                <span style="color: rgba(255,255,255,0.4); font-size: 13px;">
                    <i class="info circle icon"></i> @Model.Count productos disponibles
                </span>
                <button type="submit" class="btn-save">
                    Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        $('input[type="checkbox"]').change(function() {
            if (this.checked) {
                $(this).closest('.product-item').addClass('selected');
            } else {
                $(this).closest('.product-item').removeClass('selected');
            }
        });
    });
</script>
}
