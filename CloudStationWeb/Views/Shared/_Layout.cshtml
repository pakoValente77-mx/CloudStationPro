                        <i class="users cog icon" style="color:#ffb74d;"></i> Usuarios
                    </a>
                    <a class="item @(ctrl == "Notification" ? "active" : "")" href="@Url.Action("Index", "Notification")">
                        <i class="bell icon" style="color:#ce93d8;"></i> Notificaciones
                    </a>
                    <a class="item @(ctrl == "EarlyWarning" ? "active" : "")" href="@Url.Action("Index", "EarlyWarning")">
                        <i class="exclamation triangle icon" style="color:#e74c3c;"></i> Alertas Tempranas
                    </a>
                    @if (User.IsInRole("SuperAdmin"))
                    {
                    <div class="divider" style="border-color: rgba(255,255,255,0.1) !important;"></div>
                    <a class="item @(ctrl == "Settings" ? "active" : "")" href="@Url.Action("Index", "Settings")">
                        <i class="sliders horizontal icon" style="color:#4fc3f7;"></i> Configuración
