            <!-- Monitoreo dropdown -->
            <div class="ui dropdown item nav-dropdown @(new[]{"HourlyReport","RainfallReport","GoesMonitoring"}.Contains(ctrl) ? "active" : "")">
                <span class="text"><i class="broadcast tower icon"></i> Monitoreo</span> <i class="dropdown icon"></i>
                <div class="menu pih-dropdown-menu">
                    <a class="item @(ctrl == "HourlyReport" ? "active" : "")" href="/HourlyReport">
                        <i class="clock outline icon" style="color:#4fc3f7;"></i> Cortes Horarios
                    </a>
                    <a class="item @(ctrl == "RainfallReport" ? "active" : "")" href="/RainfallReport">
                        <i class="tint icon" style="color:#64b5f6;"></i> Corte de Lluvia
                    </a>
