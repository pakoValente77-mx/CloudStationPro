            {
            <!-- Herramientas dropdown -->
            <div class="ui dropdown item nav-dropdown @(new[]{"Documents","MisExport"}.Contains(ctrl) ? "active" : "")">
                <span class="text"><i class="toolbox icon"></i> Herramientas</span> <i class="dropdown icon"></i>
                <div class="menu pih-dropdown-menu">
                    <a class="item @(ctrl == "Documents" ? "active" : "")" href="/Documents" id="nav-documents">
                        <i class="folder open icon" style="color:#fbbf24;"></i> Repositorio
                        <span id="doc-alert-badge" style="display:none; margin-left:6px; background:#ef4444; color:#fff; border-radius:10px; padding:1px 7px; font-size:11px; font-weight:700;"></span>
                    </a>
                    <a class="item @(ctrl == "MisExport" ? "active" : "")" href="@Url.Action("Index", "MisExport")">
                        <i class="file export icon" style="color:#4fc3f7;"></i> Exportar .MIS
