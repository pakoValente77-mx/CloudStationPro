    <div class="main-content">
        @RenderBody()
    </div>

    <!-- Footer Bar -->
    <div class="pih-footer">
        <span class="pih-name pih-full">Plataforma Integral Hidrometeorológica</span>
        <span class="pih-name pih-short">PIH</span>
        <span class="pih-copy">|</span>
        <span class="pih-copy">© 2026 CFE — Todos los derechos reservados</span>
    </div>

    <!-- Leaflet Maps CSS - Local -->
    <link rel="stylesheet" href="~/lib/leaflet/leaflet.css" />
    
    <!-- Scripts - Local -->
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/fomantic-ui/dist/semantic.min.js"></script>
    
    <!-- Leaflet Maps JS - Local -->
    <script src="~/lib/leaflet/leaflet.js"></script>

    <!-- Three.js (Para efectos adicionales) - Local -->
    <script src="~/lib/threejs/three.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // ── Session KeepAlive & 401 handler ──────────────────────────────
        (function() {
            var KEEPALIVE_MS = 4 * 60 * 1000; // 4 minutes
            var keepAliveTimer = null;

            function ping() {
                fetch('/Home/KeepAlive', { credentials: 'same-origin' })
                    .then(function(r) {
                        // If redirected to login or 401 → session expired
                        if (r.redirected || r.status === 401) {
                            location.reload();
                        }
                    })
                    .catch(function() {});
            }

            function startKeepAlive() {
                if (keepAliveTimer) clearInterval(keepAliveTimer);
                keepAliveTimer = setInterval(ping, KEEPALIVE_MS);
            }

            startKeepAlive();

            // When tab comes back from background, ping immediately
            // (browsers throttle setInterval in hidden tabs)
            document.addEventListener('visibilitychange', function() {
                if (!document.hidden) {
                    ping();
                    startKeepAlive(); // reset interval
                }
            });

            // Global AJAX 401 handler for jQuery $.ajax calls
            $(document).ajaxError(function(event, jqXHR) {
                if (jqXHR.status === 401) {
                    location.reload();
                }
            });
        })();

        // Document alert badge
        (function() {
            function checkDocAlerts() {
                fetch('/Documents/GetPendingAlerts')
                    .then(r => r.json())
                    .then(data => {
                        var badge = document.getElementById('doc-alert-badge');
                        if (badge && data.count > 0) {
                            badge.textContent = data.count;
                            badge.style.display = 'inline';
                        } else if (badge) {
                            badge.style.display = 'none';
                        }
                    })
                    .catch(() => {});
            }
            checkDocAlerts();
            setInterval(checkDocAlerts, 60000);
        })();

        // Initialize Fomantic dropdowns (click-based, not hover)
        $('.ui.dropdown').dropdown({ on: 'click' });

        // Re-initialize nav dropdowns after page scripts may have overridden them
        $(function() {
            setTimeout(function() {
                $('.nav-dropdown').dropdown({ on: 'click' });
            }, 100);
        });

        // ── Mobile sidebar toggle ──
        function openSidebar() {
            document.getElementById('pihSidebar').classList.add('visible');
            document.getElementById('sidebarOverlay').classList.add('visible');
        }
        function closeSidebar() {
            document.getElementById('pihSidebar').classList.remove('visible');
            document.getElementById('sidebarOverlay').classList.remove('visible');
        }
        // Mark active sidebar item
        (function() {
            var path = window.location.pathname.toLowerCase();
            document.querySelectorAll('.pih-sidebar a.sidebar-item').forEach(function(a) {
                if (a.getAttribute('href') && path.indexOf(a.getAttribute('href').toLowerCase()) === 0 && a.getAttribute('href') !== '/') {
                    a.classList.add('active');
                }
            });
        })();
    </script>


    
    <!-- Particle Background Component -->
    <script src="~/js/particle-background.js"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
    <style>
        .dm-global-badge {
            background: #e74c3c; color: #fff; border-radius: 50%; font-size: 0.65em;
            min-width: 18px; height: 18px; display: inline-flex; align-items: center;
            justify-content: center; margin-left: 4px; font-weight: 700;
            animation: dmPulse 1s ease-in-out 3;
        }
        @@keyframes dmPulse { 0%,100%{transform:scale(1);} 50%{transform:scale(1.3);} }
    </style>
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script>
    (function() {
        // Skip if we're already on the Chat page (it has its own connection)
        if (window.location.pathname.toLowerCase().indexOf('/chat') === 0) return;

        var currentUser = '@User.Identity.Name';
        var dmCount = 0;

        var conn = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/chat')
            .withAutomaticReconnect([0, 2000, 10000, 30000])
            .build();

        conn.on('ReceiveMessage', function(msg) {
            if (msg.room && msg.room.startsWith('dm:') && msg.userName !== currentUser) {
                dmCount++;
                updateDmBadges();
                // Browser notification if tab is hidden
                if (document.hidden && Notification.permission === 'granted') {
                    new Notification('Mensaje de ' + (msg.fullName || msg.userName), {
                        body: msg.message.substring(0, 80),
                        icon: '/images/icon-chat.png',
                        tag: 'dm-' + msg.room
                    });
                }
            }
        });

        function updateDmBadges() {
            var badges = document.querySelectorAll('.dm-global-badge');
            badges.forEach(function(b) {
                if (dmCount > 0) {
                    b.textContent = dmCount > 99 ? '99+' : dmCount;
                    b.style.display = 'inline-flex';
                } else {
                    b.style.display = 'none';
                }
            });
            // Update page title
            document.title = dmCount > 0
                ? '(' + dmCount + ') ' + document.title.replace(/^\(\d+\)\s*/, '')
                : document.title.replace(/^\(\d+\)\s*/, '');
        }

        conn.start().catch(function(err) {
            console.log('Global chat notification: connection failed', err);
        });

        // Request notification permission
        if ('Notification' in window && Notification.permission === 'default') {
            Notification.requestPermission();
        }

        // Reset count when user clicks Chat link
        document.querySelectorAll('#navChatLink, #sidebarChatLink').forEach(function(el) {
            el.addEventListener('click', function() { dmCount = 0; updateDmBadges(); });
        });
    })();
    </script>
    }

</body>
</html>
