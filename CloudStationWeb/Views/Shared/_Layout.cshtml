                <div class="menu pih-dropdown-menu">
                    <a class="item @(ctrl == "DataAnalysis" ? "active" : "")" href="/DataAnalysis">
                        <i class="chart area icon" style="color:#4fc3f7;"></i> Análisis de Datos
                    </a>
                    <a class="item @(ctrl == "StationGroup" ? "active" : "")" href="/StationGroup">
                        <i class="object group icon" style="color:#81c784;"></i> Mis Grupos
                    </a>
                </div>
            </div>
            }

            <!-- Hidrología dropdown -->
            <div class="ui dropdown item nav-dropdown @(new[]{"FunVasos","Bhg","RainForecast"}.Contains(ctrl) ? "active" : "")">
                <span class="text"><i class="water icon"></i> Hidrología</span> <i class="dropdown icon"></i>
                <div class="menu pih-dropdown-menu">
                    <a class="item @(ctrl == "FunVasos" ? "active" : "")" href="/FunVasos">
                        <i class="water icon" style="color:#64b5f6;"></i> Fun. Vasos
                    </a>
                    <a class="item @(ctrl == "Bhg" ? "active" : "")" href="/Bhg">
                        <i class="chart bar icon" style="color:#81c784;"></i> Boletín BHG
                    </a>
                    @if (!User.IsInRole("SoloVasos"))
                    {
                    <div class="divider" style="border-color: rgba(255,255,255,0.1) !important;"></div>
                    <a class="item @(ctrl == "RainForecast" ? "active" : "")" href="@Url.Action("Index", "RainForecast")">
                        <i class="cloud rain icon" style="color:#ce93d8;"></i> Pronóstico de Lluvia
                    </a>
                    }
                </div>
            </div>

            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrador"))
            {
            <!-- Administración dropdown -->
            <div id="nav-admin-dropdown" class="ui dropdown item nav-dropdown @(new[]{"StationAdmin","WatershedAdmin","Admin","Maintenance","Notification","EarlyWarning","Settings"}.Contains(ctrl) ? "active" : "")">
                <span class="text"><i class="cogs icon"></i> Admin</span> <i class="dropdown icon"></i>
                <div class="menu pih-dropdown-menu" style="min-width: 220px;">
                    <a class="item @(ctrl == "StationAdmin" ? "active" : "")" href="@Url.Action("Index", "StationAdmin")">
                        <i class="server icon" style="color:#81c784;"></i> Estaciones
                    </a>
                    <a class="item @(ctrl == "Maintenance" ? "active" : "")" href="@Url.Action("Index", "Maintenance")">
                        <i class="wrench icon" style="color:#fbbf24;"></i> Mantenimiento
                    </a>
                    <a class="item @(ctrl == "WatershedAdmin" ? "active" : "")" href="@Url.Action("Index", "WatershedAdmin")">
                        <i class="tint icon" style="color:#64b5f6;"></i> Cuencas y Subcuencas
                    </a>
                    <div class="divider" style="border-color: rgba(255,255,255,0.1) !important;"></div>
