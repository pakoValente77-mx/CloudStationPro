<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PIH - @ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=2" />
    
    <!-- Fomantic-UI (Semantic Fork) - Local -->
    <link rel="stylesheet" href="~/lib/fomantic-ui/dist/semantic.min.css">
    
    <!-- Google Fonts: Inter - Local -->
    <link href="~/lib/fonts/inter/inter.css" rel="stylesheet">

    <!-- Visual Effects CSS -->
    <link rel="stylesheet" href="~/css/visual-effects.css" />
    <link rel="stylesheet" href="~/css/chart-config.css" />

    <style>
        body {
            background-color: #0b0e14;
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow: hidden; /* Prevent body scroll */
            height: 100vh; /* Full viewport height */
        }

        /* Main content container */
        .main-content {
            height: calc(100vh - 50px - 28px); /* Full height minus menu minus footer */
            margin-top: 50px; /* Offset for fixed menu */
            overflow-y: auto; /* Scroll within content area only */
            overflow-x: hidden;
        }

        /* Fixed footer bar */
        .pih-footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 28px;
            background: linear-gradient(90deg, #1b5e20, #2e7d32, #1b5e20);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            z-index: 9999;
            font-family: 'Inter', sans-serif;
            font-size: 11px;
            color: #ffffff;
            letter-spacing: 0.3px;
            border-top: 1px solid rgba(76, 175, 80, 0.4);
            box-shadow: 0 -2px 12px rgba(27, 94, 32, 0.5);
        }
        .pih-footer .pih-name {
            font-weight: 700;
            color: #81c784;
        }
        .pih-footer .pih-copy {
            color: rgba(255,255,255,0.7);
        }

        .glass-panel {
            background: rgba(20, 24, 33, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
        }

        .ui.inverted.menu {
            background: rgba(14, 18, 26, 0.9) !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
            z-index: 9999 !important; /* Ensure menu stays above all panels */
        }

        /* Compact menu items to fit all on one row */
        .ui.fixed.menu .item {
            padding: 8px 10px !important;
            font-size: 13px !important;
        }
        .ui.fixed.menu .header.item {
            padding: 8px 10px 8px 8px !important;
        }
        .ui.fixed.menu .item > i.icon {
            margin-right: 4px !important;
        }
        .ui.fixed.menu .ui.dropdown .menu .item {
            font-size: 13px !important;
            padding: 10px 16px !important;
        }

        /* ── Dropdown menus styling ── */
        .ui.inverted.menu .ui.dropdown .menu,
        .ui.inverted.menu .nav-dropdown > .menu,
        .pih-dropdown-menu {
            background: rgba(14,18,26,0.97) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 8px !important;
            min-width: 200px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.5) !important;
        }
        .ui.inverted.menu .ui.dropdown .menu > .item,
        .ui.inverted.menu .ui.dropdown .menu > a.item,
        .ui.inverted.menu .nav-dropdown > .menu > .item,
        .ui.inverted.menu .nav-dropdown > .menu > a.item {
            color: #fff !important;
            transition: background 0.15s !important;
        }
        .ui.inverted.menu .ui.dropdown .menu > .item:hover,
        .ui.inverted.menu .ui.dropdown .menu > a.item:hover,
        .ui.inverted.menu .nav-dropdown > .menu > .item:hover,
        .ui.inverted.menu .nav-dropdown > .menu > a.item:hover {
            background: rgba(255,255,255,0.08) !important;
            color: #fff !important;
        }
        .ui.inverted.menu .ui.dropdown .menu > .item.active,
        .ui.inverted.menu .ui.dropdown .menu > a.item.active,
        .ui.inverted.menu .nav-dropdown > .menu > .item.active,
        .ui.inverted.menu .nav-dropdown > .menu > a.item.active {
            background: rgba(76,175,80,0.15) !important;
            color: #81c784 !important;
        }
        .ui.inverted.menu .ui.dropdown .menu .divider,
        .pih-dropdown-menu .divider {
            border-color: rgba(255,255,255,0.1) !important;
        }
        .nav-dropdown > .dropdown.icon {
            margin-left: 2px !important;
            font-size: 10px !important;
            opacity: 0.6;
        }
        .nav-dropdown > .text {
            display: inline !important;
        }

        /* User dropdown menu overrides */
        .ui.fixed.menu .right.menu .ui.dropdown .menu {
            background: #111827 !important;
        }
        .ui.fixed.menu .right.menu .ui.dropdown .menu > .item:hover,
        .ui.fixed.menu .right.menu .ui.dropdown .menu > a.item:hover {
            background: rgba(255,255,255,0.08) !important;
        }

        /* ── Hamburger toggle button ── */
        .hamburger-btn {
            display: none !important;
            cursor: pointer;
            font-size: 20px;
        }

        /* ── Mobile sidebar ── */
        .pih-sidebar {
            position: fixed;
            top: 0; left: -280px;
            width: 280px;
            height: 100vh;
            background: rgba(14, 18, 26, 0.98);
            backdrop-filter: blur(16px);
            border-right: 1px solid rgba(255,255,255,0.08);
            z-index: 10001;
            overflow-y: auto;
            transition: left 0.3s ease;
            padding-top: 12px;
        }
        .pih-sidebar.visible {
            left: 0;
        }
        .pih-sidebar .sidebar-close {
            position: absolute;
            top: 12px; right: 14px;
            font-size: 20px;
            color: rgba(255,255,255,0.6);
            cursor: pointer;
        }
        .pih-sidebar .sidebar-close:hover { color: #fff; }
        .pih-sidebar .sidebar-header {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 18px 18px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .pih-sidebar .sidebar-header img { width: 28px; height: 28px; }
        .pih-sidebar .sidebar-header span { font-weight: 700; font-size: 16px; color: #fff; }
        .pih-sidebar a.sidebar-item,
        .pih-sidebar .sidebar-section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 20px;
            color: rgba(255,255,255,0.85);
            font-size: 14px;
            text-decoration: none;
            transition: background 0.15s;
        }
        .pih-sidebar a.sidebar-item:hover {
            background: rgba(255,255,255,0.06);
            color: #fff;
        }
        .pih-sidebar a.sidebar-item.active {
            background: rgba(76,175,80,0.15);
            color: #81c784;
            border-left: 3px solid #4caf50;
        }
        .pih-sidebar .sidebar-section-title {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.35);
            padding-top: 16px;
            pointer-events: none;
        }
        .pih-sidebar .sidebar-divider {
            height: 1px;
            background: rgba(255,255,255,0.06);
            margin: 6px 16px;
        }
        .pih-sidebar-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 10000;
        }
        .pih-sidebar-overlay.visible { display: block; }

        /* ── Mobile Responsive Menu ── */
        @@media only screen and (max-width: 1400px) {
            .hamburger-btn {
                display: flex !important;
                font-size: 22px !important;
                padding: 8px 12px !important;
            }
            /* Hide all nav items except logo and hamburger on narrow screens */
            .ui.fixed.menu > a.item:not(.header):not(.hamburger-btn),
            .ui.fixed.menu > .ui.dropdown.item,
            .ui.fixed.menu > .nav-dropdown,
            .ui.fixed.menu > .right.menu {
                display: none !important;
            }
            .main-content {
                margin-top: 50px;
                height: calc(100vh - 50px - 28px);
            }
            #map-container {
                height: calc(100vh - 50px - 28px);
            }
            .pih-footer .pih-full { display: none; }
            .pih-footer .pih-short { display: inline; }
        }

        @@media only screen and (min-width: 1401px) {
            .pih-sidebar, .pih-sidebar-overlay { display: none !important; }
            .pih-footer .pih-short { display: none; }
        }

        #map-container {
            height: calc(100vh - 50px - 28px);
            width: 100vw;
        }

        /* Personalización de Highcharts para Dark Mode */
        .highcharts-container {
            background: transparent !important;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- ═══ Mobile Sidebar ═══ -->
    <div class="pih-sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
    <nav class="pih-sidebar" id="pihSidebar">
        <span class="sidebar-close" onclick="closeSidebar()"><i class="close icon"></i></span>
        <div class="sidebar-header">
            <img src="/img/logo-pih.svg" alt="PIH" />
            <span>PIH</span>
        </div>

        @if (!User.IsInRole("SoloVasos"))
        {
        <a class="sidebar-item" href="/Map"><i class="map icon" style="color:#4fc3f7;"></i> Mapa</a>

        <div class="sidebar-divider"></div>
        <div class="sidebar-section-title"><i class="broadcast tower icon"></i> Monitoreo</div>
        <a class="sidebar-item" href="/HourlyReport"><i class="clock outline icon" style="color:#4fc3f7;"></i> Cortes Horarios</a>
        <a class="sidebar-item" href="/RainfallReport"><i class="tint icon" style="color:#64b5f6;"></i> Corte de Lluvia</a>
        <a class="sidebar-item" href="@Url.Action("Index", "GoesMonitoring")"><i class="satellite icon" style="color:#ce93d8;"></i> GOES</a>

        <div class="sidebar-divider"></div>
        <div class="sidebar-section-title"><i class="chart line icon"></i> Análisis</div>
        <a class="sidebar-item" href="/DataAnalysis"><i class="chart area icon" style="color:#4fc3f7;"></i> Análisis de Datos</a>
        <a class="sidebar-item" href="/StationGroup"><i class="object group icon" style="color:#81c784;"></i> Mis Grupos</a>
        }

        <div class="sidebar-divider"></div>
        <div class="sidebar-section-title"><i class="water icon"></i> Hidrología</div>
        <a class="sidebar-item" href="/FunVasos"><i class="water icon" style="color:#64b5f6;"></i> Fun. Vasos</a>
        <a class="sidebar-item" href="/Bhg"><i class="chart bar icon" style="color:#81c784;"></i> Boletín BHG</a>
        @if (!User.IsInRole("SoloVasos"))
        {
        <a class="sidebar-item" href="@Url.Action("Index", "RainForecast")"><i class="cloud rain icon" style="color:#ce93d8;"></i> Pronóstico de Lluvia</a>
        }

        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrador"))
        {
            <div class="sidebar-divider"></div>
            <div class="sidebar-section-title"><i class="cogs icon"></i> Administración</div>
            <a class="sidebar-item" href="@Url.Action("Index", "StationAdmin")"><i class="server icon" style="color:#81c784;"></i> Estaciones</a>
            <a class="sidebar-item" href="@Url.Action("Index", "Maintenance")"><i class="wrench icon" style="color:#fbbf24;"></i> Mantenimiento</a>
            <a class="sidebar-item" href="@Url.Action("Index", "WatershedAdmin")"><i class="tint icon" style="color:#64b5f6;"></i> Cuencas y Subcuencas</a>
            <a class="sidebar-item" href="@Url.Action("Index", "Admin")"><i class="users cog icon" style="color:#ffb74d;"></i> Usuarios</a>
            <a class="sidebar-item" href="@Url.Action("Index", "Notification")"><i class="bell icon" style="color:#ce93d8;"></i> Notificaciones</a>
            <a class="sidebar-item" href="@Url.Action("Index", "EarlyWarning")"><i class="exclamation triangle icon" style="color:#e74c3c;"></i> Alertas Tempranas</a>
            @if (User.IsInRole("SuperAdmin"))
            {
            <a class="sidebar-item" href="@Url.Action("Index", "Settings")"><i class="sliders horizontal icon" style="color:#4fc3f7;"></i> Configuración</a>
            }
        }

        @if (!User.IsInRole("SoloVasos"))
        {
        <div class="sidebar-divider"></div>
        <div class="sidebar-section-title"><i class="toolbox icon"></i> Herramientas</div>
        <a class="sidebar-item" href="/Documents"><i class="folder open icon" style="color:#fbbf24;"></i> Repositorio</a>
        <a class="sidebar-item" href="@Url.Action("Index", "MisExport")"><i class="file export icon" style="color:#4fc3f7;"></i> Exportar .MIS</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="sidebar-item" href="@Url.Action("Index", "Chat")" id="sidebarChatLink"><i class="comments icon"></i> Chat <span class="dm-global-badge" id="sidebarDmBadge" style="display:none;"></span></a>
        }
        }

        <div class="sidebar-divider"></div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="sidebar-item" href="/Account/Logout"><i class="sign out alternate icon"></i> Cerrar sesión</a>
        }
        else
        {
            <a class="sidebar-item" href="/Account/Login"><i class="sign in alternate icon"></i> Iniciar sesión</a>
        }
    </nav>

    <div class="ui inverted borderless fixed menu" style="padding:0 8px;">
            <a href="/" class="header item" style="padding:8px 14px 8px 10px;gap:8px;">
                <img src="/img/logo-pih.svg" alt="PIH" style="width:30px;height:30px;" />
                <span style="font-weight:700;letter-spacing:0.5px;font-size:15px;">PIH</span>
