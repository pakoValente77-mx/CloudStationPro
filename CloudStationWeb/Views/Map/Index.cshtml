        function renderHistoryChart(containerId, data, variable) {
            const normalizedVar = variable.toLowerCase();
            const isWind = normalizedVar.includes('viento');
            
            const commonOptions = {
                chart: { 
                    backgroundColor: 'transparent', 
                    height: 250,
                    width: 310,
                    spacingBottom: 20,
                    spacingTop: 5,
                    spacingLeft: 5,
                    spacingRight: 5
                },
                title: { text: null },
                credits: { enabled: false },
                xAxis: { 
                    type: 'datetime',
                    labels: { style: { fontSize: '10px' } }
                },
                yAxis: { 
                    title: { text: null },
                    labels: { style: { fontSize: '10px' } }
                },
                legend: { enabled: false }
            };

            if (isWind) {
                renderWindRose(containerId, data);
            } else {
                Highcharts.chart(containerId, {
                    ...commonOptions,
                    chart: { ...commonOptions.chart, type: 'spline' },
                    series: [{
                        name: variable,
                        data: data.map(d => [new Date(d.ts).getTime(), d.valor]),
                        color: '#00c3ff',
                        lineWidth: 3,
                        marker: { enabled: false, states: { hover: { enabled: true } } }
                    }]
                });
            }
        }

        // ══════════════════════════════════════════════════════════════
        // ── WEATHER LAYERS ──────────────────────────────────────────────
        // ══════════════════════════════════════════════════════════════════
        let radarLayer = null;
        let goesIrLayer = null;
        let goesVisLayer = null;
        let goesWvLayer = null;
        let goesDayCloudLayer = null;
        let satelliteLayer = null;
        let owmTempLayer = null;
        let owmWindLayer = null;
        let owmCloudsLayer = null;
        let owmPressureLayer = null;
        let mrmsLayer = null;
        let lightningMarkers = null;
        let lightningInterval = null;

        // Manejo de errores de capas: remueve la capa del mapa y desactiva el toggle
        var _layerErrorShown = {};
        function handleLayerError(layer, layerName, toggleId) {
            if (_layerErrorShown[layerName]) return; // solo notificar una vez por capa
            _layerErrorShown[layerName] = true;
            console.warn('⚠️ Capa no disponible: ' + layerName);
            if (layer && map.hasLayer(layer)) {
                map.removeLayer(layer);
            }
            if (toggleId) {
                $(toggleId).checkbox('uncheck');
            }
            // Mostrar notificación al usuario (desaparece en 5s)
            var $toast = $('<div class="ui warning message" style="position:fixed;top:60px;right:20px;z-index:10000;max-width:350px;opacity:0.95;">' +
                '<i class="close icon"></i>' +
                '<div class="header">Capa no disponible</div>' +
                '<p><strong>' + layerName + '</strong> no se pudo cargar. El mapa base continúa funcionando normalmente.</p>' +
                '</div>');
            $toast.find('.close').on('click', function() { $toast.remove(); });
            $('body').append($toast);
            setTimeout(function() { $toast.fadeOut(400, function() { $toast.remove(); }); }, 5000);
        }

        function attachLayerErrorHandler(layer, layerName, toggleId) {
            if (!layer) return;
            var errorCount = 0;
            layer.on('tileerror', function() {
                errorCount++;
                // Tolerar algunos errores de tiles individuales, actuar después de 3
                if (errorCount >= 3) {
                    handleLayerError(layer, layerName, toggleId);
                }
            });
        }

        function loadWeatherLayers() {
            // 1. RainViewer Radar
            fetch('https://api.rainviewer.com/public/weather-maps.json')
                .then(r => r.json())
                .then(data => {
                    if (data && data.radar && data.radar.past && data.radar.past.length > 0) {
                        var latest = data.radar.past[data.radar.past.length - 1];
                        radarLayer = L.tileLayer(
                            data.host + latest.path + '/256/{z}/{x}/{y}/2/1_1.png',
                            { opacity: 0.65, zIndex: 5 }
                        );
                        attachLayerErrorHandler(radarLayer, 'Radar Precipitación (RainViewer)', '#toggle-radar');
                    }
                }).catch(err => {
                    console.warn('RainViewer:', err);
                    handleLayerError(null, 'Radar Precipitación (RainViewer)', '#toggle-radar');
                });

            // 2. GOES-16 Channel 13 (Infrared - Longwave)
            goesIrLayer = L.tileLayer.wms(
                'https://mesonet.agron.iastate.edu/cgi-bin/wms/goes_east.cgi',
                {
                    layers: 'fulldisk_ch13',
                    format: 'image/png',
                    transparent: true,
                    opacity: 0.5,
                    zIndex: 4,
                    attribution: 'GOES-16 NOAA'
                }
            );
            attachLayerErrorHandler(goesIrLayer, 'GOES-16 Infrarrojo', '#toggle-goes-ir');

            // 3. GOES-16 Channel 02 (Visible)
            goesVisLayer = L.tileLayer.wms(
                'https://mesonet.agron.iastate.edu/cgi-bin/wms/goes_east.cgi',
                {
                    layers: 'fulldisk_ch02',
                    format: 'image/png',
                    transparent: true,
                    opacity: 0.45,
                    zIndex: 4,
                    attribution: 'GOES-16 NOAA'
                }
            );
            attachLayerErrorHandler(goesVisLayer, 'GOES-16 Visible', '#toggle-goes-vis');

            // 4. GOES-16 Channel 09 (Water Vapor Mid-Level)
            goesWvLayer = L.tileLayer.wms(
                'https://mesonet.agron.iastate.edu/cgi-bin/wms/goes_east.cgi',
                {
                    layers: 'fulldisk_ch09',
                    format: 'image/png',
                    transparent: true,
                    opacity: 0.5,
                    zIndex: 4,
                    attribution: 'GOES-16 WV'
                }
            );
            attachLayerErrorHandler(goesWvLayer, 'GOES-16 Vapor de Agua', '#toggle-goes-wv');

            // 5. GOES-16 Day Cloud Phase RGB
            goesDayCloudLayer = L.tileLayer.wms(
                'https://mesonet.agron.iastate.edu/cgi-bin/wms/goes_east.cgi',
                {
                    layers: 'fulldisk_ch13',  // Fallback — uses IR enhanced
                    format: 'image/png',
                    transparent: true,
                    opacity: 0.45,
                    zIndex: 4,
                    attribution: 'GOES-16 IR Enhanced'
                }
            );
            attachLayerErrorHandler(goesDayCloudLayer, 'GOES-16 Nubes (IR Enhanced)', '#toggle-goes-daycloud');

            // 6. Google Satellite
            satelliteLayer = L.tileLayer(
                'http://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}',
                {
                    maxZoom: 20,
                    subdomains: ['mt0', 'mt1', 'mt2', 'mt3'],
                    attribution: '&copy; Google Satellite'
                }
            );
            attachLayerErrorHandler(satelliteLayer, 'Google Satellite', '#toggle-satellite');

            // 7. OpenWeatherMap — Temperature
            owmTempLayer = L.tileLayer(
                'https://tile.openweathermap.org/map/temp_new/{z}/{x}/{y}.png?appid=9de243494c0b295cca9337e1e96b00e2',
                { opacity: 0.5, zIndex: 3, attribution: 'OpenWeatherMap' }
            );
            attachLayerErrorHandler(owmTempLayer, 'Temperatura (OWM)', '#toggle-owm-temp');

            // 8. OpenWeatherMap — Wind Speed
            owmWindLayer = L.tileLayer(
                'https://tile.openweathermap.org/map/wind_new/{z}/{x}/{y}.png?appid=9de243494c0b295cca9337e1e96b00e2',
                { opacity: 0.5, zIndex: 3, attribution: 'OpenWeatherMap' }
            );
            attachLayerErrorHandler(owmWindLayer, 'Viento (OWM)', '#toggle-owm-wind');

            // 9. OpenWeatherMap — Clouds
            owmCloudsLayer = L.tileLayer(
                'https://tile.openweathermap.org/map/clouds_new/{z}/{x}/{y}.png?appid=9de243494c0b295cca9337e1e96b00e2',
                { opacity: 0.45, zIndex: 3, attribution: 'OpenWeatherMap' }
            );
            attachLayerErrorHandler(owmCloudsLayer, 'Nubes (OWM)', '#toggle-owm-clouds');

            // 10. OpenWeatherMap — Pressure
            owmPressureLayer = L.tileLayer(
                'https://tile.openweathermap.org/map/pressure_new/{z}/{x}/{y}.png?appid=9de243494c0b295cca9337e1e96b00e2',
                { opacity: 0.5, zIndex: 3, attribution: 'OpenWeatherMap' }
            );
            attachLayerErrorHandler(owmPressureLayer, 'Presión (OWM)', '#toggle-owm-pressure');

            // 11. MRMS (NOAA Composite Radar - Alta resolución)
            mrmsLayer = L.tileLayer.wms(
                'https://mesonet.agron.iastate.edu/cgi-bin/wms/us/mrms.cgi',
                {
                    layers: 'mrms_a2m',
                    format: 'image/png',
                    transparent: true,
                    opacity: 0.6,
                    zIndex: 5,
                    attribution: 'NOAA MRMS'
                }
            );
            attachLayerErrorHandler(mrmsLayer, 'MRMS Radar (NOAA)', '#toggle-mrms');

            // 12. Lightning markers
            lightningMarkers = L.layerGroup();
        }

        // Fetch recent lightning strikes from Blitzortung proxy
        function loadLightningData() {
            var bounds = map.getBounds();
            var url = 'https://map.blitzortung.org/GEOjson/1/10/0/' + 
                      Math.floor(bounds.getWest()) + '/' + Math.floor(bounds.getSouth()) + '/' + 
                      Math.ceil(bounds.getEast()) + '/' + Math.ceil(bounds.getNorth()) + '/';
            // Blitzortung direct API requires CORS — use fallback with RainViewer lightning
            fetch('https://api.rainviewer.com/public/weather-maps.json')
                .then(r => r.json())
                .then(data => {
                    if (data && data.radar && data.radar.past) {
                        // Use radar-inferred storm activity — display as animated overlay
                        // For actual lightning we use the simple icon approach below
                    }
                }).catch(() => {});
            
            // Simulated lightning from storm cells — in production, integrate WWLLN or Blitzortung websocket
            // For now, show the lightning layer toggling capability
            lightningMarkers.clearLayers();
        }

        function initWeatherToggles() {
            loadWeatherLayers();

            // Helper to wire up a toggle + optional opacity slider
            function wireToggle(toggleId, getLayer, opacityWrapId, opacityId) {
                $(toggleId).checkbox({
                    onChecked: function() { 
                        var lyr = getLayer(); 
                        if (lyr) { lyr.addTo(map); if (opacityWrapId) $(opacityWrapId).slideDown(150); }
                    },
                    onUnchecked: function() { 
                        var lyr = getLayer(); 
                        if (lyr && map.hasLayer(lyr)) { map.removeLayer(lyr); if (opacityWrapId) $(opacityWrapId).slideUp(150); }
                    }
                });
                if (opacityId) {
                    $(opacityId).on('input', function() { var lyr = getLayer(); if (lyr) lyr.setOpacity(this.value / 100); });
                }
            }

            // GOES Satellite
            wireToggle('#toggle-radar', () => radarLayer, '#radar-opacity-wrap', '#radar-opacity');
            wireToggle('#toggle-goes-ir', () => goesIrLayer, '#goes-ir-opacity-wrap', '#goes-ir-opacity');
            wireToggle('#toggle-goes-vis', () => goesVisLayer, '#goes-vis-opacity-wrap', '#goes-vis-opacity');
            wireToggle('#toggle-goes-wv', () => goesWvLayer, '#goes-wv-opacity-wrap', '#goes-wv-opacity');
            wireToggle('#toggle-goes-daycloud', () => goesDayCloudLayer, '#goes-daycloud-opacity-wrap', '#goes-daycloud-opacity');
            wireToggle('#toggle-satellite', () => satelliteLayer, null, null);

            // Surface Analysis
            wireToggle('#toggle-owm-temp', () => owmTempLayer, '#owm-temp-opacity-wrap', '#owm-temp-opacity');
            wireToggle('#toggle-owm-wind', () => owmWindLayer, '#owm-wind-opacity-wrap', '#owm-wind-opacity');
            wireToggle('#toggle-owm-clouds', () => owmCloudsLayer, '#owm-clouds-opacity-wrap', '#owm-clouds-opacity');
            wireToggle('#toggle-owm-pressure', () => owmPressureLayer, '#owm-pressure-opacity-wrap', '#owm-pressure-opacity');
            wireToggle('#toggle-mrms', () => mrmsLayer, '#mrms-opacity-wrap', '#mrms-opacity');

            // Lightning
            $('#toggle-lightning').checkbox({
                onChecked: function() { 
                    if (lightningMarkers) { lightningMarkers.addTo(map); loadLightningData(); lightningInterval = setInterval(loadLightningData, 60000); }
                },
                onUnchecked: function() { 
                    if (lightningMarkers && map.hasLayer(lightningMarkers)) map.removeLayer(lightningMarkers); 
                    if (lightningInterval) { clearInterval(lightningInterval); lightningInterval = null; }
                }
            });

            // Auto-refresh ALL active weather layers every 5 mins
            setInterval(function() {
                console.log('🔄 Auto-refresh capas meteorológicas...');

                // 1. Radar (RainViewer) — regenerar tile URL con último frame
                if (radarLayer && map.hasLayer(radarLayer)) {
                    map.removeLayer(radarLayer);
                    fetch('https://api.rainviewer.com/public/weather-maps.json')
                        .then(r => r.json())
                        .then(data => {
                            if (data && data.radar && data.radar.past && data.radar.past.length > 0) {
                                var latest = data.radar.past[data.radar.past.length - 1];
                                radarLayer = L.tileLayer(
                                    data.host + latest.path + '/256/{z}/{x}/{y}/2/1_1.png',
                                    { opacity: parseFloat($('#radar-opacity').val()) / 100, zIndex: 5 }
                                );
                                radarLayer.addTo(map);
                            }
                        }).catch(() => {});
                }

                // 2. WMS layers (GOES, MRMS) — invalidate cache con timestamp
                var ts = Date.now();
                [goesIrLayer, goesVisLayer, goesWvLayer, goesDayCloudLayer, mrmsLayer].forEach(function(lyr) {
                    if (lyr && map.hasLayer(lyr)) {
                        lyr.setParams({ _t: ts });
                    }
                });

                // 3. OWM tile layers — remove & re-add to force reload
                [
                    { layer: 'owmTempLayer', slider: '#owm-temp-opacity', zIdx: 3, type: 'temp_new' },
                    { layer: 'owmWindLayer', slider: '#owm-wind-opacity', zIdx: 3, type: 'wind_new' },
                    { layer: 'owmCloudsLayer', slider: '#owm-clouds-opacity', zIdx: 3, type: 'clouds_new' },
                    { layer: 'owmPressureLayer', slider: '#owm-pressure-opacity', zIdx: 3, type: 'pressure_new' }
                ].forEach(function(cfg) {
                    var lyr = window[cfg.layer] || eval(cfg.layer);
                    if (lyr && map.hasLayer(lyr)) {
                        var op = lyr.options.opacity;
                        map.removeLayer(lyr);
                        var newLyr = L.tileLayer(
                            'https://tile.openweathermap.org/map/' + cfg.type + '/{z}/{x}/{y}.png?appid=9de243494c0b295cca9337e1e96b00e2',
                            { opacity: op, zIndex: cfg.zIdx, attribution: 'OpenWeatherMap' }
                        );
                        newLyr.addTo(map);
                        // Update reference
                        if (cfg.layer === 'owmTempLayer') owmTempLayer = newLyr;
                        else if (cfg.layer === 'owmWindLayer') owmWindLayer = newLyr;
                        else if (cfg.layer === 'owmCloudsLayer') owmCloudsLayer = newLyr;
                        else if (cfg.layer === 'owmPressureLayer') owmPressureLayer = newLyr;
                    }
                });

            }, 300000);
        }

        // ══════════════════════════════════════════════════════════════
        // ── STATION WEATHER BANNER ──────────────────────────────────
        // ══════════════════════════════════════════════════════════════
        function showStationBanner(stationId) {
            $.getJSON('/Map/GetStationBanner', { stationId: stationId }, function(resp) {
                if (!resp || !resp.nombre) return;
                $('#banner-station-name').html('<i class="map marker alternate icon" style="color:#42a5f5;margin-right:4px;"></i>' + resp.nombre);
                if (resp.ultimaTx) {
                    $('#banner-tx-time').text('🕐 ' + new Date(resp.ultimaTx).toLocaleTimeString());
                } else {
                    $('#banner-tx-time').text('');
                }
                var html = '';
                if (resp.variables && resp.variables.length) {
                    resp.variables.forEach(function(v) {
                        var color = '#fff';
                        if (v.variable.includes('precipitaci')) color = '#42a5f5';
                        else if (v.variable.includes('temperat'))  color = '#ff7043';
                        else if (v.variable.includes('humedad'))   color = '#66bb6a';
                        else if (v.variable.includes('viento'))    color = '#fdd835';
                        else if (v.variable.includes('presion') || v.variable.includes('presión')) color = '#ce93d8';
                        else if (v.variable.includes('radiaci'))   color = '#ffab40';
                        else if (v.variable.includes('nivel') || v.variable.includes('cota')) color = '#4dd0e1';
                        else if (v.variable.includes('bater'))     color = '#a5d6a7';
                        var icon = '📊';
                        if (v.variable.includes('precipitaci')) icon = '🌧️';
                        else if (v.variable.includes('temperat'))  icon = '🌡️';
                        else if (v.variable.includes('humedad'))   icon = '💧';
                        else if (v.variable.includes('velocidad') && v.variable.includes('viento')) icon = '💨';
                        else if (v.variable.includes('direcci') && v.variable.includes('viento'))   icon = '🧭';
                        else if (v.variable.includes('presion') || v.variable.includes('presión'))  icon = '🔵';
                        else if (v.variable.includes('radiaci'))   icon = '☀️';
                        else if (v.variable.includes('nivel') || v.variable.includes('cota')) icon = '🌊';
                        else if (v.variable.includes('bater'))     icon = '🔋';
                        html += '<div class="metric">';
                        html += '<div class="metric-value" style="color:' + color + ';">' + icon + ' ' + (v.valor !== null ? v.valor.toFixed(2) : 'N/A') + '</div>';
                        html += '<div class="metric-label">' + v.unidad + '</div>';
                        html += '</div>';
                    });
                }
                $('#banner-metrics').html(html);
                $('#station-weather-banner').fadeIn(300);
            }).fail(function() {});
        }

        function renderWindRose(containerId, data) {
            // Agrupar datos por dirección (8 rumbos)
            // Filtrar valores nulos o anómalos (sensores dañados suelen dar -13107.2)
            const speedData = data.filter(d => d.variable === 'velocidad_del_viento' && d.valor !== null && d.valor >= 0);
            const dirData = data.filter(d => d.variable === 'dirección_del_viento' && d.valor !== null && d.valor >= 0);
            
            const roseData = [0,0,0,0,0,0,0,0]; // N, NE, E, SE, S, SW, W, NW
            const directions = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];

            speedData.forEach(s => {
                const d = dirData.find(dd => Math.abs(new Date(dd.ts) - new Date(s.ts)) < 600000);
                if (d) {
                    const angle = d.valor;
                    const index = Math.round(angle / 45) % 8;
                    roseData[index] += s.valor;
                }
            });

            Highcharts.chart(containerId, {
                chart: { polar: true, type: 'column', backgroundColor: 'transparent', height: 250 },
                title: { text: null },
                credits: { enabled: false },
                pane: { size: '85%' },
                legend: { enabled: false },
                xAxis: {
                    categories: directions,
                    tickmarkPlacement: 'on',
                    lineWidth: 0
                },
                yAxis: {
                    min: 0,
                    endOnTick: false,
                    showLastLabel: true,
                    title: { text: null },
                    labels: { enabled: false },
                    gridLineInterpolation: 'polygon'
                },
                series: [{
                    name: 'Viento',
                    data: roseData,
                    pointPlacement: 'on',
                    color: '#fbbd08'
                }]
            });
        }
    </script>
}
