@model CloudStationWeb.Models.StationAdminViewModel
@{
    ViewData["Title"] = $"Editar {Model.Estacion?.Nombre}";
}

<style>
    /* Styling to match CFE aesthetic */
    .glass-tab-segment {
        background: rgba(30,30,40, 0.85) !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        border-radius: 0 0 10px 10px !important;
        color: white !important;
        padding: 20px !important;
    }
    .ui.inverted.menu .item.active {
        background-color: #A0D800 !important;
        color: black !important;
        font-weight: bold !important;
    }
    #stationMap {
        height: 350px;
        width: 100%;
        border-radius: 10px;
        border: 2px solid var(--cfe-green);
        margin-top: 15px;
    }
</style>

<div class="ui container" style="margin-top: 30px; margin-bottom: 50px;">
    
    <div class="ui clearing basic segment" style="padding: 0; margin-bottom: 10px;">
        <h2 class="ui left floated header" style="color: white;">
            <i class="edit icon" style="color: var(--cfe-green);"></i>
            <div class="content">
                @Model.Estacion?.Nombre
                <div class="sub header" style="color: #bbb;">@Model.Estacion?.IdAsignado - Administrar Configuración</div>
            </div>
        </h2>
        <a href="@Url.Action("Index", "StationAdmin")" class="ui right floated inverted button">
            <i class="arrow left icon"></i> Volver al Catálogo
        </a>
    </div>

    <!-- MAIN FORM -->
    <form class="ui inverted form" method="post" action="@Url.Action("Edit", "StationAdmin")" id="editForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Estacion.Id" />

        <!-- TABS MENU -->
        <div class="ui top attached tabular inverted menu" style="border-bottom: 2px solid var(--cfe-green);">
            <a class="item active" data-tab="tab-general"><i class="cogs icon"></i> General & Ubicación</a>
            <a class="item" data-tab="tab-telemetry"><i class="satellite dish icon"></i> Telemetría</a>
            <a class="item" data-tab="tab-sensors"><i class="thermometer half icon"></i> Sensores</a>
            <a class="item" data-tab="tab-bitacora"><i class="history icon"></i> Bitácora</a>
        </div>

        <!-- TAB: GENERAL -->
        <div class="ui bottom attached active tab glass-tab-segment" data-tab="tab-general">
            <div class="ui stackable grid">
                <!-- Data Column -->
                <div class="eight wide column">
                    <h4 class="ui dividing inverted header">Identificadores</h4>
                    <div class="two fields">
                        <div class="field">
                            <label>Nombre de la Estación</label>
                            <input type="text" asp-for="Estacion.Nombre" required />
                        </div>
                        <div class="field">
                            <label>ID Asignado (Mapeo Interno)</label>
                            <input type="text" asp-for="Estacion.IdAsignado" />
                        </div>
                    </div>
                    <div class="field">
                        <label>Etiqueta / Alias</label>
                        <input type="text" asp-for="Estacion.Etiqueta" />
                    </div>

                    <h4 class="ui dividing inverted header">Clasificación Geográfica</h4>
                    <div class="two fields">
                        <div class="field">
                            <label>Cuenca</label>
                            <select class="ui search dropdown" asp-for="Estacion.IdCuenca">
                                <option value="">Select Cuenca...</option>
                                @foreach (var c in Model.Catalogs.Cuencas) {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="field">
                            <label>Subcuenca</label>
                            <select class="ui search dropdown" asp-for="Estacion.IdSubcuenca">
                                <option value="">Select Subcuenca...</option>
                                @foreach (var c in Model.Catalogs.Subcuencas) {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>
                    
                    <div class="three fields">
                        <div class="field">
                            <label>Estado</label>
                            <select class="ui search dropdown" asp-for="Estacion.IdEntidadFederativa">
                                <option value="">Select Estado...</option>
                                @foreach (var c in Model.Catalogs.Entidades) {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="field">
                            <label>Municipio</label>
                            <select class="ui search dropdown" asp-for="Estacion.IdMunicipio">
                                <option value="">Select Mun...</option>
                                @foreach (var c in Model.Catalogs.Municipios) {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="field">
                            <label>Organismo</label>
                             <select class="ui search dropdown" asp-for="Estacion.IdOrganismo">
                                <option value="">Select Org...</option>
                                @foreach (var c in Model.Catalogs.Organismos) {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>

                    <h4 class="ui dividing inverted header">Estado del Sitio</h4>
                    <div class="inline fields">
                        <div class="field">
                            <div class="ui toggle checkbox">
                                <input type="checkbox" asp-for="Estacion.Activo" class="hidden">
                                <label style="color:white !important;">Activa (Mantenimiento BD)</label>
                            </div>
                        </div>
                        <div class="field">
                            <div class="ui toggle checkbox">
                                <input type="checkbox" asp-for="Estacion.Visible" class="hidden">
                                <label style="color:white !important;">Visible en el Mapa Público</label>
                            </div>
                        </div>
                        <div class="field">
                            <div class="ui toggle checkbox">
                                <input type="checkbox" asp-for="Estacion.EsPresa" class="hidden">
                                <label style="color:white !important;">Es Presa</label>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Map Column -->
                <div class="eight wide column">
                    <h4 class="ui dividing inverted header">Coordenadas Exactas</h4>
                    <div class="two fields">
                        <div class="field">
                            <label>Latitud</label>
                            <input type="text" asp-for="Estacion.Latitud" id="latInput" />
                        </div>
                        <div class="field">
                            <label>Longitud</label>
                            <input type="text" asp-for="Estacion.Longitud" id="lngInput" />
                        </div>
                    </div>
                    <div class="field">
                        <label>String Geográfico (Auto-generado)</label>
                        <input type="text" asp-for="Estacion.Coordenadas" id="coordString" readonly style="background: rgba(0,0,0,0.5);" />
                    </div>
                    
                    <div class="ui message info inverted" style="background: rgba(0,100,255,0.2); margin-top: 10px;">
                        <i class="mouse pointer icon"></i> Da clic en el mapa para ajustar la posición automáticamente.
                    </div>
                    <div id="stationMap"></div>
                </div>
            </div>
        </div>

        <!-- TAB: TELEMETRY -->
        <div class="ui bottom attached tab glass-tab-segment" data-tab="tab-telemetry">
            
            <!-- MASTER SWITCHES -->
            <div class="ui segment inverted" style="background: rgba(0,0,0,0.4);">
                <h4 class="ui header" style="color: var(--cfe-green);">Rutas de Telemetría Habilitadas</h4>
                <div class="inline fields">
                    <div class="field">
                        <div class="ui slider checkbox">
                            <input type="checkbox" asp-for="Estacion.GOES" id="chkGoes" class="hidden">
                            <label style="color:white !important;"><i class="satellite icon"></i> GOES</label>
                        </div>
                    </div>
                    <div class="field">
                        <div class="ui slider checkbox">
                            <input type="checkbox" asp-for="Estacion.GPRS" id="chkGprs" class="hidden">
                            <label style="color:white !important;"><i class="wifi icon"></i> GPRS Celular</label>
                        </div>
                    </div>
                    <div class="field">
                        <div class="ui slider checkbox">
                            <input type="checkbox" asp-for="Estacion.RADIO" id="chkRadio" class="hidden">
                            <label style="color:white !important;"><i class="broadcast tower icon"></i> RADIO UHF/VHF</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="ui divider"></div>

            <div id="goesParamsSection" style="display: @(Model.Estacion.GOES ? "block" : "none");">
                <h3 class="ui header" style="color: white;"><i class="satellite icon"></i> Configuración Satelital (DatosGOES)</h3>
                <div class="ui inverted message warning">
                    Aquí se asocia la estación física con el <strong>ID Satelital del transmisor (DCP ID)</strong> real. Un ID incorrecto provocará cruce de datos.
                </div>
                
                @if(Model.GoesParams == null) { Model.GoesParams = new CloudStationWeb.Models.DatosGoesDto(); }
                <input type="hidden" asp-for="GoesParams.Id" />
                <input type="hidden" asp-for="GoesParams.IdEstacion" value="@Model.Estacion.Id"/>

                <div class="three fields">
                    <div class="field">
                        <label>DCP ID (IdSatelital Oficial)</label>
                        <input type="text" asp-for="GoesParams.IdSatelital" style="border: 1px solid var(--cfe-green); font-weight:bold;" />
                    </div>
                    <div class="field">
                        <label>Satélite Asignado</label>
                        <input type="text" asp-for="GoesParams.Satelite" />
                    </div>
                    <div class="field">
                        <label>Decodificador</label>
                        <input type="text" asp-for="GoesParams.Decodificador" />
                    </div>
                </div>

                <h4 class="ui inverted dividing header" style="color: #ccc;">Canales y Velocidades</h4>
                <div class="four fields">
                    <div class="field">
                        <label>Canal Primario</label>
                        <input type="number" asp-for="GoesParams.CanalPrimario" />
                    </div>
                    <div class="field">
                        <label>Velocidad (Primario)</label>
                        <input type="number" asp-for="GoesParams.Velocidad" />
                    </div>
                    <div class="field">
                        <label>Canal Alarma</label>
                        <input type="number" asp-for="GoesParams.CanalAlarma" />
                    </div>
                    <div class="field">
                        <label>Velocidad (Alarma)</label>
                        <input type="number" asp-for="GoesParams.VelocidadAlarma" />
                    </div>
                </div>

                <h4 class="ui inverted dividing header" style="color: #ccc;">Transmisión y Tiempos</h4>
                <div class="four fields">
                    <div class="field">
                        <label>Primera Transmisión</label>
                        <input type="text" asp-for="GoesParams.PrimeraTransmision" placeholder="HH:MM:SS" pattern="^([0-1]?[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$" title="Formato Militar 24H (HH:MM:SS)" />
                    </div>
                    <div class="field">
                        <label>Ventana Transmisión</label>
                        <input type="text" asp-for="GoesParams.VentanaTransmision" placeholder="HH:MM:SS" pattern="^([0-1]?[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$" title="Formato Militar 24H (HH:MM:SS)" />
                    </div>
                    <div class="field">
                        <label>Rango Transmisión</label>
                        <input type="text" asp-for="GoesParams.RangoTransmision" placeholder="HH:MM:SS" pattern="^([0-1]?[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$" title="Formato Militar 24H (HH:MM:SS)" />
                    </div>
                    <div class="field">
                        <label>Intervalo Transmisión</label>
                        <input type="text" asp-for="GoesParams.IntervaloTransmision" placeholder="HH:MM:SS" pattern="^([0-1]?[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$" title="Formato Militar 24H (HH:MM:SS)" />
                    </div>
                </div>
            </div>

            <div id="gprsParamsSection" style="display: @(Model.Estacion.GPRS ? "block" : "none"); margin-top: 30px;">
                <h3 class="ui header" style="color: white;"><i class="wifi icon"></i> Configuración Celular (DatosGPRS)</h3>
                @if(Model.GprsParams == null) { Model.GprsParams = new CloudStationWeb.Models.DatosGprsDto(); }
                <input type="hidden" asp-for="GprsParams.Id" />
                <input type="hidden" asp-for="GprsParams.IdEstacion" value="@Model.Estacion.Id"/>

                <div class="two fields">
                    <div class="field">
                        <label>Período de Transmisión (Mins/Horas)</label>
                        <input type="text" asp-for="GprsParams.PeriodoTransmision" placeholder="Ej. Cada 15 mins" />
                    </div>
                    <div class="field">
                        <label>Comentarios / Notas Internas</label>
                        <input type="text" asp-for="GprsParams.Comentarios" />
                    </div>
                </div>
            </div>

            <div id="radioParamsSection" style="display: @(Model.Estacion.RADIO ? "block" : "none"); margin-top: 30px;">
                <h3 class="ui header" style="color: white;"><i class="broadcast tower icon"></i> Configuración de RADIO (DatosRADIO)</h3>
                @if(Model.RadioParams == null) { Model.RadioParams = new CloudStationWeb.Models.DatosRadioDto(); }
                <input type="hidden" asp-for="RadioParams.Id" />
                <input type="hidden" asp-for="RadioParams.IdEstacion" value="@Model.Estacion.Id"/>

                <div class="two fields">
                    <div class="field">
                        <label>Período de Transmisión (Mins/Horas)</label>
                        <input type="text" asp-for="RadioParams.PeriodoTransmision" placeholder="Ej. Tiempo Real" />
                    </div>
                    <div class="field">
                        <label>Comentarios / Notas Internas</label>
                        <input type="text" asp-for="RadioParams.Comentarios" />
                    </div>
                </div>
            </div>

        </div>

        <!-- TAB: SENSORS (READ ONLY FOR NOW) -->
        <div class="ui bottom attached tab glass-tab-segment" data-tab="tab-sensors">
            <h3 class="ui header" style="color: white;">Sensores Registrados</h3>
            
            @if(Model.Sensores == null || !Model.Sensores.Any())
            {
                <div class="ui placeholder segment inverted" style="background:transparent; border: 1px dashed #555;">
                  <div class="ui icon header" style="color: #888;">
                    <i class="thermometer empty icon"></i>
                    No hay sensores mapeados a esta estación.
                  </div>
                </div>
            }
            else
            {
                <table class="ui inverted table structured">
                    <thead>
                        <tr>
                            <th>Orden</th>
                            <th>Icono</th>
                            <th>Variable (TipoSensor)</th>
                            <th>No. Serie</th>
                            <th>Unidad</th>
                            <th>Rango Validez (Min - Max)</th>
                            <th>Configuración Reporte</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var s in Model.Sensores)
                        {
                            <tr>
                                <td><div class="ui circular label">@(Model.Sensores.IndexOf(s) + 1)</div></td>
                                <td><i class="@s.Icono icon" style="color: var(--cfe-green);"></i></td>
                                <td style="font-weight:bold;">@s.TipoSensorNombre</td>
                                <td>@s.NumeroSensor</td>
                                <td>@s.UnidadMedidaNombre (@s.UnidadMedidaAbv)</td>
                                <td>
                                    @if(s.ValorMinimo.HasValue || s.ValorMaximo.HasValue) {
                                        <span style="color:#ffcc00;">[ @s.ValorMinimo  &rarr;  @s.ValorMaximo ]</span>
                                    } else {
                                        <span style="color: #666;">Sin límite configurado</span>
                                    }
                                </td>
                                <td>
                                    <div style="font-size: 0.9em; color: #ccc;">
                                        <strong>Período:</strong> @(s.PeriodoMuestra ?? 0) min<br/>
                                        <strong>Gráfica:</strong> @(string.IsNullOrEmpty(s.TipoGrafica) ? "Ninguna" : s.TipoGrafica)
                                    </div>
                                </td>
                                <td>
                                    @if(s.Activo) { <div class="ui green horizontal label" id="lbl-estado-@s.Id">Activo</div> } else { <div class="ui grey horizontal label" id="lbl-estado-@s.Id">Inactivo</div>}
                                </td>
                                <td>
                                    <button type="button" class="ui mini blue icon button" title="Editar Sensor" onclick="openSensorModal('@s.Id', '@s.TipoSensorNombre', '@s.NumeroSensor', '@(s.ValorMinimo.HasValue ? s.ValorMinimo.Value.ToString() : "")', '@(s.ValorMaximo.HasValue ? s.ValorMaximo.Value.ToString() : "")', '@(s.ValorMinError.HasValue ? s.ValorMinError.Value.ToString() : "")', '@(s.ValorMaxError.HasValue ? s.ValorMaxError.Value.ToString() : "")', '@s.Activo.ToString().ToLower()', '@(s.PeriodoMuestra ?? 0)', '@(s.TipoGrafica ?? "")', '@s.IdUnidadMedida')">
                                        <i class="edit icon"></i>
                                    </button>
                                    <button type="button" class="ui mini purple icon button" title="Configurar Umbrales de Gráfica" onclick="openUmbralesModal('@s.Id', '@s.TipoSensorNombre')">
                                        <i class="chart area icon"></i>
                                    </button>
                                    <button type="button" class="ui mini teal icon button" title="Gestionar Cotas de Valor" onclick="openCotasModal('@s.Id', '@s.TipoSensorNombre')">
                                        <i class="bullseye icon"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- TAB: BITACORA -->
        <div class="ui bottom attached tab glass-tab-segment" data-tab="tab-bitacora">
            <h3 class="ui header" style="color: white;">Historial de Mantenimiento y Eventos</h3>
            <div class="ui list inverted divided relaxed">
                @if(Model.Bitacora == null || !Model.Bitacora.Any())
                {
                    <div class="item">
                        <div class="content"><div class="header" style="color: #888;">No hay registros en bitácora.</div></div>
                    </div>
                }
                else
                {
                    @foreach(var b in Model.Bitacora)
                    {
                        <div class="item" style="padding: 15px 0;">
                            <i class="large calendar alternate outline middle aligned icon" style="color: var(--cfe-green);"></i>
                            <div class="content">
                                <a class="header" style="color: white; font-size:1.1em;">@(b.FechaEvento ?? b.FechaRegistro)</a>
                                <div class="description" style="color: #ccc; margin-top:5px;">
                                    <strong>Registró:</strong> @(b.UsuarioNombreCompleto ?? b.Usuario ?? "N/A") <br/>
                                    <strong>Descripción:</strong> <i>@b.Descripcion</i>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- SAVE BUTTON -->
        <div class="ui divider" style="border-top: 1px solid rgba(255,255,255,0.1); margin-top:20px;"></div>
        <div class="ui right aligned grid" style="padding-bottom: 20px;">
            <div class="column">
                <a href="@Url.Action("Index", "StationAdmin")" class="ui cancel inverted button">
                    <i class="left arrow icon"></i> Cancelar
                </a>
                <button type="submit" class="ui large button" style="background-color: #A0D800 !important; color: black !important; font-weight: bold; min-width: 200px;">
                    <i class="save icon"></i> Guardar Cambios
                </button>
            </div>
        </div>
    </form>
</div>

<!-- SENSOR EDIT MODAL -->
<div class="ui small inverted modal" id="sensorEditModal">
    <div class="header" style="background: rgba(20,24,33,1); border-bottom: 1px solid rgba(255,255,255,0.1); color: var(--cfe-green);">
        <i class="thermometer half icon"></i> Editar Configuración de Sensor
    </div>
    <div class="scrolling content" style="background: rgba(30,30,40,1); max-height: 50vh; overflow-y: auto;">
        <form class="ui inverted form" id="sensorEditForm">
            <input type="hidden" id="modalSensorId">
            <h4 class="ui inverted header" id="modalSensorNombre" style="color: white; margin-bottom: 20px;">Tipo Sensor</h4>
            
            <div class="three fields">
                <div class="field">
                    <label>No. Serie / Identificador</label>
                    <input type="text" id="modalSensorSerie">
                </div>
                <div class="field">
                    <label>Unidad de Medida</label>
                    <select class="ui search dropdown" id="modalSensorUnidad">
                        <option value="">Sin Unidad</option>
                        @foreach (var um in Model.Catalogs.UnidadesMedida)
                        {
                            <option value="@um.Id">@um.Nombre</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Estado Activo</label>
                    <div class="ui toggle checkbox" style="margin-top:10px;">
                        <input type="checkbox" id="modalSensorActivo">
                        <label style="color:white !important;">Habilitado</label>
                    </div>
                </div>
            </div>

            <div class="two fields">
                <div class="field">
                    <label>Valor Mínimo Físico</label>
                    <input type="number" step="any" id="modalSensorMin">
                </div>
                <div class="field">
                    <label>Valor Máximo Físico</label>
                    <input type="number" step="any" id="modalSensorMax">
                </div>
            </div>

            <div class="two fields">
                <div class="field">
                    <label>Valor Mínimo Error (Descarte)</label>
                    <input type="number" step="any" id="modalSensorMinError" placeholder="Valores menores se descartan">
                </div>
                <div class="field">
                    <label>Valor Máximo Error (Descarte)</label>
                    <input type="number" step="any" id="modalSensorMaxError" placeholder="Valores mayores se descartan">
                </div>
            </div>

            <h4 class="ui dividing inverted header">Comportamiento en Motor Visual</h4>
            <div class="two fields">
                <div class="field">
                    <label>Periodo de Muestra (Minutos)</label>
                    <input type="number" id="modalSensorPeriodo" min="0">
                </div>
                <div class="field">
                    <label>Tipo de Gráfica Default</label>
                    <select class="ui dropdown" id="modalSensorGrafica">
                        <option value="">Selecciona tipo de gráfica</option>
                        <option value="line">Línea Suave (Spline)</option>
                        <option value="column">Columnas / Barras</option>
                        <option value="area">Área Rellena</option>
                        <option value="scatter">Dispersión (Puntos)</option>
                    </select>
                </div>
            </div>
            
            <div class="ui error message" id="sensorErrorMsg" style="display:none;"></div>
        </form>
    </div>
    <div class="actions" style="background: rgba(20,24,33,1); border-top: 1px solid rgba(255,255,255,0.1);">
        <div class="ui cancel inverted button">Cancelar</div>
        <button class="ui positive button" style="background-color: #A0D800 !important; color: black !important; font-weight: bold;" onclick="saveSensorModal()">Guardar Sensor</button>
    </div>
</div>

<!-- UMBRALES MODAL -->
<div class="ui large inverted modal" id="umbralesModal">
    <div class="header" style="background: rgba(20,24,33,1); border-bottom: 1px solid rgba(255,255,255,0.1); color: #a855f7;">
        <i class="chart area icon"></i> Umbrales de Gráfica: <span id="umbralesSensorName"></span>
    </div>
    <div class="content" style="background: rgba(30,30,40,1); max-height: 60vh; overflow-y:auto;">
        <input type="hidden" id="currentUmbralSensorId">
        
        <table class="ui celled inverted selectable table" id="umbralesTable">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Valor Ref.</th>
                    <th>Color</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="umbralesTableBody">
                <!-- Dynamically populated -->
            </tbody>
        </table>

        <!-- Form to add new / edit umbral -->
        <div class="ui inverted segment" style="margin-top: 20px; border: 1px solid rgba(255,255,255,0.2);">
            <h4 class="ui inverted header" id="umbralFormTitle">Registrar Nuevo Umbral</h4>
            <form class="ui inverted form" id="umbralForm">
                <input type="hidden" id="uId" value="0">
                <div class="four fields">
                    <div class="field">
                        <label>Nombre Umbral (Ej. NAMO)</label>
                        <input type="text" id="uNombre" required>
                    </div>
                    <div class="field">
                        <label>Valor Referencia</label>
                        <input type="number" step="any" id="uValor" required>
                    </div>
                    <div class="field">
                        <label>Color (Hex)</label>
                        <input type="color" id="uColor" style="width:100%; height:40px; padding:0;">
                    </div>
                    <div class="field" style="display: flex; align-items: flex-end;">
                        <button type="button" class="ui purple button" style="width:100%;" onclick="saveUmbral()">Guardar Umbral</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <div class="actions" style="background: rgba(20,24,33,1); border-top: 1px solid rgba(255,255,255,0.1);">
        <div class="ui cancel inverted button">Cerrar</div>
    </div>
</div>

<!-- COTAS MODAL -->
<div class="ui large inverted modal" id="cotasModal">
    <div class="header" style="background: rgba(20,24,33,1); border-bottom: 1px solid rgba(255,255,255,0.1); color: #00b5ad;">
        <i class="bullseye icon"></i> Historial de Cotas: <span id="cotasSensorName"></span>
    </div>
    <div class="content" style="background: rgba(30,30,40,1); max-height: 60vh; overflow-y:auto;">
        <input type="hidden" id="currentCotaSensorId">
        
        <table class="ui celled inverted selectable table" id="cotasTable">
            <thead>
                <tr>
                    <th>Fecha Inicio</th>
                    <th>Vigencia</th>
                    <th>Valor de Ajuste (Cota)</th>
                    <th>Auditoría</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="cotasTableBody">
                <!-- Dynamically populated via AJAX API -->
            </tbody>
        </table>

        <!-- Form to add new cota -->
        <div class="ui inverted segment" style="margin-top: 20px; border: 1px solid rgba(255,255,255,0.2);">
            <h4 class="ui inverted header" id="cotaFormTitle">Registrar Nueva Cota / Desfase</h4>
            <div class="ui inverted message info">
                La cota es el valor que se debe <strong>Sumar</strong> o <strong>Restar</strong> a la lectura pura del sensor para calibrarlo. Escriba el valor en positivo y elija el operador matemático.
            </div>
            <form class="ui inverted form" id="cotaForm">
                <input type="hidden" id="cId" value="">
                
                <div class="two fields">
                    <div class="field">
                        <label>Diferencial / Valor de Cota</label>
                        <div class="ui right labeled input">
                            <input type="number" step="any" id="cValor" required placeholder="Ej. 10.5">
                            <div class="ui dropdown label" id="cOperadorSelect">
                                <i class="dropdown icon"></i>
                                <span class="text">Operador</span>
                                <div class="menu">
                                    <div class="item" data-value="+"><i class="plus icon"></i> Sumar (+)</div>
                                    <div class="item" data-value="-"><i class="minus icon"></i> Restar (-)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="fields">
                    <div class="five wide field">
                        <label>Fecha de Inicio</label>
                        <input type="date" id="cFechaInicioDate">
                    </div>
                    <div class="three wide field">
                        <label>Hora de Inicio</label>
                        <input type="time" id="cFechaInicioTime" value="00:00">
                    </div>
                    <div class="two wide field" style="display:flex; align-items:flex-end; padding-bottom:10px;">
                        <div class="ui checkbox" id="chkFinVigencia">
                            <input type="checkbox" id="cFin">
                            <label style="color:white !important;">Fin de Vigencia</label>
                        </div>
                    </div>
                    <div class="four wide field disabled" id="fieldFechaFin">
                        <label>Fecha Final</label>
                        <input type="date" id="cFechaFinalDate">
                    </div>
                    <div class="two wide field disabled" id="fieldHoraFin">
                        <label>Hora Final</label>
                        <input type="time" id="cFechaFinalTime" value="00:00">
                    </div>
                </div>

                <div class="field" style="text-align: right;">
                    <button type="button" class="ui teal button" onclick="saveCota()">
                        <i class="save icon"></i> Guardar Cota
                    </button>
                    <button type="button" class="ui basic inverted button" onclick="resetCotaForm()">
                        Limpiar Formulario
                    </button>
                </div>
            </form>
        </div>
    </div>
    <div class="actions" style="background: rgba(20,24,33,1); border-top: 1px solid rgba(255,255,255,0.1);">
        <div class="ui cancel inverted button">Cerrar</div>
    </div>
</div>

@section Scripts {
    <script>
        var stationUmbrales = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Umbrales));
        
        $(document).ready(function() {
            // Semantic UI Init
            $('.menu .item').tab();
            $('.ui.dropdown').dropdown({ fullTextSearch: true });
            $('.ui.checkbox').checkbox();

            // Toggle GOES Section dynamically
            $('#chkGoes').parent().checkbox({
                onChange: function() {
                    $('#goesParamsSection').slideToggle($(this).is(':checked'));
                }
            });

            // Toggle GPRS Section dynamically
            $('#chkGprs').parent().checkbox({
                onChange: function() {
                    $('#gprsParamsSection').slideToggle($(this).is(':checked'));
                }
            });

            // Toggle RADIO Section dynamically
            $('#chkRadio').parent().checkbox({
                onChange: function() {
                    $('#radioParamsSection').slideToggle($(this).is(':checked'));
                }
            });

            // --- LEAFLET MAP LOGIC ---
            var defaultLat = @(Model.Estacion.Latitud ?? 19.4326);
            var defaultLng = @(Model.Estacion.Longitud ?? -99.1332);
            var isNew = @(Model.Estacion.Latitud == null ? "true" : "false");

            var map = L.map('stationMap', {
                center: [defaultLat, defaultLng],
                zoom: isNew ? 5 : 12, // zoom out if no default pos exists
                minZoom: 4,
                maxZoom: 18,
                attributionControl: false
            });

            // Google Maps Terrain (relieve topográfico)
            L.tileLayer('http://{s}.google.com/vt/lyrs=p&x={x}&y={y}&z={z}', {
                attribution: '&copy; Google Maps',
                subdomains: ['mt0', 'mt1', 'mt2', 'mt3'],
                maxZoom: 20
            }).addTo(map);

            var marker = L.marker([defaultLat, defaultLng], {
                draggable: true
            }).addTo(map);

            // Function to update inputs when map changes
            function updateCoordinates(lat, lng) {
                $('#latInput').val(lat.toFixed(6));
                $('#lngInput').val(lng.toFixed(6));
                $('#coordString').val(lat.toFixed(6) + ', ' + lng.toFixed(6));
            }

            // On Drag map pin
            marker.on('dragend', function (e) {
                var position = marker.getLatLng();
                updateCoordinates(position.lat, position.lng);
            });

            // On Click map
            map.on('click', function(e) {
                marker.setLatLng(e.latlng);
                updateCoordinates(e.latlng.lat, e.latlng.lng);
            });

            // If manual text change -> update map pin
            $('#latInput, #lngInput').on('change', function() {
                var lat = parseFloat($('#latInput').val());
                var lng = parseFloat($('#lngInput').val());
                if(!isNaN(lat) && !isNaN(lng)) {
                    marker.setLatLng([lat, lng]);
                    map.panTo([lat, lng]);
                    $('#coordString').val(lat.toFixed(6) + ', ' + lng.toFixed(6));
                }
            });

            // Due to CSS rendering, maps inside hidden semantic UI tabs load with bad layout width
            // Force redraw when "General" tab is activated
            $('.menu .item[data-tab="tab-general"]').on('click', function() {
                setTimeout(function(){
                    map.invalidateSize();
                }, 100);
            });
            // Also call it once on init
            setTimeout(function(){ map.invalidateSize(); }, 500);
        });

        // --- SENSOR MODAL LOGIC ---
        function openSensorModal(id, nombre, serie, min, max, minError, maxError, activo, periodo, grafica, idUnidad) {
            $('#modalSensorId').val(id);
            $('#modalSensorNombre').text(nombre);
            $('#modalSensorSerie').val(serie);
            $('#modalSensorMin').val(min);
            $('#modalSensorMax').val(max);
            $('#modalSensorMinError').val(minError);
            $('#modalSensorMaxError').val(maxError);
            $('#modalSensorPeriodo').val(periodo);
            
            // Set the dropdown value safely
            $('#modalSensorGrafica').dropdown('set selected', grafica || '');
            $('#modalSensorUnidad').dropdown('set selected', idUnidad || '');
            
            if(activo === 'true') {
                $('#modalSensorActivo').prop('checked', true);
            } else {
                $('#modalSensorActivo').prop('checked', false);
            }

            $('#sensorErrorMsg').hide();
            $('#sensorEditModal').modal('show');
        }

        function saveSensorModal() {
            var data = {
                Id: $('#modalSensorId').val(),
                NumeroSensor: $('#modalSensorSerie').val(),
                ValorMinimo: $('#modalSensorMin').val() ? parseFloat($('#modalSensorMin').val()) : null,
                ValorMaximo: $('#modalSensorMax').val() ? parseFloat($('#modalSensorMax').val()) : null,
                ValorMinError: $('#modalSensorMinError').val() ? parseFloat($('#modalSensorMinError').val()) : null,
                ValorMaxError: $('#modalSensorMaxError').val() ? parseFloat($('#modalSensorMaxError').val()) : null,
                PeriodoMuestra: $('#modalSensorPeriodo').val() ? parseInt($('#modalSensorPeriodo').val()) : null,
                TipoGrafica: $('#modalSensorGrafica').val(),
                IdUnidadMedida: $('#modalSensorUnidad').val() || null,
                Activo: $('#modalSensorActivo').is(':checked')
            };

            // Basic validation
            if (data.ValorMinimo !== null && data.ValorMaximo !== null && data.ValorMinimo > data.ValorMaximo) {
                $('#sensorErrorMsg').text("El valor mínimo no puede ser mayor que el máximo.").show();
                return;
            }

            $.ajax({
                type: "POST",
                url: "/StationAdmin/UpdateSensor",
                data: JSON.stringify(data),
                contentType: "application/json; charset=utf-8",
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                success: function (response) {
                    if (response.success) {
                        $('#sensorEditModal').modal('hide');
                        // Optional: show a small toast or just let the user know, then reload to see changes
                        location.reload(); 
                    } else {
                        $('#sensorErrorMsg').text(response.message || "Error al actualizar").show();
                    }
                },
                error: function () {
                    $('#sensorErrorMsg').text("Falla de red o de servidor interno.").show();
                }
            });
        }

        // --- UMBRALES MODAL LOGIC ---
        function openUmbralesModal(sensorId, sensorName) {
            $('#currentUmbralSensorId').val(sensorId);
            $('#umbralesSensorName').text(sensorName);
            
            resetUmbralForm();
            renderUmbralesTable(sensorId);
            
            $('#umbralesModal').modal('show');
        }

        function renderUmbralesTable(sensorId) {
            var tbody = $('#umbralesTableBody');
            tbody.empty();
            
            var matched = stationUmbrales.filter(function(u) { return u.IdSensor === sensorId; });
            
            if (matched.length === 0) {
                tbody.append('<tr><td colspan="4" class="center aligned" style="color:#888;">No hay umbrales registrados para este sensor.</td></tr>');
                return;
            }

            matched.forEach(function(u) {
                var cColor = u.Color || '#ffffff';
                var row = `<tr>
                    <td>${u.Nombre}</td>
                    <td>${u.ValorReferencia}</td>
                    <td><div style="background-color:${cColor}; width:20px; height:20px; border-radius:3px; display:inline-block; vertical-align:middle; margin-right:5px;"></div> ${cColor}</td>
                    <td>
                        <button class="ui mini blue icon button" title="Editar" onclick="editUmbral(${u.Id})"><i class="edit icon"></i></button>
                        <button class="ui mini red icon button" title="Eliminar" onclick="deleteUmbral(${u.Id})"><i class="trash icon"></i></button>
                    </td>
                </tr>`;
                tbody.append(row);
            });
        }

        function resetUmbralForm() {
            $('#uId').val('0');
            $('#uNombre').val('');
            $('#uValor').val('');
            $('#uColor').val('#ffffff');
            $('#umbralFormTitle').text('Registrar Nuevo Umbral');
        }

        function editUmbral(id) {
            var umb = stationUmbrales.find(function(u) { return u.Id === id; });
            if(umb) {
                $('#uId').val(umb.Id);
                $('#uNombre').val(umb.Nombre);
                $('#uValor').val(umb.ValorReferencia);
                $('#uColor').val(umb.Color || '#ffffff');
                $('#umbralFormTitle').text('Editando Umbral: ' + umb.Nombre);
            }
        }

        function saveUmbral() {
            var sensorId = $('#currentUmbralSensorId').val();
            var nombre = $('#uNombre').val();
            var valor = $('#uValor').val();
            
            if(!nombre || !valor) {
                alert("Por favor ingresa Nombre y Valor Referencia");
                return;
            }

            var payload = {
                Id: parseInt($('#uId').val()),
                IdSensor: sensorId,
                Nombre: nombre,
                ValorReferencia: parseFloat(valor),
                Umbral: 0, 
                Operador: '-',
                Activo: true,
                Periodo: 0,
                Color: $('#uColor').val()
            };

            $.ajax({
                type: "POST",
                url: "/StationAdmin/SaveUmbral",
                data: JSON.stringify(payload),
                contentType: "application/json; charset=utf-8",
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                success: function (r) {
                    if (r.success) {
                        // Update local array
                        var existingIndex = stationUmbrales.findIndex(function(u) { return u.Id === r.umbral.Id; });
                        if(existingIndex >= 0) {
                            stationUmbrales[existingIndex] = r.umbral;
                        } else {
                            stationUmbrales.push(r.umbral);
                        }
                        resetUmbralForm();
                        renderUmbralesTable(sensorId);
                    } else {
                        alert("Error: " + r.message);
                    }
                },
                error: function() { alert("Falla de red."); }
            });
        }

        function deleteUmbral(id) {
            if(!confirm("¿Seguro que deseas eliminar este umbral permanentemente?")) return;

            $.ajax({
                type: "POST",
                url: "/StationAdmin/DeleteUmbral?id=" + id,
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                success: function (r) {
                    if (r.success) {
                        // Remove from local array
                        stationUmbrales = stationUmbrales.filter(function(u) { return u.Id !== id; });
                        var sensorId = $('#currentUmbralSensorId').val();
                        renderUmbralesTable(sensorId);
                    } else {
                        alert("Error: " + r.message);
                    }
                },
                error: function() { alert("Falla de red."); }
            });
        }

        // --- COTAS MODAL LOGIC ---
        
        // Manejo del checkbox de Fin de Vigencia
        $('#cFin').on('change', function() {
            if($(this).is(':checked')) {
                $('#fieldFechaFin').removeClass('disabled');
                $('#fieldHoraFin').removeClass('disabled');
            } else {
                $('#fieldFechaFin').addClass('disabled');
                $('#fieldHoraFin').addClass('disabled');
                $('#cFechaFinalDate').val('');
                $('#cFechaFinalTime').val('00:00');
            }
        });

        function openCotasModal(sensorId, sensorName) {
            $('#currentCotaSensorId').val(sensorId);
            $('#cotasSensorName').text(sensorName);
            
            resetCotaForm();
            loadCotasTable(sensorId);
            
            // Inicializar dropdown del operador
            $('#cOperadorSelect').dropdown();
            
            $('#cotasModal').modal('show');
        }

        function loadCotasTable(sensorId) {
            var tbody = $('#cotasTableBody');
            tbody.html('<tr><td colspan="5" class="center aligned"><div class="ui active centered inline loader"></div> Cargando historial...</td></tr>');
            
            $.ajax({
                type: "GET",
                url: "/StationAdmin/GetCotas?sensorId=" + sensorId,
                success: function (r) {
                    tbody.empty();
                    if (r.success) {
                        if(r.cotas.length === 0) {
                            tbody.append('<tr><td colspan="5" class="center aligned" style="color:#888;">No hay historial de cotas para este sensor.</td></tr>');
                        } else {
                            r.cotas.forEach(function(c) {
                                var finText = c.fin ? (c.fechaFinal ? new Date(c.fechaFinal).toLocaleString() : 'Sí') : 'Vigente';
                                var btnFin = c.fin ? '' : `<div class="ui yellow horizontal label">Vigente Actual</div>`;
                                var opr = c.operador === '+' ? '<span style="color:var(--cfe-green)">+</span> ' : '<span style="color:#ff3366">-</span> ';
                                
                                var userReg = c.nombreCompleto || c.idUsuarioRegistra || 'Admin';
                                var dtReg= c.fechaRegistro || 'N/A';
                                
                                var row = `<tr>
                                    <td>${c.fechaInicio ? new Date(c.fechaInicio).toLocaleString() : 'N/A'}</td>
                                    <td>${finText} ${btnFin}</td>
                                    <td style="font-size:1.1em; font-weight:bold;">${opr}${c.valorCota}</td>
                                    <td style="font-size:0.85em; color:#ccc;">
                                        Registró: ${userReg}<br/>
                                        <i class="clock outline icon"></i> ${dtReg}
                                    </td>
                                    <td>
                                        <button class="ui mini blue icon button" title="Editar Cota" onclick="editCota('${c.id}', ${c.valorCota}, '${c.operador}', '${c.fechaInicio || ''}', ${c.fin ? 'true' : 'false'}, '${c.fechaFinal || ''}')">
                                            <i class="edit icon"></i>
                                        </button>
                                        <button class="ui mini red icon button" title="Eliminar Permanente" onclick="deleteCota('${c.id}')">
                                            <i class="trash icon"></i>
                                        </button>
                                    </td>
                                </tr>`;
                                tbody.append(row);
                            });
                        }
                    } else {
                        tbody.append(`<tr><td colspan="5" style="color:#ff3366;">Error: ${r.message}</td></tr>`);
                    }
                },
                error: function() { 
                    tbody.html('<tr><td colspan="5" style="color:#ff3366;">Falla de red al consultar historial.</td></tr>');
                }
            });
        }

        function resetCotaForm() {
            $('#cId').val('');
            $('#cValor').val('');
            $('#cOperadorSelect').dropdown('clear');
            $('#cFechaInicioDate').val('');
            $('#cFechaInicioTime').val('00:00');
            
            $('#cFin').prop('checked', false);
            $('#fieldFechaFin').addClass('disabled');
            $('#fieldHoraFin').addClass('disabled');
            $('#cFechaFinalDate').val('');
            $('#cFechaFinalTime').val('00:00');
            $('#cotaFormTitle').text('Registrar Nueva Cota / Desfase');
        }

        function parseDateParts(dateString) {
            if(!dateString) return { date: '', time: '00:00' };
            var d = new Date(dateString);
            var year = d.getFullYear();
            var month = String(d.getMonth() + 1).padStart(2, '0');
            var day = String(d.getDate()).padStart(2, '0');
            var hours = String(d.getHours()).padStart(2, '0');
            var mins = String(d.getMinutes()).padStart(2, '0');
            return { date: year + '-' + month + '-' + day, time: hours + ':' + mins };
        }

        function editCota(id, valorCota, operador, fechaInicio, fin, fechaFinal) {
            $('#cId').val(id);
            $('#cValor').val(valorCota);
            $('#cOperadorSelect').dropdown('set selected', operador);
            
            if(fechaInicio) {
                var fi = parseDateParts(fechaInicio);
                $('#cFechaInicioDate').val(fi.date);
                $('#cFechaInicioTime').val(fi.time);
            } else {
                $('#cFechaInicioDate').val('');
                $('#cFechaInicioTime').val('00:00');
            }
            
            if(fin) {
                $('#cFin').prop('checked', true);
                $('#fieldFechaFin').removeClass('disabled');
                $('#fieldHoraFin').removeClass('disabled');
                if(fechaFinal) {
                    var ff = parseDateParts(fechaFinal);
                    $('#cFechaFinalDate').val(ff.date);
                    $('#cFechaFinalTime').val(ff.time);
                }
            } else {
                $('#cFin').prop('checked', false);
                $('#fieldFechaFin').addClass('disabled');
                $('#fieldHoraFin').addClass('disabled');
                $('#cFechaFinalDate').val('');
                $('#cFechaFinalTime').val('00:00');
            }
            
            $('#cotaFormTitle').text('Editar Cota / Desfase');
        }

        function combineDatetime(dateVal, timeVal) {
            if (!dateVal) return null;
            var t = timeVal || '00:00';
            return dateVal + 'T' + t + ':00';
        }

        function saveCota() {
            var sensorId = $('#currentCotaSensorId').val();
            var valor = $('#cValor').val();
            var operador = $('#cOperadorSelect').dropdown('get value');
            var fechaInicioDate = $('#cFechaInicioDate').val();
            var fechaInicioTime = $('#cFechaInicioTime').val();
            var isFin = $('#cFin').is(':checked');
            var fechaFinDate = $('#cFechaFinalDate').val();
            var fechaFinTime = $('#cFechaFinalTime').val();
            
            if(!valor || !operador) {
                alert("Los campos Valor y Operador son obligatorios.");
                return;
            }
            if(isFin && !fechaFinDate) {
                alert("Has indicado que tiene Fin de Vigencia, debes seleccionar la Fecha Final.");
                return;
            }

            var payload = {
                id: parseInt($('#cId').val() || "0"),
                idSensor: sensorId,
                valorCota: parseFloat(valor),
                operador: operador,
                fechaInicio: combineDatetime(fechaInicioDate, fechaInicioTime),
                fin: isFin,
                fechaFinal: isFin ? combineDatetime(fechaFinDate, fechaFinTime) : null
            };

            console.log('SaveCota payload:', JSON.stringify(payload));

            $.ajax({
                type: "POST",
                url: "/StationAdmin/SaveCota",
                data: JSON.stringify(payload),
                contentType: "application/json; charset=utf-8",
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                success: function (r) {
                    if (r.success) {
                        resetCotaForm();
                        loadCotasTable(sensorId);
                    } else {
                        alert("Error: " + r.message);
                    }
                },
                error: function(xhr) { 
                    console.error('SaveCota error:', xhr.status, xhr.responseText);
                    alert("Falla de red al guardar. Status: " + xhr.status); 
                }
            });
        }

        function deleteCota(id) {
            if(!confirm("¿CONFIRMAS eliminar esta asignación de Cota de la bitácora? Esto provocará que valores históricos cambien.")) return;

            $.ajax({
                type: "POST",
                url: "/StationAdmin/DeleteCota?id=" + id,
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                success: function (r) {
                    if (r.success) {
                        var sensorId = $('#currentCotaSensorId').val();
                        loadCotasTable(sensorId);
                    } else {
                        alert("Error al eliminar: " + r.message);
                    }
                },
                error: function() { alert("Falla de comunicación de red al eliminar."); }
            });
        }
    </script>
}
