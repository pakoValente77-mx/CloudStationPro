        return yAxisConfig;
    }

    // Enrich chart tooltip for precipitation series
    function buildPrecipTooltipFormatter(resMin) {
        const factorToHr = 60 / resMin;
        return function() {
            let s = `<b>${Highcharts.dateFormat('%d %b %Y %H:%M', this.x)}</b><br/>`;
            this.points.forEach(p => {
                const isEra5 = p.series.name.includes('ERA5');
                const mmHr  = (p.y * (isEra5 ? 1 : factorToHr)).toFixed(1);
                const cat   = !isEra5 ? getSmnCategory(p.y) : null;
                const catLabel = cat && cat.label !== 'Sin lluvia' ? ` <span style="color:${cat.color};">[${cat.label}]</span>` : '';
                s += `<span style="color:${p.color}">●</span> ${p.series.name}: <b>${p.y.toFixed(2)} mm</b>`;
                if (!isEra5) s += ` <span style="color:#aaa;">(${mmHr} mm/hr)${catLabel}</span>`;
                s += '<br/>';
            });
            return s;
        };
    }

    // NOTE: loadStations, updateInfo, clearChart, and updateChart are all redefined below
    // as complete replacements (no monkey-patching needed since they are in the same script scope).

    // Patch updateChart to add WMO plotLines and enriched tooltip for precipitation
    function updateChartWithMet(seriesList, aggregationLevel) {
        // Destroy and Rebuild is safer for changing axes structure dynamically
        if (chart) {
            try {
                while (chart.series.length > 0) {
                    chart.series[0].remove(false);
                }
                chart.destroy();
            } catch (e) {
                console.warn('Highcharts destroy warning (ignorable):', e.message);
                $('#analysis-chart').empty();
            }
            chart = null;
        }

        const hasPrecip = seriesList.some(s => s.variable.toLowerCase().includes('precipitación'));
        const resMin    = hasPrecip ? detectResolutionMinutes(
            (seriesList.find(s => s.variable.toLowerCase().includes('precipitación')) || seriesList[0]).dataPoints
        ) : 60;

        // Build Y-Axes configuration
        const yAxes = [];

        yAxes.push({
            title: { text: 'Valor' },
            labels: { format: '{value}' },
            opposite: false,
            min: 0
        });

        seriesList.forEach((s, i) => {
            if (s.newAxis) {
                yAxes.push({
                    title: { text: s.variableDisplayName },
                    labels: { format: '{value}' },
                    opposite: true,
                    min: 0
                });
                s.yAxisIndex = yAxes.length - 1;
            } else {
                s.yAxisIndex = 0;
                if (yAxes[0].title.text === 'Valor') {
                    yAxes[0].title.text = s.variableDisplayName;
                }
            }

            // Add WMO plotLines to rain axes
            if (s.variable.toLowerCase().includes('precipitación')) {
                addWmoPlotLines(yAxes[s.yAxisIndex]);
            }
        });

        // Generate Accumulation Series for Precipitation
        const derivedSeries = [];
        seriesList.forEach(s => {
            if (s.variable.toLowerCase().includes('precipitación')) {
                let runningTotal = 0;
                const accumulatedData = s.dataPoints.map(dp => {
                    if (dp.value !== null) { runningTotal += dp.value; }
                    return [new Date(dp.timestamp).getTime(), runningTotal];
                });

                const acumColors = ['#f59e0b', '#10b981', '#a78bfa', '#f472b6', '#34d399'];
                const acumColor  = acumColors[derivedSeries.length % acumColors.length];
                const acumAxisIndex = yAxes.length;

                yAxes.push({
                    title: { text: `Acumulado (${s.stationName})`, style: { color: acumColor, fontSize: '11px' } },
                    labels: { format: '{value} mm', style: { color: acumColor } },
                    opposite: true, min: 0, gridLineWidth: 0, lineColor: acumColor, tickColor: acumColor
                });

                derivedSeries.push({
                    name: `${s.stationName} - Acumulado`,
                    data: accumulatedData,
                    type: 'spline',
                    yAxis: acumAxisIndex,
                    color: acumColor,
                    dashStyle: 'ShortDot',
                    lineWidth: 2,
                    marker: { enabled: false },
                    tooltip: { valueDecimals: 2, valueSuffix: ' mm' }
                });
            }
        });

        const finalSeriesConfig = [];

        seriesList.forEach(s => {
            const isRain  = s.variable.toLowerCase().includes('precipitación');
            const isLevel = s.variable.toLowerCase().includes('nivel');
            const validData = [], invalidData = [];
            let minValidY = Number.MAX_VALUE, maxValidY = Number.MIN_VALUE;

            s.dataPoints.forEach(dp => {
                const time = new Date(dp.timestamp).getTime();
                if (dp.isValid !== false) {
                    validData.push([time, dp.value]);
                    if (dp.value !== null) {
                        minValidY = Math.min(minValidY, dp.value);
                        maxValidY = Math.max(maxValidY, dp.value);
                    }
                } else {
                    if (!isRain) validData.push([time, null]);
                    invalidData.push({ x: time, y: dp.value, realValue: dp.value });
                }
            });

            if (validData.length > 0 && minValidY !== Number.MAX_VALUE) {
                let yAxis = yAxes[s.yAxisIndex];
                if (isLevel) {
                    yAxis.tickInterval = 0.1; yAxis.minorTickInterval = 0.1; yAxis.tickPixelInterval = 20;
                } else if (isRain) {
                    yAxis.tickInterval = 1; yAxis.minorTickInterval = 0.5;
                } else {
                    yAxis.tickInterval = null;
                }

                let diff = maxValidY - minValidY;
                if (diff < 0.5) {
                    const pad = (0.5 - diff) / 2.0;
                    yAxis.min = minValidY - pad; yAxis.max = maxValidY + pad;
                    if (isRain || isLevel) yAxis.min = Math.max(0, yAxis.min);
                } else {
                    const pad = diff * 0.05;
                    yAxis.min = minValidY - pad; yAxis.max = maxValidY + pad;
                    if (isRain || isLevel) yAxis.min = Math.max(0, yAxis.min);
                }
                if (isLevel) { yAxis.startOnTick = false; yAxis.endOnTick = false; }

                const visualMin = yAxis.min !== undefined ? yAxis.min : minValidY;
                const visualMax = yAxis.max !== undefined ? yAxis.max : maxValidY;
                invalidData.forEach(dp => {
                    if (dp.y > visualMax) dp.y = visualMax;
                    else if (dp.y < visualMin) dp.y = visualMin;
                });
            }

            finalSeriesConfig.push({
                name: `${s.stationName} - ${s.variableDisplayName}`,
                data: validData,
                type: isRain ? 'column' : 'areaspline',
                fillOpacity: 0.15,
                yAxis: s.yAxisIndex,
                marker: { enabled: true, radius: aggregationLevel === 'daily' ? 4 : 2 },
                connectNulls: false
            });

            if (invalidData.length > 0) {
                finalSeriesConfig.push({
                    name: `${s.stationName} - Inválidos`,
                    data: invalidData,
                    type: 'scatter',
                    yAxis: s.yAxisIndex,
                    color: 'red',
                    marker: { symbol: 'triangle-down', radius: 6 },
                    tooltip: {
                        pointFormatter: function() {
                            return `<span style="color:${this.color}">●</span> ${this.series.name}: <b>${this.realValue}</b><br/>`;
                        }
                    }
                });
            }
        });

        finalSeriesConfig.push(...derivedSeries);

        // Build tooltip — use enriched formatter for precipitation
        const tooltipConfig = hasPrecip
            ? { shared: true, crosshairs: true, useHTML: true, formatter: buildPrecipTooltipFormatter(resMin) }
            : { shared: true, crosshairs: true, xDateFormat: '%Y-%m-%d %H:%M' };

        chart = Highcharts.stockChart('analysis-chart', {
            chart: { backgroundColor: 'transparent', zoomType: 'x' },
            title: { text: 'Análisis de Datos Hidrometeorológicos', style: { color: '#333', fontSize: '16px', fontWeight: '600' } },
            subtitle: { text: getSubtitleText(aggregationLevel, seriesList), style: { color: '#666', fontSize: '12px' } },
            rangeSelector: {
                enabled: true, inputEnabled: false, buttonTheme: { width: 60 },
                buttons: [{ type: 'day', count: 1, text: '1d' }, { type: 'week', count: 1, text: '1s' }, { type: 'month', count: 1, text: '1m' }, { type: 'year', count: 1, text: '1a' }, { type: 'all', text: 'Todo' }],
                selected: 4
            },
            navigator: { enabled: true },
            xAxis: {
                type: 'datetime',
                title: { text: 'Fecha/Hora' },
                ordinal: false,
                plotLines: hasPrecip && chart === null ? [] : [] // ERA5 will add peak annotation after chart creation
            },
            yAxis: yAxes,
            tooltip: tooltipConfig,
            legend: { enabled: true, layout: 'horizontal', align: 'center', verticalAlign: 'bottom', itemStyle: { fontSize: '11px' } },
            plotOptions: {
                column: { borderRadius: 3, grouping: false, shadow: false, borderWidth: 0 },
                series: { connectNulls: false }
            },
            credits: { enabled: false },
            series: finalSeriesConfig
        });
    }




</script>
}
