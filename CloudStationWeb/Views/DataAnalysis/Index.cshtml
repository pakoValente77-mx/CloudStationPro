    // ============================================================
    // METEOROLOGICAL INTELLIGENCE ENGINE
    // ============================================================

    // Global registry of stations with coordinates (populated by loadStations)
    let stationRegistry = {}; // { stationId: { lat, lon, name } }

    // Store ERA5 data for storm table enrichment
    let era5DataCache = null;

    // SMN/CONAGUA intensity categories (based on mm/10min intervals)
    // Scale: 1 mm/10min = 6 mm/hr
    const SMN_CATEGORIES = [
        { label: 'Muy Intensa',  minMmPer10min: 5.0,  color: '#ef4444', glow: 'rgba(239,68,68,0.4)' },
        { label: 'Intensa',      minMmPer10min: 2.5,  color: '#f97316', glow: 'rgba(249,115,22,0.3)' },
        { label: 'Moderada',     minMmPer10min: 0.42, color: '#f59e0b', glow: 'rgba(245,158,11,0.3)' },
        { label: 'Ligera',       minMmPer10min: 0.017,color: '#60a5fa', glow: 'rgba(96,165,250,0.2)' },
        { label: 'Sin lluvia',   minMmPer10min: 0,    color: '#6b7280', glow: null }
    ];

    function getSmnCategory(mmPer10min) {
        for (const cat of SMN_CATEGORIES) {
            if (mmPer10min >= cat.minMmPer10min) return cat;
        }
        return SMN_CATEGORIES[SMN_CATEGORIES.length - 1];
    }

    // Detect the data resolution in minutes (10min raw, 60min hourly, 1440min daily)
    function detectResolutionMinutes(dataPoints) {
        if (!dataPoints || dataPoints.length < 2) return 10;
        const t1 = new Date(dataPoints[0].timestamp).getTime();
        const t2 = new Date(dataPoints[1].timestamp).getTime();
        const diffMin = (t2 - t1) / 60000;
        if (diffMin <= 15)  return 10;
        if (diffMin <= 70)  return 60;
        return 1440;
    }

    // Storm event detection algorithm
    // Two intervals are considered the same storm if the dry gap between them is <= gapThreshold minutes
    function detectStormEvents(dataPoints, resolutionMinutes) {
        const gapThreshold = Math.max(30, resolutionMinutes * 3); // 30 min for raw, 3 intervals for hourly/daily
        const events = [];
        let currentEvent = null;
        let drySince = null;

        dataPoints.forEach(dp => {
            const val   = dp.value !== null && dp.value !== undefined ? dp.value : 0;
            const time  = new Date(dp.timestamp).getTime();
            const isWet = val > 0;

            if (isWet) {
                drySince = null;
                if (!currentEvent) {
                    currentEvent = { start: time, end: time, total: 0, peak: 0, peakTime: time, intervals: [] };
                }
                currentEvent.end   = time;
                currentEvent.total = (currentEvent.total || 0) + val;
                currentEvent.intervals.push({ time, val });
                if (val > (currentEvent.peak || 0)) {
                    currentEvent.peak     = val;
                    currentEvent.peakTime = time;
                }
            } else {
                if (currentEvent) {
                    if (drySince === null) {
                        drySince = time;
                    } else if ((time - drySince) / 60000 >= gapThreshold) {
                        // Close the event
                        events.push(currentEvent);
                        currentEvent = null;
                        drySince     = null;
                    }
                }
            }
        });

        // Close last open event
        if (currentEvent) events.push(currentEvent);
        return events;
    }

    // Duration in human-readable format
    function formatDuration(ms) {
        const totalMin = Math.round(ms / 60000);
        if (totalMin < 60)  return `${totalMin} min`;
        const h = Math.floor(totalMin / 60);
        const m = totalMin % 60;
        return m > 0 ? `${h}h ${m}min` : `${h}h`;
    }

    // Calculate all meteorological KPIs for a precipitation series
    function calcPrecipKpis(series, resolutionMinutes) {
        const dps        = series.dataPoints || [];
        const factor     = 60 / resolutionMinutes; // Convert to mm/hr
        let totalMm      = 0;
        let peakVal10    = 0;
        let peakTime     = null;
        let wetIntervals = 0;

        dps.forEach(dp => {
            const v = dp.value !== null && dp.value !== undefined ? dp.value : 0;
            totalMm += v;
            if (v > peakVal10) { peakVal10 = v; peakTime = dp.timestamp; }
            if (v > 0) wetIntervals++;
        });

        const peakMmHr        = peakVal10 * factor;
        const durationMinutes = wetIntervals * resolutionMinutes;
        const durationHours   = durationMinutes / 60;
        const meanIntensity   = durationHours > 0 ? totalMm / durationHours : 0;
        const peakCategory    = getSmnCategory(peakVal10);
        const stormEvents     = detectStormEvents(dps, resolutionMinutes);

        return { totalMm, peakMmHr, peakTime, durationMinutes, meanIntensity, peakCategory, stormEvents };
    }

    // Render the meteorological KPI panel
    function renderMetPanel(seriesList, aggregationLevel) {
        const precipSeries = seriesList.filter(s => s.variable.toLowerCase().includes('precipitación'));

        if (precipSeries.length === 0) {
            $('#met-stats-panel').hide();
            era5DataCache = null;
            return;
        }

        $('#met-stats-panel').show();

        // Use the first precipitation series for global KPIs
        const primary   = precipSeries[0];
        const resMin    = detectResolutionMinutes(primary.dataPoints);
        const kpis      = calcPrecipKpis(primary, resMin);

        // KPI Cards
        $('#kpi-total').text(`${kpis.totalMm.toFixed(1)} mm`);
        $('#kpi-peak-intensity').text(`${kpis.peakMmHr.toFixed(1)} mm/hr`);
        $('#kpi-peak-time').text(kpis.peakTime ? new Date(kpis.peakTime).toLocaleString('es-MX', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '--');
        $('#kpi-duration').text(formatDuration(kpis.durationMinutes * 60000));
        $('#kpi-mean-intensity').text(`${kpis.meanIntensity.toFixed(2)} mm/hr`);
        $('#kpi-storms').text(kpis.stormEvents.length);

        // Category card (color per category)
        const cat = kpis.peakCategory;
        $('#kpi-category').text(cat.label).css('color', cat.color);
        if (cat.glow) {
            $('#kpi-category').closest('.statistic').css('border-color', cat.color.replace(')', ',0.4)').replace('rgb', 'rgba'));
        }

        // Render storm events table
        renderStormTable(kpis.stormEvents, 60 / resMin);

        // Trigger ERA5 comparison if station has coordinates
        const stationId = primary.stationId;
        if (stationRegistry[stationId] && stationRegistry[stationId].lat) {
            const { lat, lon } = stationRegistry[stationId];
            const startDate  = new Date(primary.dataPoints[0].timestamp);
            const endDate    = new Date(primary.dataPoints[primary.dataPoints.length - 1].timestamp);
            fetchEra5Comparison(lat, lon, startDate, endDate, kpis.stormEvents, resMin);
        }
    }

    // Render storm events table rows
    function renderStormTable(events, factorToHr) {
        const tbody = $('#storm-events-body');
        tbody.empty();

        if (events.length === 0) {
            $('#storm-events-panel').hide();
            return;
        }

        events.forEach((ev, idx) => {
            const peakMmHr = (ev.peak * factorToHr).toFixed(1);
            const durMs = ev.end - ev.start + (60000 / factorToHr); // add one interval
            const cat = getSmnCategory(ev.peak);
            const catBadge = `<span style="background:${cat.color}22; color:${cat.color}; border:1px solid ${cat.color}44; border-radius:12px; padding:2px 8px; font-size:0.75rem;">${cat.label}</span>`;
            
            tbody.append(`
                <tr style="background:rgba(0,0,0,0.2);">
                    <td style="color:#aaa; border-color:#333; padding:7px 10px;">${idx + 1}</td>
                    <td style="border-color:#333; padding:7px 10px; color:#e0e0e0;">${new Date(ev.start).toLocaleString('es-MX', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'})}</td>
                    <td style="border-color:#333; padding:7px 10px; color:#e0e0e0;">${new Date(ev.end).toLocaleString('es-MX', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'})}</td>
                    <td style="border-color:#333; padding:7px 10px; color:#60a5fa;">${formatDuration(durMs)}</td>
                    <td style="border-color:#333; padding:7px 10px; color:#00e676; font-weight:700;">${ev.total.toFixed(1)}</td>
                    <td style="border-color:#333; padding:7px 10px; color:#f97316;">${peakMmHr}</td>
                    <td style="border-color:#333; padding:7px 10px; color:#aaa; font-size:0.75rem;">${new Date(ev.peakTime).toLocaleString('es-MX', {hour:'2-digit',minute:'2-digit'})}</td>
                    <td style="border-color:#333; padding:7px 10px;">${catBadge}</td>
                    <td class="era5-cell" style="border-color:#333; padding:7px 10px; color:#93c5fd; display:none;">--</td>
                </tr>
            `);
        });

        $('#storm-events-panel').show();
    }

    // Fetch ERA5 climatological normal — same calendar dates from last N years
    // This avoids the 5-7 day ERA5 lag issue: historical years are always available.
    function fetchEra5Comparison(lat, lon, startDate, endDate, stormEvents, resMin) {
        const YEARS_BACK = 5;
        const fmt = d => d.toISOString().split('T')[0];
        $('#era5-status').show();
        $('#era5-status-text').text(`Consultando climatología ERA5 (${YEARS_BACK} años anteriores)...`);

        const spanDays = Math.ceil((endDate - startDate) / 86400000) + 2; // +2 buffer
        const startDoy  = startDate; // day-of-year anchor

        // Build fetch promises for each past year
        const fetchPromises = [];
        const currentYear   = startDate.getFullYear();

        for (let yr = 1; yr <= YEARS_BACK; yr++) {
            const yearOffset = currentYear - yr;
            const s = new Date(startDate); s.setFullYear(yearOffset); s.setDate(s.getDate() - 1);
            const e = new Date(endDate);   e.setFullYear(yearOffset); e.setDate(e.getDate() + 1);
            const url = `https://archive-api.open-meteo.com/v1/archive?latitude=${lat.toFixed(4)}&longitude=${lon.toFixed(4)}&start_date=${fmt(s)}&end_date=${fmt(e)}&hourly=precipitation&timezone=America%2FMexico_City`;
            fetchPromises.push(
                fetch(url).then(r => r.json()).then(d => ({ year: yearOffset, data: d })).catch(() => null)
            );
        }

        Promise.all(fetchPromises).then(results => {
            const validResults = results.filter(r => r && r.data && r.data.hourly && r.data.hourly.time);
            if (validResults.length === 0) {
                $('#era5-status-text').text('ERA5 histórico no disponible para esta ubicación.');
                return;
            }

            // Normalize all years to relative hours from start offset
            // Key = hour-of-day-offset (0, 1, 2, ...), value = [ sum, count ]
            const hourBuckets = {}; // { relativeHourOffset: { sum, count, byYear } }

            validResults.forEach(({ year, data }) => {
                const baseMs = new Date(`${year}-${String(startDate.getMonth()+1).padStart(2,'0')}-${String(startDate.getDate()).padStart(2,'0')}T00:00:00`).getTime();
                data.hourly.time.forEach((t, i) => {
                    const tMs = new Date(t).getTime();
                    const relHr = Math.round((tMs - baseMs) / 3600000);
                    const pp = data.hourly.precipitation[i] || 0;
                    if (!hourBuckets[relHr]) hourBuckets[relHr] = { sum: 0, count: 0 };
                    hourBuckets[relHr].sum   += pp;
                    hourBuckets[relHr].count += 1;
                });
            });

            // Build averaged series anchored to the actual query start date
            const baseAnchor = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate(), 0, 0, 0).getTime();
            const era5AvgData = Object.keys(hourBuckets)
                .map(h => parseInt(h))
                .filter(h => h >= -1 && h <= (spanDays * 24))
                .sort((a, b) => a - b)
                .map(h => [baseAnchor + h * 3600000, parseFloat((hourBuckets[h].sum / hourBuckets[h].count).toFixed(2))]);

            // Total ERA5 climatological precipitation for each storm event window
            stormEvents.forEach((ev, idx) => {
                let clim = 0;
                era5AvgData.forEach(([t, v]) => {
                    if (t >= ev.start && t <= ev.end + 3600000) clim += v;
                });
                const cells = $('#storm-events-body tr td.era5-cell');
                $(cells[idx]).html(`${clim.toFixed(1)} <span style="color:#6b7280;font-size:0.7rem;">mm</span>`).show();
            });

            // Show ERA5 badge and column
            $('#storm-era5-badge').text(`🛰 Normal ${validResults.map(r=>r.year).join('/')}`).show();
            $('#era5-col-header').show();
            $('.era5-cell').show();
            $('#era5-status-text').html(`🛰 Normal Climatológico ERA5 &mdash; mismo período, últimos ${validResults.length} años (${validResults.map(r=>r.year).join(', ')})`);

            // Add ERA5 climatological series to chart
            if (chart && era5AvgData.length > 0) {
                // Remove any existing ERA5 series first
                const existing = chart.series.find(s => s.name && s.name.includes('ERA5'));
                if (existing) existing.remove(false);

                chart.addSeries({
                    name: `Normal Climatológico ERA5 (${YEARS_BACK}a)`,
                    type: 'areaspline',
                    data: era5AvgData,
                    color: '#818cf8',
                    fillOpacity: 0.10,
                    lineWidth: 1.8,
                    dashStyle: 'LongDash',
                    marker: { enabled: false },
                    yAxis: 0,
                    zIndex: 1,
                    tooltip: {
                        valueDecimals: 2,
                        valueSuffix: ' mm (Normal ERA5)'
                    }
                }, false);
                chart.redraw();
            }
        }).catch(err => {
            $('#era5-status-text').text(`Error ERA5: ${err.message}`);
            console.warn('ERA5 climatology fetch failed:', err);
        });
    }

    // Add WMO/SMN alert plotLines to a precipitation Y-axis config object
    function addWmoPlotLines(yAxisConfig) {
        yAxisConfig.plotLines = [
            {
                value: 5.0, color: '#ef4444', width: 1.5, dashStyle: 'ShortDash', zIndex: 5,
