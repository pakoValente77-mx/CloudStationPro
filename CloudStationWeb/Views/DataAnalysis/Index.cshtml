                label: { text: 'Intensa (15mm/hr)', align: 'right', x: -4, style: { color: '#f97316', fontSize: '9px', fontWeight: '600' } }
            },
            {
                value: 0.42, color: '#f59e0b', width: 1, dashStyle: 'Dot', zIndex: 5,
                label: { text: 'Moderada (2.5mm/hr)', align: 'right', x: -4, style: { color: '#f59e0b', fontSize: '9px' } }
            }
