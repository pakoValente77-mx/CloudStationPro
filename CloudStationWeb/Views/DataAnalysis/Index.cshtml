    // Helper function to generate informative subtitle for charts
    function getSubtitleText(aggregationLevel, seriesList) {
        let aggText = '';
        if (aggregationLevel === 'raw') {
            aggText = 'Datos puntuales (10 min)';
        } else if (aggregationLevel === 'hourly') {
            aggText = 'Agregación horaria';
        } else {
            aggText = 'Agregación diaria';
        }
        
        const seriesCount = seriesList ? seriesList.length : 0;
        const totalPoints = seriesList ? seriesList.reduce((sum, s) => sum + s.dataPoints.length, 0) : 0;
        
        return `${aggText} | ${seriesCount} serie(s) | ${totalPoints.toLocaleString('es-MX')} puntos`;
    }

    function updateChart(seriesList, aggregationLevel) {
        // Destroy and Rebuild is safer for changing axes structure dynamically
        if (chart) {
            try {
                while (chart.series.length > 0) {
                    chart.series[0].remove(false);
                }
                chart.destroy();
            } catch (e) {
                console.warn('Highcharts destroy warning (ignorable):', e.message);
                $('#analysis-chart').empty();
            }
            chart = null;
        }
        
        // Build Y-Axes configuration
        const yAxes = [];

        yAxes.push({
            title: { text: 'Valor' }, // Generic title for primary
            labels: { format: '{value}' },
            opposite: false,
            min: 0 // Force zero baseline
        });

        seriesList.forEach((s, i) => {
            if (s.newAxis) {
                // ADD new axis
                yAxes.push({
                    title: { text: s.variableDisplayName },
                    labels: { format: '{value}' },
                    opposite: true, // Secondary axes on right
                    min: 0 // Force zero baseline
                });
                s.yAxisIndex = yAxes.length - 1;
            } else {
                // Use primary
                s.yAxisIndex = 0;
                // Update primary title if it's the first series using it
                 if (yAxes[0].title.text === 'Valor') {
                    yAxes[0].title.text = s.variableDisplayName;
                }
            }
        });

        // Generate Accumulation Series for Precipitation (with DEDICATED right Y-axis)
        const derivedSeries = [];
        seriesList.forEach(s => {
            if (s.variable.toLowerCase().includes('precipitación')) {
                // Calculate accumulated values
                let runningTotal = 0;
                const accumulatedData = s.dataPoints.map(dp => {
                    if (dp.value !== null) {
                        runningTotal += dp.value;
                    }
                    return [new Date(dp.timestamp).getTime(), runningTotal];
                });

                // Pick a distinct color for this accumulation axis/series
                const acumColors = ['#f59e0b', '#10b981', '#a78bfa', '#f472b6', '#34d399'];
                const acumColorIndex = derivedSeries.length % acumColors.length;
                const acumColor = acumColors[acumColorIndex];

                // Create a dedicated Y-axis for this accumulation series (right side)
                const acumAxisIndex = yAxes.length;
                yAxes.push({
                    title: {
                        text: `Acumulado (${s.stationName})`,
                        style: { color: acumColor, fontSize: '11px' }
                    },
                    labels: {
                        format: '{value} mm',
                        style: { color: acumColor }
                    },
                    opposite: true,        // Right side
                    min: 0,
                    gridLineWidth: 0,      // No grid for secondary axis (avoids clutter)
                    lineColor: acumColor,
                    tickColor: acumColor
                });

                derivedSeries.push({
                    name: `${s.stationName} - Acumulado`,
                    data: accumulatedData,
                    type: 'spline',
                    yAxis: acumAxisIndex,  // Use the new dedicated axis
                    color: acumColor,
                    dashStyle: 'ShortDot',
                    lineWidth: 2,
                    marker: { enabled: false },
                    tooltip: {
                        valueDecimals: 2,
                        valueSuffix: ' mm'
                    }
                });
            }
        });


        const finalSeriesConfig = [];

        seriesList.forEach(s => {
            const isRain = s.variable.toLowerCase().includes('precipitación');
            const isLevel = s.variable.toLowerCase().includes('nivel');
            
            // Separate valid and invalid data
            const validData = [];
            const invalidData = [];
            
            let minValidY = Number.MAX_VALUE;
            let maxValidY = Number.MIN_VALUE;
            
            // Generate max/min object references
            let maxDp = null;
            let minDp = null;
            s.dataPoints.forEach(dp => {
                if (dp.isValid !== false && dp.value !== null) {
                    if (!maxDp || dp.value > maxDp.value) maxDp = dp;
                    if (!minDp || dp.value < minDp.value) minDp = dp;
                }
            });
            s.maxPoint = maxDp;
            s.minPoint = minDp;

            s.dataPoints.forEach(dp => {
                const time = new Date(dp.timestamp).getTime();
                
                if (dp.isValid !== false) { // Default to true if undefined
                    if (dp.value !== null) {
                        let point = { x: time, y: dp.value };
                        
                        if (!isRain) {
                            if (s.maxPoint && time === new Date(s.maxPoint.timestamp).getTime() && dp.value === s.maxPoint.value) {
                                point.marker = { enabled: true, fillColor: '#ff5252', radius: 6, symbol: 'triangle', lineColor: '#333', lineWidth: 1 };
                                point.dataLabels = { enabled: true, format: 'Máx', color: '#ff5252', y: -10, style: { textOutline: 'none', fontWeight: 'bold' } };
                            } else if (s.minPoint && time === new Date(s.minPoint.timestamp).getTime() && dp.value === s.minPoint.value) {
                                point.marker = { enabled: true, fillColor: '#448aff', radius: 6, symbol: 'triangle-down', lineColor: '#333', lineWidth: 1 };
                                point.dataLabels = { enabled: true, format: 'Mín', color: '#448aff', y: 30, style: { textOutline: 'none', fontWeight: 'bold' } };
                            }
                        }
                        
                        validData.push(point);
                        minValidY = Math.min(minValidY, dp.value);
                        maxValidY = Math.max(maxValidY, dp.value);
                    } else {
                        // Push null to validData to break the line (if not column)
                        if (!isRain) {
                            validData.push([time, null]);
                        }
                    }
                } else {
                    // Invalid data point
                    // Push null to validData to break the line (if not column)
                    if (!isRain) {
                        validData.push([time, null]);
                    }
                    invalidData.push({ x: time, y: dp.value, realValue: dp.value });
                }
            });

            // Adjust Y-axis scale based ONLY on valid data
            if (validData.length > 0 && minValidY !== Number.MAX_VALUE) {
                let yAxis = yAxes[s.yAxisIndex];
                
                // Enforce High Definition Y-Axis Scale
                if (isLevel) {
                    yAxis.tickInterval = 0.1;
                    yAxis.minorTickInterval = 0.1;
                    yAxis.tickPixelInterval = 20; // Allows labels to be closer without skipping
                } else if (isRain) {
                    yAxis.tickInterval = 1;
                    yAxis.minorTickInterval = 0.5;
                } else {
                    yAxis.tickInterval = null; // Auto for temperature, wind, etc.
                }

                let diff = maxValidY - minValidY;
                if (diff < 0.5) { // Force a minimum 0.5 logical range if data is literally flat
                    const padding = (0.5 - diff) / 2.0;
                    yAxis.min = minValidY - padding;
                    yAxis.max = maxValidY + padding;
                    if (isRain || isLevel) yAxis.min = Math.max(0, yAxis.min);
                } else {
                    // Force strict boundaries so Highstock doesn't zoom out 
                    // and crush the 0.1 scale
                    const padding = diff * 0.05; // 5% padding
                    yAxis.min = minValidY - padding;
                    yAxis.max = maxValidY + padding;
                    if (isRain || isLevel) yAxis.min = Math.max(0, yAxis.min);
                }
                
                // Extra safety: do not let highcharts start from 0 automatically for levels
                if (isLevel) {
                    yAxis.startOnTick = false;
                    yAxis.endOnTick = false;
                }
                
                // Clamp invalid data points boundaries
                const visualMin = yAxis.min !== undefined ? yAxis.min : minValidY;
                const visualMax = yAxis.max !== undefined ? yAxis.max : maxValidY;
                invalidData.forEach(dp => {
                    if (dp.y > visualMax) dp.y = visualMax;
                    else if (dp.y < visualMin) dp.y = visualMin;
                });
            }

            // Main valid series
            finalSeriesConfig.push({
                name: `${s.stationName} - ${s.variableDisplayName}`,
                data: validData,
                type: isRain ? 'column' : 'areaspline',
                fillOpacity: 0.15,
                yAxis: s.yAxisIndex,
                marker: { 
                    enabled: true,
                    radius: aggregationLevel === 'daily' ? 4 : 2
                },
                connectNulls: false
            });

            // Invalid series (Scatter dots in red)
            if (invalidData.length > 0) {
                finalSeriesConfig.push({
                    name: `${s.stationName} - Inválidos`,
                    data: invalidData,
                    type: 'scatter',
                    yAxis: s.yAxisIndex,
                    color: 'red',
                    marker: { symbol: 'triangle-down', radius: 6 },
                    tooltip: {
                        pointFormatter: function() {
                            return `<span style="color:${this.color}">\u25CF</span> ${this.series.name}: <b>${this.realValue}</b><br/>`;
                        }
                    }
                });
            }
        });
        
        finalSeriesConfig.push(...derivedSeries);

        chart = Highcharts.stockChart('analysis-chart', {
            chart: { backgroundColor: 'transparent', zoomType: 'x' },
            title: { text: 'Análisis de Datos Hidrometeorológicos', style: { color: '#333', fontSize: '16px', fontWeight: '600' } },
            subtitle: { text: getSubtitleText(aggregationLevel, seriesList), style: { color: '#666', fontSize: '12px' } },
            rangeSelector: {
                enabled: true,
                inputEnabled: false,
                buttonTheme: { width: 60 },
                buttons: [{ type: 'day', count: 1, text: '1d' }, { type: 'week', count: 1, text: '1s' }, { type: 'month', count: 1, text: '1m' }, { type: 'year', count: 1, text: '1a' }, { type: 'all', text: 'Todo' }],
                selected: 4
            },
            navigator: { enabled: true },
            xAxis: { type: 'datetime', title: { text: 'Fecha/Hora' }, ordinal: false },
            yAxis: yAxes,
            tooltip: { shared: true, crosshairs: true, xDateFormat: '%Y-%m-%d %H:%M' },
            legend: { enabled: true, layout: 'horizontal', align: 'center', verticalAlign: 'bottom', itemStyle: { fontSize: '11px' } },
            plotOptions: { column: { borderRadius: 3, grouping: false, shadow: false, borderWidth: 0 }, series: { connectNulls: false } },
            credits: { enabled: false },
            series: finalSeriesConfig
        });
    }

