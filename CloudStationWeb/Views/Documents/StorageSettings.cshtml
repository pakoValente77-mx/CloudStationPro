@{
    ViewData["Title"] = "Configuración de Almacenamiento";
    var products = Model as List<CloudStationWeb.Models.DocumentProduct> ?? new();
}

@section Styles {
<style>
    .storage-page {
        padding: 30px 40px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .page-header h1 { font-size: 22px; font-weight: 700; color: #fff; }

    .btn-back {
        padding: 10px 18px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 13px;
        transition: all 0.2s;
    }

    .btn-back:hover { background: rgba(255,255,255,0.1); color: #fff; }

    .info-banner {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 18px;
        background: rgba(59,130,246,0.08);
        border: 1px solid rgba(59,130,246,0.2);
        border-radius: 12px;
        margin-bottom: 24px;
        color: rgba(255,255,255,0.7);
        font-size: 13px;
        line-height: 1.5;
    }

    .info-banner .icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }

    .alert-msg {
        padding: 12px 18px;
        border-radius: 10px;
        font-size: 13px;
        margin-bottom: 16px;
        font-weight: 500;
    }

    .alert-success {
        background: rgba(34,197,94,0.1);
        border: 1px solid rgba(34,197,94,0.2);
        color: #86efac;
    }

    .alert-error {
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.2);
        color: #fca5a5;
    }

    .product-storage-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 20px 24px;
        margin-bottom: 14px;
        transition: all 0.2s;
    }

    .product-storage-card:hover {
        background: rgba(255,255,255,0.06);
        border-color: rgba(255,255,255,0.12);
    }

    .product-storage-card .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .product-storage-card .product-name {
        font-size: 15px;
        font-weight: 600;
        color: #fff;
    }

    .product-storage-card .product-code {
        font-size: 12px;
        color: rgba(255,255,255,0.35);
        background: rgba(255,255,255,0.06);
        padding: 3px 8px;
        border-radius: 6px;
        font-family: monospace;
    }

    .path-status {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 6px;
    }

    .path-configured {
        background: rgba(34,197,94,0.12);
        color: #86efac;
    }

    .path-missing {
        background: rgba(239,68,68,0.12);
        color: #fca5a5;
    }

    .path-form {
        display: flex;
        gap: 10px;
        align-items: stretch;
    }

    .path-form input[type="text"] {
        flex: 1;
        padding: 10px 14px;
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        color: #fff;
        font-size: 13px;
        font-family: 'SF Mono', 'Fira Code', monospace;
        transition: border-color 0.2s;
    }

    .path-form input[type="text"]:focus {
        outline: none;
        border-color: rgba(99,102,241,0.5);
    }

    .path-form input[type="text"]::placeholder {
        color: rgba(255,255,255,0.25);
    }

    .btn-save {
        padding: 10px 20px;
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.2s;
    }

    .btn-save:hover { filter: brightness(1.15); transform: translateY(-1px); }

    .current-path {
        margin-top: 8px;
        font-size: 12px;
        color: rgba(255,255,255,0.35);
        font-family: monospace;
    }

    .current-path strong { color: rgba(255,255,255,0.5); font-weight: 500; }
</style>
}

<div class="storage-page">
    <div class="page-header">
        <h1>📂 Configuración de Almacenamiento</h1>
        <a href="@Url.Action("Index")" class="btn-back">← Volver</a>
    </div>

    <div class="info-banner">
        <span class="icon">ℹ️</span>
        <div>
            Configure la ruta de almacenamiento de archivos para cada producto.
            Debe ser una ruta absoluta del sistema de archivos (ej. <code>/datos/documentos/boletin</code>).
            El directorio se creará automáticamente si no existe.
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-msg alert-success">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-msg alert-error">⚠️ @TempData["Error"]</div>
    }

    @foreach (var product in products)
    {
        var hasPath = !string.IsNullOrEmpty(product.StoragePath);

        <div class="product-storage-card">
            <div class="card-header">
                <div style="display:flex; align-items:center; gap:10px;">
                    <span class="product-name">@product.Name</span>
                    <span class="product-code">@product.Code</span>
                </div>
                @if (hasPath)
                {
                    <span class="path-status path-configured">✓ Configurado</span>
                }
                else
                {
                    <span class="path-status path-missing">✗ Sin configurar</span>
                }
            </div>

            <form method="post" asp-action="UpdateStoragePath" class="path-form">
                <input type="hidden" name="id" value="@product.Id" />
                <input type="text"
                       name="storagePath"
                       value="@product.StoragePath"
                       placeholder="/ruta/absoluta/para/@product.Code" />
                <button type="submit" class="btn-save">💾 Guardar</button>
            </form>

            @if (hasPath)
            {
                <div class="current-path">
                    <strong>Ruta actual:</strong> @product.StoragePath
                </div>
            }
        </div>
    }
</div>
