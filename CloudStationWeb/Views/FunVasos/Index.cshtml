        });

        Highcharts.chart('hydroInputRainChart', {
            chart: { backgroundColor: 'transparent', height: 180 },
            title: { text: 'Lluvia Pronosticada por Cuenca (mm/h)', style: { color: '#78909c', fontSize: '12px' } },
            xAxis: { type: 'datetime', labels: { style: { color: '#546e7a', fontSize: '10px' }, format: '{value:%d/%m %H}h' },
                gridLineColor: 'rgba(255,255,255,0.03)' },
            yAxis: { title: { text: null }, labels: { style: { color: '#546e7a' } }, gridLineColor: 'rgba(255,255,255,0.05)', min: 0 },
            legend: { itemStyle: { color: '#78909c', fontSize: '10px' }, backgroundColor: 'transparent' },
            plotOptions: { column: { pointPadding: 0, groupPadding: 0.1, borderWidth: 0 } },
            series: series,
            exporting: { enabled: false },
            credits: { enabled: false },
            tooltip: { shared: true, backgroundColor: 'rgba(15,25,30,0.95)', style: { color: '#e8f5e9' },
                xDateFormat: '%Y-%m-%d %H:%M', valueSuffix: ' mm' }
        });
