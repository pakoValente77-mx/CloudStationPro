@Html.AntiForgeryToken()

@section Scripts {
<script src="~/lib/highcharts/highcharts.js"></script>
<script src="~/lib/highcharts/modules/exporting.js"></script>
<script src="~/js/chart-config.js"></script>
<script src="~/lib/threejs/three.min.js"></script>
<script src="~/js/cascade3d.js"></script>
<script>
$(function() {
    console.log('[FunVasos] Script v3 loaded at', new Date().toISOString());

    // Sanitize string for DOM IDs (remove diacritics, replace spaces)
    function sanitizeId(str) {
        return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/ /g, '_');
    }

    // Tab switching
    $('.presa-tab').on('click', function() {
        $('.presa-tab').removeClass('active');
        $(this).addClass('active');
        var presa = $(this).data('presa');
        $('.tab-content').hide();
        stopCascadeAutoRefresh(); // stop auto-refresh when leaving cascade tab
        if (presa === 'todas') {
            $('#tab-todas').show();
        } else if (presa === 'cascada3d') {
            $('#tab-cascada3d').show();
            if (!window._c3dReady) {
                setTimeout(function() {
                    initCascade3D('cascade3d-wrapper', window._c3dData);
                    window._c3dReady = true;
                    setTimeout(function() { $('#c3dHint').css('opacity', 0); }, 5000);
                }, 150);
            } else {
                resizeCascade3D();
            }
            startCascadeAutoRefresh();
        } else if (presa === 'promapor') {
            $('#tab-promapor').show();
            renderPromAporCharts();
        } else if (presa === 'niveleshorarios') {
            $('#tab-niveleshorarios').show();
            renderNivelesHorarios();
        } else if (presa === 'hydrosim') {
            $('#tab-hydrosim').show();
            loadHydroInputData();
        } else {
            $('#tab-' + sanitizeId(presa)).show();
            renderCharts(presa);
        }
    });

    // Date range query
    $('#btnConsultar').on('click', function() {
        var fi = $('#fechaInicio').val();
        var ff = $('#fechaFin').val();
        window.location.href = '@Url.Action("Index", "FunVasos")' + '?fechaInicio=' + fi + '&fechaFin=' + ff;
    });

    // Also query on Enter key in date fields
    $('#fechaInicio, #fechaFin').on('keydown', function(e) {
        if (e.key === 'Enter') { $('#btnConsultar').click(); }
    });

    @{
        var isRange = Model.FechaInicio != Model.FechaFin;
    }

    // Chart data from model
    var presasData = {};
    @foreach (var p in Model.Presas)
    {
        <text>
        presasData['@SafeId(p.Presa)'] = {
            labels: [@Html.Raw(string.Join(",", p.Datos.Select(d => isRange
                ? $"'{d.Ts:dd/MM} {d.Hora}:00'"
                : $"'{d.Hora}:00'")))],
            elevacion: [@string.Join(",", p.Datos.Select(d => d.Elevacion?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))],
            almacenamiento: [@string.Join(",", p.Datos.Select(d => d.Almacenamiento?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))],
            aportQ: [@string.Join(",", p.Datos.Select(d => d.AportacionesQ?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))],
            turbQ: [@string.Join(",", p.Datos.Select(d => d.ExtraccionesTurbQ?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))],
            vertQ: [@string.Join(",", p.Datos.Select(d => d.ExtraccionesVertQ?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))],
            totalQ: [@string.Join(",", p.Datos.Select(d => d.ExtraccionesTotalQ?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))],
            gen: [@string.Join(",", p.Datos.Select(d => d.Generacion?.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) ?? "null"))],
            isTapon: @(p.Presa == "Tapón Juan Grijalva" ? "true" : "false")
        };
        </text>
    }

    // 3D Cascade data (enriched with EmbalseConfig)
    @{
        var embalseConfigs = (ViewBag.EmbalseConfigs as List<CloudStationWeb.Controllers.EmbalseConfigDto>) ?? new List<CloudStationWeb.Controllers.EmbalseConfigDto>();
        var cfgByDisplay = embalseConfigs.ToDictionary(c => c.NombreDisplay, c => c);
    }
    window._c3dData = [
        @foreach (var p in Model.Presas)
        {
            var lastRow = p.Datos.LastOrDefault();
            cfgByDisplay.TryGetValue(p.Presa, out var ecfg);
            <text>{ key: '@SafeId(p.Presa)', name: '@Html.Raw(p.Presa)', currentElev: @(p.UltimaElevacion?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"), generation: @(p.TotalGeneracion?.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) ?? "0"), activeUnits: @(lastRow?.NumUnidades ?? 0), namo: @(ecfg?.Namo?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"), namino: @(ecfg?.Namino?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "null"), totalUnits: @(ecfg?.TotalUnits ?? 0), isTapon: @((ecfg?.IsTaponType ?? false).ToString().ToLower()), color: @(ecfg?.Color != null ? "'" + ecfg.Color + "'" : "null") },
            </text>
        }
    ];
    window._c3dReady = false;
    window._c3dRefreshInterval = null;

    // Set initial timestamp from model data
    (function setInitialTimestamp() {
        var presas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Presas.Select(p => new { p.Presa, p.UltimaHora }).ToList()));
        var maxHora = 0;
        presas.forEach(function(p) { if (p.UltimaHora > maxHora) maxHora = p.UltimaHora; });
        var fechaStr = '@Model.FechaFin.ToString("dd/MM/yyyy")';
        var horaStr = maxHora > 0 ? (maxHora + ':00') : '--';
        $('#c3dTimestamp').html('<i class="clock outline icon"></i> Datos al: ' + fechaStr + ' ' + horaStr + ' hrs');
    })();

    // Auto-refresh cascade every 5 minutes
    function refreshCascadeData() {
        $.ajax({
            url: '@Url.Action("GetCascadeData", "FunVasos")',
            type: 'GET',
            dataType: 'json',
            success: function(resp) {
                if (!resp || !resp.presas) return;
                var maxHora = 0;
                var fecha = resp.fecha || '';

                // Update _c3dData and banner
                resp.presas.forEach(function(p) {
                    if (p.ultimaHora > maxHora) maxHora = p.ultimaHora;

                    // Update 3D data array
                    for (var i = 0; i < window._c3dData.length; i++) {
                        if (window._c3dData[i].key === p.key) {
                            window._c3dData[i].currentElev = p.currentElev;
                            window._c3dData[i].generation = p.generation;
                            window._c3dData[i].activeUnits = p.activeUnits;
                            if (p.namo != null) window._c3dData[i].namo = p.namo;
                            if (p.namino != null) window._c3dData[i].namino = p.namino;
                            if (p.totalUnits != null) window._c3dData[i].totalUnits = p.totalUnits;
                            if (p.isTapon != null) window._c3dData[i].isTapon = p.isTapon;
                            if (p.color != null) window._c3dData[i].color = p.color;
                            break;
                        }
                    }

                    // Update bottom banner values
                    var $item = $('#c3dBanner .c3d-banner-item[data-presa-key="' + p.key + '"]');
                    if ($item.length) {
                        $item.find('.c3d-val-elev').html((p.currentElev != null ? p.currentElev.toFixed(2) : '—') + ' <small>msnm</small>');
                        $item.find('.c3d-val-almac').html((p.almacenamiento != null ? p.almacenamiento.toFixed(2) : '—') + ' <small>Mm³</small>');
                        if ($item.find('.c3d-val-gen').length) {
                            $item.find('.c3d-val-gen').html((p.generation != null ? p.generation.toFixed(1) : '—') + ' <small>MWh</small>');
                        }
                        if ($item.find('.c3d-val-uds').length) {
                            $item.find('.c3d-val-uds').text((p.activeUnits || 0) + ' generando');
                        }
                    }
                });

                // Update timestamp
                var d = new Date();
                var fechaDisplay = fecha ? fecha.split('-').reverse().join('/') : d.toLocaleDateString('es-MX');
                var horaStr = maxHora > 0 ? (maxHora + ':00') : '--';
                $('#c3dTimestamp').html('<i class="clock outline icon"></i> Datos al: ' + fechaDisplay + ' ' + horaStr + ' hrs &nbsp;|&nbsp; Actualizado: ' + d.toLocaleTimeString('es-MX'));

                // Reinitialize 3D scene with new data
                if (window._c3dReady) {
                    destroyCascade3D();
                    window._c3dReady = false;
                    setTimeout(function() {
                        initCascade3D('cascade3d-wrapper', window._c3dData);
                        window._c3dReady = true;
                    }, 200);
                }

                console.log('[Cascade] Auto-refresh OK — ' + d.toLocaleTimeString());
            },
            error: function(xhr, status, err) {
                console.warn('[Cascade] Auto-refresh error:', err);
            }
        });
    }

    function startCascadeAutoRefresh() {
        if (window._c3dRefreshInterval) return;
        window._c3dRefreshInterval = setInterval(refreshCascadeData, 5 * 60 * 1000); // 5 min
        console.log('[Cascade] Auto-refresh started (cada 5 min)');
    }

    function stopCascadeAutoRefresh() {
        if (window._c3dRefreshInterval) {
            clearInterval(window._c3dRefreshInterval);
            window._c3dRefreshInterval = null;
            console.log('[Cascade] Auto-refresh stopped');
        }
    }

    // ===== DUAL THEME SYSTEM =====
    var fvDarkTheme = {
        chart: { backgroundColor: 'transparent', style: { fontFamily: "'Segoe UI', sans-serif" } },
        title: { text: null, style: { color: '#e8f5e9' } },
        credits: { enabled: false },
        legend: { itemStyle: { color: '#b0bec5', fontWeight: '400' }, itemHoverStyle: { color: '#fff' } },
        xAxis: { labels: { style: { color: '#78909c' } }, gridLineColor: 'rgba(255,255,255,0.05)', lineColor: 'rgba(255,255,255,0.1)' },
        yAxis: { labels: { style: { color: '#78909c' } }, gridLineColor: 'rgba(255,255,255,0.05)', title: { style: { color: '#78909c' } } },
        tooltip: { shared: true, crosshairs: true, backgroundColor: 'rgba(15,25,30,0.95)', borderColor: '#00e676', style: { color: '#e8f5e9' } }
    };
    var fvLightTheme = {
        chart: { backgroundColor: '#ffffff', style: { fontFamily: "'Segoe UI', sans-serif" } },
        title: { text: null, style: { color: '#333' } },
        credits: { enabled: false },
        legend: { itemStyle: { color: '#333', fontWeight: '400' }, itemHoverStyle: { color: '#000' } },
        xAxis: { labels: { style: { color: '#555' } }, gridLineColor: 'rgba(0,0,0,0.08)', lineColor: 'rgba(0,0,0,0.15)' },
        yAxis: { labels: { style: { color: '#555' } }, gridLineColor: 'rgba(0,0,0,0.1)', title: { style: { color: '#555' } } },
        tooltip: { shared: true, crosshairs: true, backgroundColor: 'rgba(255,255,255,0.96)', borderColor: '#1565c0', style: { color: '#333' } }
    };

    var fvSavedTheme = localStorage.getItem('fvChartTheme') || 'dark';
    Highcharts.setOptions(fvSavedTheme === 'light' ? fvLightTheme : fvDarkTheme);
    if (fvSavedTheme === 'light') {
        document.body.classList.add('fv-light');
        $('#fvThemeIcon').removeClass('sun').addClass('moon');
        $('#fvThemeLabel').text('Tema Oscuro');
    }

    // Theme toggle handler
    $('#btnFvThemeToggle').on('click', function() {
        var isLight = document.body.classList.toggle('fv-light');
        var theme = isLight ? fvLightTheme : fvDarkTheme;
        localStorage.setItem('fvChartTheme', isLight ? 'light' : 'dark');
        $('#fvThemeIcon').toggleClass('sun moon');
        $('#fvThemeLabel').text(isLight ? 'Tema Oscuro' : 'Tema Claro');
        Highcharts.charts.forEach(function(c) {
            if (!c) return;
            c.update({
                chart: { backgroundColor: theme.chart.backgroundColor },
                title: { style: theme.title.style },
                xAxis: [{ labels: { style: theme.xAxis.labels.style }, gridLineColor: theme.xAxis.gridLineColor, lineColor: theme.xAxis.lineColor }],
                yAxis: [{ labels: { style: theme.yAxis.labels.style }, gridLineColor: theme.yAxis.gridLineColor, title: { style: theme.yAxis.title.style } }],
                legend: { itemStyle: theme.legend.itemStyle, itemHoverStyle: theme.legend.itemHoverStyle },
                tooltip: theme.tooltip
            }, true, false);
        });
    });

    // ========== NIVELES DE REFERENCIA POR PRESA (desde BD) ==========
    var NIVELES_REF = {};
    var nivelesVisibles = {};

    // Cargar configuración de embalses desde BD
    function loadEmbalseConfig() {
        $.getJSON('/FunVasos/GetEmbalseConfigAll', function(resp) {
            if (resp.success && resp.data) {
                NIVELES_REF = {};
                resp.data.forEach(function(cfg) {
                    NIVELES_REF[cfg.presaKey] = {
                        namo: cfg.namo || 0,
                        name_e: cfg.name || 0,
                        namino: cfg.namino || 0,
                        isActive: cfg.isActive,
                        nombreDisplay: cfg.nombreDisplay,
                        color: cfg.color || '#78909c',
                        id: cfg.id
                    };
                });
                Object.keys(NIVELES_REF).forEach(function(k) {
                    if (!nivelesVisibles[k])
                        nivelesVisibles[k] = { namo: true, name_e: true, namino: true };
                });
                console.log('[FunVasos] EmbalseConfig loaded:', Object.keys(NIVELES_REF).length, 'embalses');
                // Update NAMO_NIVELES for niveles horarios table
                NAMO_NIVELES = {};
                Object.keys(NIVELES_REF).forEach(function(k) {
                    if (NIVELES_REF[k].isActive && NIVELES_REF[k].namo)
                        NAMO_NIVELES[k] = NIVELES_REF[k].namo;
                });
            }
        });
    }
    loadEmbalseConfig();

    // ========== REFERENCIAS PERSONALIZADAS (desde BD) ==========
    var customRefs = {};  // { presaKey: [ {Id, PresaKey, Nombre, Valor, Color, Visible}, ... ] }
    var currentRefPresa = '';

    // Cargar todas las referencias al inicio
    function loadAllReferencias() {
        $.get('@Url.Action("GetReferencias", "FunVasos")', function(r) {
            if (r.success) {
                customRefs = {};
                (r.data || []).forEach(function(ref) {
                    if (!customRefs[ref.presaKey]) customRefs[ref.presaKey] = [];
                    customRefs[ref.presaKey].push(ref);
                });
                console.log('[FunVasos] Referencias cargadas:', customRefs);
            } else {
                console.warn('[FunVasos] No se pudieron cargar referencias:', r.message);
            }
        }).fail(function(xhr) {
            console.warn('[FunVasos] Error cargando referencias:', xhr.status, xhr.responseText && xhr.responseText.substring(0, 200));
        });
    }
    loadAllReferencias();

    // ========== CONSTRUIR plotLines PARA GRÁFICAS DE ELEVACIÓN ==========
    function buildElevPlotLines(presaKey) {
        var lines = [];
        var nivRef = NIVELES_REF[presaKey];
        var vis = nivelesVisibles[presaKey];
        if (nivRef && vis) {
            if (vis.namo) {
                lines.push({ value: nivRef.namo, color: '#ff5252', dashStyle: 'Dash', width: 2, zIndex: 4,
                    label: { text: 'NAMO ' + nivRef.namo.toFixed(2), style: { color: '#ff5252', fontSize: '10px', fontWeight: '700' }, align: 'right', x: -4 } });
            }
            if (vis.name_e) {
                lines.push({ value: nivRef.name_e, color: '#ff9800', dashStyle: 'ShortDash', width: 2, zIndex: 4,
                    label: { text: 'NAME ' + nivRef.name_e.toFixed(2), style: { color: '#ff9800', fontSize: '10px', fontWeight: '700' }, align: 'right', x: -4 } });
            }
            if (vis.namino) {
                lines.push({ value: nivRef.namino, color: '#42a5f5', dashStyle: 'LongDash', width: 2, zIndex: 4,
                    label: { text: 'NAMINO ' + nivRef.namino.toFixed(2), style: { color: '#42a5f5', fontSize: '10px', fontWeight: '700' }, align: 'right', x: -4 } });
            }
        }
        // Custom user references
        var refs = customRefs[presaKey] || [];
        refs.forEach(function(ref) {
            if (ref.visible) {
                lines.push({ value: ref.valor, color: ref.color || '#ffff00', dashStyle: 'DashDot', width: 2, zIndex: 4,
                    label: { text: ref.nombre + ' ' + parseFloat(ref.valor).toFixed(2), style: { color: ref.color || '#ffff00', fontSize: '10px', fontWeight: '600' }, align: 'left', x: 4 } });
            }
        });
        return lines;
    }

    // Build invisible reference series for tooltip display
    function buildRefSeries(plotLines, numPoints) {
        var series = [];
        plotLines.forEach(function(pl) {
            var labelText = pl.label && pl.label.text ? pl.label.text : ('Ref ' + pl.value);
            series.push({
                name: labelText,
                type: 'line',
                yAxis: 0,
                data: Array(numPoints).fill(pl.value),
                color: pl.color || '#ffff00',
                dashStyle: pl.dashStyle || 'Dash',
                lineWidth: 0,
                enableMouseTracking: true,
                showInLegend: false,
                marker: { enabled: false },
                states: { hover: { lineWidth: 0 } }
            });
        });
        return series;
    }

    function renderCharts(presa) {
        var d = presasData[presa];
        if (!d) return;
        var cats = d.labels;
        var key = sanitizeId(presa);
        var elevPlotLines = buildElevPlotLines(key);

        // Combined Chart: Comportamiento del Embalse
        indivCharts[key + '_combo'] = renderComboChart('chart-combo-' + key, d, cats, null, elevPlotLines);

        // Elevation
        var elevRefSeries = buildRefSeries(elevPlotLines, cats.length);
        indivCharts[key + '_elev'] = Highcharts.chart('chart-elev-' + key, {
            chart: { type: 'areaspline' },
            xAxis: { categories: cats },
            yAxis: { title: { text: 'm.s.n.m' }, plotLines: elevPlotLines },
            tooltip: {
                shared: true,
                backgroundColor: 'rgba(15,25,30,0.95)',
                borderColor: '#00e676',
                style: { color: '#e8f5e9' }
            },
            series: [{
                name: 'Elevación',
                data: d.elevacion,
                color: '#00e676',
                fillColor: { linearGradient: {x1:0,y1:0,x2:0,y2:1}, stops: [[0,'rgba(0,230,118,0.3)'],[1,'rgba(0,230,118,0.02)']] },
                marker: { radius: 3 }
            }].concat(elevRefSeries)
        });

        // Q Flows
        indivCharts[key + '_qflow'] = Highcharts.chart('chart-qflow-' + key, {
            chart: { type: 'column' },
            xAxis: { categories: cats },
            yAxis: { title: { text: 'm³/s' } },
            plotOptions: { column: { borderRadius: 2, borderWidth: 0 } },
            series: [
                { name: 'Aportaciones', data: d.aportQ, color: '#ffab40' },
                { name: d.isTapon ? 'Canal' : 'Turbinas', data: d.turbQ, color: '#42a5f5' },
                { name: d.isTapon ? 'Túneles' : 'Vertedor', data: d.vertQ, color: '#ef5350' }
            ]
        });

        // Generation (not for Tapón)
        if (!d.isTapon) {
            indivCharts[key + '_gen'] = Highcharts.chart('chart-gen-' + key, {
                chart: { type: 'column' },
                xAxis: { categories: cats },
                yAxis: { title: { text: 'MWH' } },
                plotOptions: { column: { borderRadius: 2, borderWidth: 0 } },
                series: [{
                    name: 'Generación',
                    data: d.gen,
                    color: '#e040fb'
                }]
            });
        }

        // Almacenamiento
        indivCharts[key + '_almac'] = Highcharts.chart('chart-almac-' + key, {
            chart: { type: 'areaspline' },
            xAxis: { categories: cats },
            yAxis: { title: { text: 'Mill. m³' } },
            series: [{
                name: 'Almacenamiento',
                data: d.almacenamiento,
                color: '#00b0ff',
                fillColor: { linearGradient: {x1:0,y1:0,x2:0,y2:1}, stops: [[0,'rgba(0,176,255,0.3)'],[1,'rgba(0,176,255,0.02)']] },
                marker: { radius: 3 }
            }]
        });
    }

    function renderComboChart(containerId, d, cats, height, elevPlotLines) {
        var pLines = elevPlotLines || [];
        // Calculate Y-axis range to include plotLines
        var elevMin = null, elevMax = null;
        if (d.elevacion && d.elevacion.length) {
            d.elevacion.forEach(function(v) { if (v != null) { if (elevMin === null || v < elevMin) elevMin = v; if (elevMax === null || v > elevMax) elevMax = v; } });
        }
        pLines.forEach(function(pl) { if (pl.value != null) { if (elevMin === null || pl.value < elevMin) elevMin = pl.value; if (elevMax === null || pl.value > elevMax) elevMax = pl.value; } });
        var yMinElev = elevMin !== null ? elevMin - (elevMax - elevMin) * 0.05 - 0.5 : undefined;
        var yMaxElev = elevMax !== null ? elevMax + (elevMax - elevMin) * 0.05 + 0.5 : undefined;
        var seriesBars = [
            { name: 'Gasto Aportado (m³/s)', data: d.aportQ, color: '#2196F3', type: 'column', yAxis: 1 },
            { name: d.isTapon ? 'Gasto Canal (m³/s)' : 'Gasto Extracción Turbinas (m³/s)', data: d.turbQ, color: '#FFC107', type: 'column', yAxis: 1 },
            { name: d.isTapon ? 'Gasto Túneles (m³/s)' : 'Gasto Extracción Vertedor (m³/s)', data: d.vertQ, color: '#FF5722', type: 'column', yAxis: 1 }
        ];
        var seriesLine = {
            name: 'Elev. (msnm)',
            data: d.elevacion,
            type: 'spline',
            yAxis: 0,
            color: '#00e676',
            lineWidth: 2.5,
            marker: { radius: 4, fillColor: '#00e676', lineWidth: 1, lineColor: '#00e676' },
            zIndex: 5
        };

        return Highcharts.chart(containerId, {
            chart: { height: height || null, backgroundColor: 'transparent' },
            title: { text: null },
            credits: { enabled: false },
            xAxis: {
                categories: cats,
                labels: { style: { color: '#78909c', fontSize: '10px' }, rotation: cats.length > 30 ? -45 : 0 },
                gridLineColor: 'rgba(255,255,255,0.05)',
                lineColor: 'rgba(255,255,255,0.1)',
                title: { text: 'Tiempo, horas', style: { color: '#78909c' } }
            },
            yAxis: [{
                title: { text: 'Elevación, msnm', style: { color: '#00e676' } },
                labels: { style: { color: '#78909c' }, format: '{value:.2f}' },
                gridLineColor: 'rgba(255,255,255,0.05)',
                opposite: false,
                plotLines: pLines,
                min: yMinElev,
                max: yMaxElev
            }, {
                title: { text: 'Gasto, m³/s', style: { color: '#2196F3' } },
                labels: { style: { color: '#78909c' } },
                gridLineColor: 'rgba(255,255,255,0.03)',
                opposite: true,
                min: 0
            }],
            tooltip: {
                shared: true,
                backgroundColor: 'rgba(15,25,30,0.95)',
                borderColor: '#00e676',
                style: { color: '#e8f5e9' }
            },
            legend: {
                itemStyle: { color: '#b0bec5', fontWeight: '400', fontSize: '11px' },
                itemHoverStyle: { color: '#fff' }
            },
            plotOptions: {
                column: { borderRadius: 1, borderWidth: 0, groupPadding: 0.15, pointPadding: 0.05 }
            },
            series: [seriesLine].concat(seriesBars).concat(buildRefSeries(pLines, cats.length))
        });
    }

    // Maximize chart to fullscreen
    var currentFsPresa = null;
    window.maximizeChart = function(presaKey, presaTitle) {
        currentFsPresa = presaKey;
        var d = presasData[presaKey];
        if (!d) return;
        var cats = d.labels;
        var elevPlotLines = buildElevPlotLines(sanitizeId(presaKey));
        $('#fsTitleText').text('Comportamiento del Embalse de ' + presaTitle);
        $('#chartFullscreen').addClass('active');
        $('body').css('overflow', 'hidden');
        setTimeout(function() {
            var h = $('#fsChartContainer').height();
            renderComboChart('fsChartContainer', d, cats, h, elevPlotLines);
        }, 100);
    };

    window.closeFullscreen = function() {
        $('#chartFullscreen').removeClass('active');
        $('body').css('overflow', '');
        currentFsPresa = null;
    };

    // Close fullscreen on Escape key
    $(document).on('keydown', function(e) {
        if (e.key === 'Escape' && currentFsPresa) closeFullscreen();
    });

    // ========== INDIVIDUAL CHARTS: Maximize & Export ==========
    var indivCharts = {};  // { presaKey_chartType: Highcharts.Chart instance }

    window.maximizeIndivChart = function(presaKey, chartType, chartTitle) {
        var d = presasData[presaKey];
        if (!d) return;
        var cats = d.labels;
        var key = sanitizeId(presaKey);
        var displayName = PRESA_DISPLAY[presaKey] || presaKey;
        $('#fsTitleText').text(chartTitle + ' — ' + displayName);
        $('#chartFullscreen').addClass('active');
        $('body').css('overflow', 'hidden');
        currentFsPresa = '__indiv__' + presaKey + '_' + chartType;
        setTimeout(function() {
            var h = $('#fsChartContainer').height();
            renderIndivChartTo('fsChartContainer', presaKey, chartType, h);
        }, 100);
    };

    window.exportIndivChart = function(presaKey, chartType) {
        var chart = indivCharts[presaKey + '_' + chartType];
        if (chart) {
            chart.exportChart({ type: 'image/png', filename: chartType + '_' + presaKey }, {
                chart: { backgroundColor: '#0f1923' }
            });
        }
    };

    function renderIndivChartTo(containerId, presaKey, chartType, chartHeight) {
        var d = presasData[presaKey];
        if (!d) return;
        var cats = d.labels;
        var key = sanitizeId(presaKey);
        var elevPlotLines = buildElevPlotLines(key);
        var opts = { chart: { backgroundColor: 'transparent', height: chartHeight || null }, credits: { enabled: false }, exporting: { enabled: false } };

        if (chartType === 'elev') {
            var elevRefSeries = buildRefSeries(elevPlotLines, cats.length);
            Highcharts.chart(containerId, $.extend(true, opts, {
                chart: { type: 'areaspline' },
                title: { text: 'Elevación del Vaso', style: { color: '#e8f5e9', fontSize: '14px' } },
                xAxis: { categories: cats },
                yAxis: { title: { text: 'm.s.n.m' }, plotLines: elevPlotLines },
                tooltip: { shared: true, backgroundColor: 'rgba(15,25,30,0.95)', borderColor: '#00e676', style: { color: '#e8f5e9' } },
                series: [{ name: 'Elevación', data: d.elevacion, color: '#00e676',
                    fillColor: { linearGradient: {x1:0,y1:0,x2:0,y2:1}, stops: [[0,'rgba(0,230,118,0.3)'],[1,'rgba(0,230,118,0.02)']] },
                    marker: { radius: 3 } }].concat(elevRefSeries)
            }));
        } else if (chartType === 'qflow') {
            Highcharts.chart(containerId, $.extend(true, opts, {
                chart: { type: 'column' },
                title: { text: 'Aportaciones vs Extracciones', style: { color: '#e8f5e9', fontSize: '14px' } },
                xAxis: { categories: cats },
                yAxis: { title: { text: 'm³/s' } },
                plotOptions: { column: { borderRadius: 2, borderWidth: 0 } },
                series: [
                    { name: 'Aportaciones', data: d.aportQ, color: '#ffab40' },
                    { name: d.isTapon ? 'Canal' : 'Turbinas', data: d.turbQ, color: '#42a5f5' },
                    { name: d.isTapon ? 'Túneles' : 'Vertedor', data: d.vertQ, color: '#ef5350' }
                ]
            }));
        } else if (chartType === 'gen') {
            Highcharts.chart(containerId, $.extend(true, opts, {
                chart: { type: 'column' },
                title: { text: 'Generación (MWH)', style: { color: '#e8f5e9', fontSize: '14px' } },
                xAxis: { categories: cats },
                yAxis: { title: { text: 'MWH' } },
                plotOptions: { column: { borderRadius: 2, borderWidth: 0 } },
                series: [{ name: 'Generación', data: d.gen, color: '#e040fb' }]
            }));
        } else if (chartType === 'almac') {
            Highcharts.chart(containerId, $.extend(true, opts, {
                chart: { type: 'areaspline' },
                title: { text: 'Almacenamiento (Mill. m³)', style: { color: '#e8f5e9', fontSize: '14px' } },
                xAxis: { categories: cats },
                yAxis: { title: { text: 'Mill. m³' } },
                series: [{ name: 'Almacenamiento', data: d.almacenamiento, color: '#00b0ff',
                    fillColor: { linearGradient: {x1:0,y1:0,x2:0,y2:1}, stops: [[0,'rgba(0,176,255,0.3)'],[1,'rgba(0,176,255,0.02)']] },
                    marker: { radius: 3 } }]
            }));
        }
    }

    // Export functionality
    window.exportTable = function() {
        window.location.href = '@Url.Action("Index", "FunVasos")' + '?fechaInicio=' + $('#fechaInicio').val() + '&fechaFin=' + $('#fechaFin').val() + '&export=true';
    };

    // ========== MODAL: REFERENCIAS PERSONALIZADAS ==========
    var _antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

    window.openRefModal = function(presaKey, presaTitle) {
        currentRefPresa = presaKey;
        $('#refPresaTitle').text(presaTitle);
        resetRefForm();
        renderNivelesToggle(presaKey);
        loadRefTable(presaKey);
        $('#refModal').modal({ closable: false }).modal('show');
    };

    function renderNivelesToggle(presaKey) {
        var nivRef = NIVELES_REF[presaKey];
        var vis = nivelesVisibles[presaKey];
        if (!nivRef || !vis) { $('#refNivelesToggle').html('<span style="color:#546e7a; font-size:12px;">Sin niveles de referencia para esta presa.</span>'); return; }
        var html = '';
        var items = [
            { key: 'namo', label: 'NAMO', val: nivRef.namo, color: '#ff5252', bg: 'rgba(255,82,82,0.15)', border: 'rgba(255,82,82,0.5)' },
            { key: 'name_e', label: 'NAME', val: nivRef.name_e, color: '#ff9800', bg: 'rgba(255,152,0,0.15)', border: 'rgba(255,152,0,0.5)' },
            { key: 'namino', label: 'NAMINO', val: nivRef.namino, color: '#42a5f5', bg: 'rgba(66,165,245,0.15)', border: 'rgba(66,165,245,0.5)' }
        ];
        items.forEach(function(item) {
            var active = vis[item.key] ? 'active' : '';
            html += '<div class="nivel-toggle-chip ' + active + '" data-nivel="' + item.key + '" '
                + 'style="background:' + item.bg + '; border-color:' + item.border + '; color:' + item.color + ';" '
                + 'onclick="toggleNivel(\'' + presaKey + '\', \'' + item.key + '\', this)">'
                + '<i class="' + (vis[item.key] ? 'eye' : 'eye slash') + ' icon" style="margin:0;"></i> '
                + item.label + ' <span class="nivel-val">' + item.val.toFixed(2) + '</span>'
                + '</div>';
        });
        $('#refNivelesToggle').html(html);
    }

    window.toggleNivel = function(presaKey, nivelKey, el) {
        nivelesVisibles[presaKey][nivelKey] = !nivelesVisibles[presaKey][nivelKey];
        var isVis = nivelesVisibles[presaKey][nivelKey];
        $(el).toggleClass('active', isVis);
        $(el).find('i').attr('class', isVis ? 'eye icon' : 'eye slash icon');
    };

    function loadRefTable(presaKey) {
        var refs = customRefs[presaKey] || [];
        var html = '';
        if (refs.length === 0) {
            html = '<tr><td colspan="5" style="color:#546e7a; text-align:center; padding:12px;">No hay asíntotas personalizadas configuradas.</td></tr>';
        } else {
            refs.forEach(function(ref) {
                html += '<tr>'
                    + '<td style="color:#e8f5e9;">' + escHtml(ref.nombre) + '</td>'
                    + '<td style="color:#e8f5e9; text-align:center;">' + parseFloat(ref.valor).toFixed(2) + '</td>'
                    + '<td style="text-align:center;"><span style="display:inline-block; width:20px; height:14px; border-radius:3px; background:' + escHtml(ref.color) + ';"></span></td>'
                    + '<td style="text-align:center;">'
                    + '  <div class="ui fitted toggle checkbox" style="transform:scale(0.8);">'
                    + '    <input type="checkbox" ' + (ref.visible ? 'checked' : '') + ' onchange="toggleRefVisible(' + ref.id + ', this.checked)">'
                    + '    <label></label>'
                    + '  </div>'
                    + '</td>'
                    + '<td style="text-align:center;">'
                    + '  <button class="ui tiny inverted yellow icon button" onclick="editRef(' + ref.id + ')" title="Editar"><i class="edit icon"></i></button>'
                    + '  <button class="ui tiny inverted red icon button" onclick="deleteRef(' + ref.id + ')" title="Eliminar"><i class="trash icon"></i></button>'
                    + '</td>'
                    + '</tr>';
            });
        }
        $('#refTableBody').html(html);
        $('#refTableBody .ui.checkbox').checkbox();
    }

    function escHtml(s) { return $('<span>').text(s).html(); }

    window.resetRefForm = function() {
        $('#refEditId').val('0');
        $('#refNombre').val('');
        $('#refValor').val('');
        $('#refColor').val('#ffff00');
    };

    window.saveReferencia = function() {
        var nombre = $('#refNombre').val().trim();
        var valor = $('#refValor').val();
        if (!nombre || !valor) { alert('Ingresa nombre y valor.'); return; }
        if (!currentRefPresa) { alert('No hay presa seleccionada.'); return; }
        var payload = {
            id: 0,
            presaKey: currentRefPresa,
            nombre: nombre,
            valor: parseFloat(valor),
            color: $('#refColor').val(),
            visible: true
        };
        var editId = parseInt($('#refEditId').val());
        if (editId > 0) payload.id = editId;
        console.log('[FunVasos] Guardando referencia:', payload);
        $.ajax({
            type: 'POST',
            url: '@Url.Action("SaveReferencia", "FunVasos")',
            contentType: 'application/json',
            data: JSON.stringify(payload),
            headers: { 'RequestVerificationToken': _antiForgeryToken },
            success: function(r) {
                console.log('[FunVasos] Respuesta save:', r);
                if (r.success) {
                    if (!customRefs[currentRefPresa]) customRefs[currentRefPresa] = [];
                    var ref = r.referencia;
                    var idx = customRefs[currentRefPresa].findIndex(function(x) { return x.id === ref.id; });
                    if (idx >= 0) customRefs[currentRefPresa][idx] = ref;
                    else customRefs[currentRefPresa].push(ref);
                    resetRefForm();
                    loadRefTable(currentRefPresa);
                    // Re-render charts immediately so user sees the line
                    reRenderPresa(currentRefPresa);
                } else { alert('Error al guardar: ' + (r.message || 'Error desconocido')); }
            },
            error: function(xhr, status, err) {
                console.error('[FunVasos] Error AJAX save:', xhr.status, xhr.responseText);
                alert('Error al guardar referencia (HTTP ' + xhr.status + '). Revisa la consola del navegador.');
            }
        });
    };

    window.editRef = function(id) {
