    window.renderNivelesHorarios = function() {
        var presas = getNivelesPresas();
        buildNivelesHeaders();

        var tbody = $('#nivelesHorariosBody');
        tbody.empty();

        // Build hour maps for each presa
        function buildHourMap(pd) {
            if (!pd) return {};
            var map = {};
            for (var i = 0; i < pd.labels.length; i++) {
                var lbl = pd.labels[i];
                var parts = lbl.split(' ');
                var hourStr = parts.length > 1 ? parts[parts.length - 1] : parts[0];
                var h = parseInt(hourStr);
                if (!isNaN(h)) map[h] = pd.elevacion[i];
            }
            return map;
        }

        var hourMaps = {};
        presas.forEach(function(p) {
            hourMaps[p.presaKey] = buildHourMap(presasData[p.presaKey]);
        });

        for (var h = 1; h <= 24; h++) {
            var fmt = function(v) { return v != null ? v.toFixed(2) : ''; };
            var row = '<tr><td style="text-align:center; color:#4caf50; font-weight:600;">' + h + '</td>';
            presas.forEach(function(p) {
                var val = hourMaps[p.presaKey] ? hourMaps[p.presaKey][h] : null;
                row += '<td style="text-align:center;">' + fmt(val) + '</td>';
                if (p.hasDif) {
                    var dif = (val != null && p.namo) ? (p.namo - val) : null;
                    row += '<td style="text-align:center; color:' + (dif != null && dif > 0 ? '#ffab40' : '#00e676') + ';">' + fmt(dif) + '</td>';
                }
            });
            row += '</tr>';
            tbody.append(row);
        }

        renderNivelCharts();
    };

