    // Cargar todas las referencias al inicio
    function loadAllReferencias() {
        $.get('@Url.Action("GetReferencias", "FunVasos")', function(r) {
            if (r.success) {
                customRefs = {};
                (r.data || []).forEach(function(ref) {
                    if (!customRefs[ref.presaKey]) customRefs[ref.presaKey] = [];
                    customRefs[ref.presaKey].push(ref);
                });
                console.log('[FunVasos] Referencias cargadas:', customRefs);
            } else {
                console.warn('[FunVasos] No se pudieron cargar referencias:', r.message);
            }
        }).fail(function(xhr) {
