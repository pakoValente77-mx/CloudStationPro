    // ========== CONSTRUIR plotLines PARA GRÁFICAS DE ELEVACIÓN ==========
    function buildElevPlotLines(presaKey) {
        var lines = [];
        var nivRef = NIVELES_REF[presaKey];
        var vis = nivelesVisibles[presaKey];
        if (nivRef && vis) {
            if (vis.namo) {
                lines.push({ value: nivRef.namo, color: '#ff5252', dashStyle: 'Dash', width: 2, zIndex: 4,
                    label: { text: 'NAMO ' + nivRef.namo.toFixed(2), style: { color: '#ff5252', fontSize: '10px', fontWeight: '700' }, align: 'right', x: -4 } });
            }
            if (vis.name_e) {
                lines.push({ value: nivRef.name_e, color: '#ff9800', dashStyle: 'ShortDash', width: 2, zIndex: 4,
                    label: { text: 'NAME ' + nivRef.name_e.toFixed(2), style: { color: '#ff9800', fontSize: '10px', fontWeight: '700' }, align: 'right', x: -4 } });
            }
            if (vis.namino) {
                lines.push({ value: nivRef.namino, color: '#42a5f5', dashStyle: 'LongDash', width: 2, zIndex: 4,
                    label: { text: 'NAMINO ' + nivRef.namino.toFixed(2), style: { color: '#42a5f5', fontSize: '10px', fontWeight: '700' }, align: 'right', x: -4 } });
            }
        }
        // Custom user references
        var refs = customRefs[presaKey] || [];
        refs.forEach(function(ref) {
            if (ref.visible) {
                lines.push({ value: ref.valor, color: ref.color || '#ffff00', dashStyle: 'DashDot', width: 2, zIndex: 4,
                    label: { text: ref.nombre + ' ' + parseFloat(ref.valor).toFixed(2), style: { color: ref.color || '#ffff00', fontSize: '10px', fontWeight: '600' }, align: 'left', x: 4 } });
            }
        });
        return lines;
    }

    // Build invisible reference series for tooltip display
    function buildRefSeries(plotLines, numPoints) {
        var series = [];
        plotLines.forEach(function(pl) {
            var labelText = pl.label && pl.label.text ? pl.label.text : ('Ref ' + pl.value);
            series.push({
                name: labelText,
                type: 'line',
                yAxis: 0,
                data: Array(numPoints).fill(pl.value),
                color: pl.color || '#ffff00',
                dashStyle: pl.dashStyle || 'Dash',
                lineWidth: 0,
                enableMouseTracking: true,
                showInLegend: false,
                marker: { enabled: false },
                states: { hover: { lineWidth: 0 } }
            });
        });
        return series;
    }

    function renderCharts(presa) {
        var d = presasData[presa];
        if (!d) return;
        var cats = d.labels;
        var key = sanitizeId(presa);
        var elevPlotLines = buildElevPlotLines(key);

        // Combined Chart: Comportamiento del Embalse
        indivCharts[key + '_combo'] = renderComboChart('chart-combo-' + key, d, cats, null, elevPlotLines);

        // Elevation
        var elevRefSeries = buildRefSeries(elevPlotLines, cats.length);
        indivCharts[key + '_elev'] = Highcharts.chart('chart-elev-' + key, {
            chart: { type: 'areaspline' },
            xAxis: { categories: cats },
            yAxis: { title: { text: 'm.s.n.m' }, plotLines: elevPlotLines },
            tooltip: {
                shared: true,
                backgroundColor: 'rgba(15,25,30,0.95)',
                borderColor: '#00e676',
                style: { color: '#e8f5e9' }
            },
            series: [{
                name: 'Elevación',
                data: d.elevacion,
                color: '#00e676',
                fillColor: { linearGradient: {x1:0,y1:0,x2:0,y2:1}, stops: [[0,'rgba(0,230,118,0.3)'],[1,'rgba(0,230,118,0.02)']] },
                marker: { radius: 3 }
            }].concat(elevRefSeries)
        });

        // Q Flows
        indivCharts[key + '_qflow'] = Highcharts.chart('chart-qflow-' + key, {
            chart: { type: 'column' },
            xAxis: { categories: cats },
            yAxis: { title: { text: 'm³/s' } },
            plotOptions: { column: { borderRadius: 2, borderWidth: 0 } },
            series: [
                { name: 'Aportaciones', data: d.aportQ, color: '#ffab40' },
                { name: d.isTapon ? 'Canal' : 'Turbinas', data: d.turbQ, color: '#42a5f5' },
                { name: d.isTapon ? 'Túneles' : 'Vertedor', data: d.vertQ, color: '#ef5350' }
            ]
        });

        // Generation (not for Tapón)
        if (!d.isTapon) {
            indivCharts[key + '_gen'] = Highcharts.chart('chart-gen-' + key, {
                chart: { type: 'column' },
                xAxis: { categories: cats },
                yAxis: { title: { text: 'MWH' } },
                plotOptions: { column: { borderRadius: 2, borderWidth: 0 } },
                series: [{
                    name: 'Generación',
                    data: d.gen,
                    color: '#e040fb'
                }]
            });
        }

        // Almacenamiento
        indivCharts[key + '_almac'] = Highcharts.chart('chart-almac-' + key, {
            chart: { type: 'areaspline' },
            xAxis: { categories: cats },
            yAxis: { title: { text: 'Mill. m³' } },
            series: [{
                name: 'Almacenamiento',
                data: d.almacenamiento,
                color: '#00b0ff',
                fillColor: { linearGradient: {x1:0,y1:0,x2:0,y2:1}, stops: [[0,'rgba(0,176,255,0.3)'],[1,'rgba(0,176,255,0.02)']] },
                marker: { radius: 3 }
            }]
        });
    }

    function renderComboChart(containerId, d, cats, height, elevPlotLines) {
        var pLines = elevPlotLines || [];
        // Calculate Y-axis range to include plotLines
        var elevMin = null, elevMax = null;
        if (d.elevacion && d.elevacion.length) {
            d.elevacion.forEach(function(v) { if (v != null) { if (elevMin === null || v < elevMin) elevMin = v; if (elevMax === null || v > elevMax) elevMax = v; } });
        }
        pLines.forEach(function(pl) { if (pl.value != null) { if (elevMin === null || pl.value < elevMin) elevMin = pl.value; if (elevMax === null || pl.value > elevMax) elevMax = pl.value; } });
        var yMinElev = elevMin !== null ? elevMin - (elevMax - elevMin) * 0.05 - 0.5 : undefined;
        var yMaxElev = elevMax !== null ? elevMax + (elevMax - elevMin) * 0.05 + 0.5 : undefined;
        var seriesBars = [
            { name: 'Gasto Aportado (m³/s)', data: d.aportQ, color: '#2196F3', type: 'column', yAxis: 1 },
            { name: d.isTapon ? 'Gasto Canal (m³/s)' : 'Gasto Extracción Turbinas (m³/s)', data: d.turbQ, color: '#FFC107', type: 'column', yAxis: 1 },
            { name: d.isTapon ? 'Gasto Túneles (m³/s)' : 'Gasto Extracción Vertedor (m³/s)', data: d.vertQ, color: '#FF5722', type: 'column', yAxis: 1 }
        ];
        var seriesLine = {
            name: 'Elev. (msnm)',
            data: d.elevacion,
            type: 'spline',
            yAxis: 0,
            color: '#00e676',
            lineWidth: 2.5,
            marker: { radius: 4, fillColor: '#00e676', lineWidth: 1, lineColor: '#00e676' },
            zIndex: 5
        };

        return Highcharts.chart(containerId, {
            chart: { height: height || null, backgroundColor: 'transparent' },
            title: { text: null },
            credits: { enabled: false },
            xAxis: {
                categories: cats,
                labels: { style: { color: '#78909c', fontSize: '10px' }, rotation: cats.length > 30 ? -45 : 0 },
                gridLineColor: 'rgba(255,255,255,0.05)',
                lineColor: 'rgba(255,255,255,0.1)',
                title: { text: 'Tiempo, horas', style: { color: '#78909c' } }
            },
            yAxis: [{
                title: { text: 'Elevación, msnm', style: { color: '#00e676' } },
                labels: { style: { color: '#78909c' }, format: '{value:.2f}' },
                gridLineColor: 'rgba(255,255,255,0.05)',
                opposite: false,
                plotLines: pLines,
                min: yMinElev,
                max: yMaxElev
            }, {
                title: { text: 'Gasto, m³/s', style: { color: '#2196F3' } },
                labels: { style: { color: '#78909c' } },
                gridLineColor: 'rgba(255,255,255,0.03)',
                opposite: true,
                min: 0
            }],
            tooltip: {
                shared: true,
                backgroundColor: 'rgba(15,25,30,0.95)',
                borderColor: '#00e676',
                style: { color: '#e8f5e9' }
            },
            legend: {
                itemStyle: { color: '#b0bec5', fontWeight: '400', fontSize: '11px' },
                itemHoverStyle: { color: '#fff' }
            },
            plotOptions: {
                column: { borderRadius: 1, borderWidth: 0, groupPadding: 0.15, pointPadding: 0.05 }
            },
            series: [seriesLine].concat(seriesBars).concat(buildRefSeries(pLines, cats.length))
        });
    }

