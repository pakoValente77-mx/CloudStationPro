    // Cargar datos de entrada al abrir el tab o al cambiar horizonte
    $('#hydroHorizon').on('change', function() { loadHydroInputData(); });
    $('#btnRefreshInputData').on('click', function() { loadHydroInputData(); });

    // ── TABLA DE EXTRACCIONES PROGRAMADAS (por día) ──
    var _hydroInitialExtractions = {}; // { damName: m³/s }
    var _hydroInitialAportations = {}; // { damName: m³/s }
    var _hydroInitialParams = {};      // { damName: { cn, drainCoeff } }
    var _damOrder = ['Angostura', 'Chicoasen', 'Malpaso', 'JGrijalva', 'Penitas'];

    function _getDays() {
        var horizon = parseInt($('#hydroHorizon').val());
        var days = Math.ceil(horizon / 24);
        return Math.max(1, Math.min(days, 15));
    }

    function _dayHeaders(color) {
        var days = _getDays();
        var today = new Date();
        var html = '<tr style="background:rgba(' + color + ',0.08);">';
        html += '<th style="min-width:100px; position:sticky; left:0; background:#131c24; z-index:1;">Presa</th>';
        for (var d = 0; d < days; d++) {
            var dt = new Date(today); dt.setDate(today.getDate() + d);
            var dateStr = dt.toLocaleDateString('es-MX', { day: '2-digit', month: 'short' });
            html += '<th style="text-align:center; min-width:75px;">D' + (d + 1) + '<br><span style="font-size:10px; color:#78909c; font-weight:400;">' + dateStr + '</span></th>';
        }
        return html + '</tr>';
    }

    function _scheduleRows(className, initValues, inputColor, borderColor) {
        var days = _getDays();
        var html = '';
        _damOrder.forEach(function(dam) {
            var color = damColors[dam] || '#ccc';
            var label = damLabels[dam] || dam;
            var initQ = initValues[dam] || 0;
            html += '<tr>';
            html += '<td style="color:' + color + '; font-weight:600; position:sticky; left:0; background:#131c24; z-index:1;">' + label + '</td>';
            for (var d = 0; d < days; d++) {
                html += '<td style="text-align:center;">';
                html += '<input type="number" step="0.1" min="0" class="' + className + '" data-dam="' + dam + '" data-day="' + d + '" ';
                html += 'value="' + initQ.toFixed(1) + '" ';
                html += 'style="background:' + inputColor + '; border:1px solid ' + borderColor + '; color:' + borderColor.replace('0.3', '1') + '; font-weight:600; width:70px; padding:3px 4px; border-radius:4px; font-size:12px; text-align:right;">';
                html += '</td>';
            }
            html += '</tr>';
        });
        return html;
    }

    function buildExtractionScheduleTable() {
        $('#extractionScheduleHead').html(_dayHeaders('255,112,67').replace(/>Presa</g, ' style="color:#ff7043;">Presa<').replace(/>D/g, ' style="color:#ff7043;">D'));
        // Re-color headers
        var headHtml = _dayHeaders('255,112,67');
        headHtml = headHtml.replace(/<th /g, '<th style="color:#ff7043;" ');
        $('#extractionScheduleHead').html(headHtml);
        $('#extractionScheduleBody').html(_scheduleRows('hydro-sched-input', _hydroInitialExtractions, 'rgba(255,112,67,0.08)', 'rgba(255,112,67,0.3)'));
    }

    function buildAportationScheduleTable() {
        var headHtml = _dayHeaders('79,195,247');
        headHtml = headHtml.replace(/<th /g, '<th style="color:#4fc3f7;" ');
        $('#aportationScheduleHead').html(headHtml);
        $('#aportationScheduleBody').html(_scheduleRows('hydro-aport-input', _hydroInitialAportations, 'rgba(79,195,247,0.08)', 'rgba(79,195,247,0.3)'));
    }

    function buildModelParamsTable() {
        var html = '';
        _damOrder.forEach(function(dam) {
            var color = damColors[dam] || '#ccc';
            var label = damLabels[dam] || dam;
            var p = _hydroInitialParams[dam] || { cn: 75, drainCoeff: 0.15 };
            html += '<tr>';
            html += '<td style="color:' + color + '; font-weight:600;">' + label + '</td>';
            html += '<td style="text-align:center;"><input type="number" step="1" min="30" max="100" class="hydro-cn-input" data-dam="' + dam + '" value="' + p.cn.toFixed(0) + '" style="background:rgba(171,71,188,0.08); border:1px solid rgba(171,71,188,0.3); color:#ce93d8; font-weight:600; width:60px; padding:3px 4px; border-radius:4px; font-size:12px; text-align:right;"></td>';
            html += '<td style="text-align:center;"><input type="number" step="0.01" min="0" max="1" class="hydro-dc-input" data-dam="' + dam + '" value="' + p.drainCoeff.toFixed(2) + '" style="background:rgba(171,71,188,0.08); border:1px solid rgba(171,71,188,0.3); color:#ce93d8; font-weight:600; width:60px; padding:3px 4px; border-radius:4px; font-size:12px; text-align:right;"></td>';
            html += '</tr>';
        });
        $('#modelParamsBody').html(html);
    }

    // Al cargar datos de entrada, guardar valores iniciales y reconstruir tablas
    var _origRenderHydroInput = renderHydroInputData;
    renderHydroInputData = function(data) {
        _origRenderHydroInput(data);
        data.dams.forEach(function(d) {
            _hydroInitialExtractions[d.damName] = d.extraccionQ || 0;
            _hydroInitialAportations[d.damName] = d.aportacionQ || 0;
            _hydroInitialParams[d.damName] = {
                cn: d.curveNumber || 75,
                drainCoeff: d.drainCoeff || 0.15
            };
        });
        buildExtractionScheduleTable();
        buildAportationScheduleTable();
        buildModelParamsTable();
    };

    // ── Botones Fill/Reset para Extracciones ──
    $('#btnFillExtraction').on('click', function() {
        _damOrder.forEach(function(dam) {
            var d0 = $('.hydro-sched-input[data-dam="' + dam + '"][data-day="0"]').val();
            if (d0 !== undefined) $('.hydro-sched-input[data-dam="' + dam + '"]').val(d0);
        });
    });
    $('#btnResetExtraction').on('click', function() {
        $('.hydro-sched-input').each(function() {
            $(this).val((_hydroInitialExtractions[$(this).data('dam')] || 0).toFixed(1));
        });
    });

    // ── Botones Fill/Reset para Aportaciones ──
    $('#btnFillAportation').on('click', function() {
        _damOrder.forEach(function(dam) {
            var d0 = $('.hydro-aport-input[data-dam="' + dam + '"][data-day="0"]').val();
            if (d0 !== undefined) $('.hydro-aport-input[data-dam="' + dam + '"]').val(d0);
        });
    });
    $('#btnResetAportation').on('click', function() {
        $('.hydro-aport-input').each(function() {
            $(this).val((_hydroInitialAportations[$(this).data('dam')] || 0).toFixed(1));
        });
    });

    // ── Reset Parámetros del Modelo ──
    $('#btnResetParams').on('click', function() {
        $('.hydro-cn-input').each(function() {
            var p = _hydroInitialParams[$(this).data('dam')] || { cn: 75 };
            $(this).val(p.cn.toFixed(0));
        });
        $('.hydro-dc-input').each(function() {
            var p = _hydroInitialParams[$(this).data('dam')] || { drainCoeff: 0.15 };
            $(this).val(p.drainCoeff.toFixed(2));
        });
    });

    // ── Recoger schedules y parámetros ──
    function getExtractionSchedule() {
        var schedule = {};
        $('.hydro-sched-input').each(function() {
            var dam = $(this).data('dam'), day = parseInt($(this).data('day'));
            var val = parseFloat($(this).val());
            if (isNaN(val) || val < 0) val = 0;
            if (!schedule[dam]) schedule[dam] = [];
            schedule[dam][day] = val;
        });
        return schedule;
    }

    function getAportationSchedule() {
        var schedule = {};
        var hasAny = false;
        $('.hydro-aport-input').each(function() {
            var dam = $(this).data('dam'), day = parseInt($(this).data('day'));
            var val = parseFloat($(this).val());
            if (isNaN(val) || val < 0) val = 0;
            if (!schedule[dam]) schedule[dam] = [];
            schedule[dam][day] = val;
            if (val > 0) hasAny = true;
        });
        return hasAny ? schedule : null;
    }

    function getModelParams() {
        var drainCoefficients = {}, curveNumbers = {}, hasChanges = false;
        $('.hydro-cn-input').each(function() {
            var dam = $(this).data('dam'), val = parseFloat($(this).val());
            var orig = (_hydroInitialParams[dam] || {}).cn || 75;
            if (!isNaN(val) && Math.abs(val - orig) > 0.01) { curveNumbers[dam] = val; hasChanges = true; }
        });
        $('.hydro-dc-input').each(function() {
            var dam = $(this).data('dam'), val = parseFloat($(this).val());
            var orig = (_hydroInitialParams[dam] || {}).drainCoeff || 0.15;
            if (!isNaN(val) && Math.abs(val - orig) > 0.001) { drainCoefficients[dam] = val; hasChanges = true; }
        });
        return hasChanges ? { drainCoefficients: drainCoefficients, curveNumbers: curveNumbers } : null;
    }

    $('#btnRunHydroSim').on('click', function() {
        var horizon = parseInt($('#hydroHorizon').val());
        var $btn = $(this);
        $btn.addClass('loading disabled');
        $('#hydroSimStatus').text('Ejecutando simulación...').css('color', '#ffab40');
        $('#hydroSimSummary').hide();
        $('#hydroSimCharts').empty();
        $('#hydroSimTable').hide();

        // Recoger extracciones editadas por el usuario
        var extractions = {};
        $('.hydro-extraction-input').each(function() {
            var dam = $(this).data('dam');
            var val = parseFloat($(this).val());
            if (!isNaN(val) && val >= 0) {
                extractions[dam] = val;
            }
        });

        // Recoger programa de extracciones por día
        var extractionSchedule = getExtractionSchedule();

        // Recoger programa de aportaciones por día
        var aportationSchedule = getAportationSchedule();

        // Recoger parámetros del modelo editados
        var modelParams = getModelParams();

        var postData = {
            horizonHours: horizon,
            extractions: extractions,
            extractionSchedule: extractionSchedule,
            aportationSchedule: aportationSchedule,
            drainCoefficients: modelParams ? modelParams.drainCoefficients : null,
            curveNumbers: modelParams ? modelParams.curveNumbers : null
        };

        $.ajax({
            url: '@Url.Action("RunSimulation", "HydroForecast")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(postData),
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            success: function(res) {
                $btn.removeClass('loading disabled');
                if (!res.success) {
                    $('#hydroSimStatus').text('Error: ' + res.message).css('color', '#ff5252');
                    return;
                }
                hydroSimData = res;
                var dateStr = res.forecastDate ? 'Pronóstico: ' + res.forecastDate : '';
                $('#hydroSimStatus').html('<i class="check circle icon" style="color:#00e676;"></i> Simulación completada — ' + dateStr).css('color', '#a5d6a7');

                renderHydroSummary(res);
                renderHydroCharts(res);
                renderHydroTable(res);
            },
            error: function() {
                $btn.removeClass('loading disabled');
                $('#hydroSimStatus').text('Error de conexión').css('color', '#ff5252');
            }
        });
    });

    function renderHydroSummary(res) {
        var html = '';
        res.dams.forEach(function(d) {
            var color = damColors[d.damName] || '#00e676';
            var label = damLabels[d.damName] || d.damName;
            var arrow = d.deltaElev >= 0 ? '▲' : '▼';
            var arrowColor = d.deltaElev >= 0 ? '#ff5252' : '#4caf50';
            html += '<div class="summary-card" style="min-width:160px; border-left:3px solid ' + color + ';">';
            html += '  <div class="label" style="color:' + color + ';">' + label + '</div>';
            html += '  <div class="value" style="color:#e8f5e9; font-size:18px;">' + d.initialElev.toFixed(2) + '</div>';
            html += '  <div class="unit">msnm actual</div>';
            html += '  <div style="margin-top:6px; font-size:13px;">';
            html += '    <span style="color:' + arrowColor + '; font-weight:700;">' + arrow + ' ' + (d.deltaElev >= 0 ? '+' : '') + d.deltaElev.toFixed(2) + ' m</span>';
            html += '    <span style="color:#78909c;"> → ' + d.finalElev.toFixed(2) + '</span>';
            html += '  </div>';
            html += '  <div style="font-size:11px; color:#546e7a; margin-top:4px;">Máx: ' + d.maxElev.toFixed(2) + ' | Mín: ' + d.minElev.toFixed(2) + '</div>';
            html += '</div>';
        });
        $('#hydroSummaryCards').html(html);
        $('#hydroSimSummary').show();
    }

    function renderHydroCharts(res) {
        var container = $('#hydroSimCharts');
        container.empty();

        var isLight = document.body.classList.contains('fv-light');
        var bgColor = isLight ? '#ffffff' : '#0f1923';
        var textColor = isLight ? '#555' : '#78909c';
        var gridColor = isLight ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)';
        var tooltipBg = isLight ? 'rgba(255,255,255,0.96)' : 'rgba(15,25,30,0.95)';
        var tooltipText = isLight ? '#333' : '#e8f5e9';
        var legendColor = isLight ? '#333' : '#b0bec5';

        res.dams.forEach(function(d) {
            var color = damColors[d.damName] || '#00e676';
            var label = damLabels[d.damName] || d.damName;
            var chartId = 'hydro-chart-' + d.damName;

            container.append(
                '<div class="chart-card" style="position:relative;">' +
                '  <div style="position:absolute; top:8px; right:8px; z-index:3; display:flex; gap:5px;">' +
                '    <button class="btn-action-sm" type="button" onclick="exportHydroChart(\'' + d.damName + '\')" title="Exportar PNG"><i class="download icon"></i></button>' +
                '  </div>' +
                '  <div id="' + chartId + '" style="height:400px;"></div>' +
                '</div>'
            );

            var times = d.hourly.map(function(h) { return new Date(h.time).getTime(); });
            var elevData = d.hourly.map(function(h, i) { return [times[i], h.elev]; });
            var rainData = d.hourly.map(function(h, i) { return [times[i], h.rain]; });
            // Aportación total = cuenca + aguas arriba, convertir Mm³/h → m³/s
            var aportData = d.hourly.map(function(h, i) {
                return [times[i], Math.round((h.basinInput + h.upstreamInput) * 1e6 / 3600 * 100) / 100];
            });
            // Extracción: Mm³/h → m³/s
            var extracData = d.hourly.map(function(h, i) {
                return [times[i], Math.round(h.extraction * 1e6 / 3600 * 100) / 100];
            });

            // Nivel final = asíntota
            var asintotaVal = d.finalElev;
            var asintotaData = times.length >= 2 ? [[times[0], asintotaVal], [times[times.length - 1], asintotaVal]] : [];

            // PlotLines: NAMO, NAME, Nivel Actual
            var elevPlotLines = [
                { value: d.initialElev, color: 'rgba(255,255,255,0.3)', width: 1, dashStyle: 'Dot',
                  label: { text: 'Actual: ' + d.initialElev.toFixed(2), style: { color: isLight ? '#666' : 'rgba(255,255,255,0.5)', fontSize: '10px' } } }
            ];
            // Add NAMO/NAME from known levels
            var knownLevels = {
                'Angostura': { namo: 539.00, name_e: 542.10 },
                'Chicoasen': { namo: 395.00, name_e: 400.00 },
                'Malpaso': { namo: 189.70, name_e: 192.00 },
                'JGrijalva': { namo: 100.00, name_e: 105.50 },
                'Penitas': { namo: 95.10, name_e: 99.20 }
            };
            var kl = knownLevels[d.damName];
            if (kl) {
                elevPlotLines.push({ value: kl.namo, color: '#ffeb3b', width: 2, dashStyle: 'Dash',
                    label: { text: 'NAMO ' + kl.namo.toFixed(1), style: { color: '#ffeb3b', fontSize: '10px', fontWeight: '600' }, align: 'right' }, zIndex: 5 });
                elevPlotLines.push({ value: kl.name_e, color: '#ff5252', width: 2, dashStyle: 'Dash',
                    label: { text: 'NAME ' + kl.name_e.toFixed(1), style: { color: '#ff5252', fontSize: '10px', fontWeight: '600' }, align: 'right' }, zIndex: 5 });
            }

            var arrow = d.deltaElev >= 0 ? '▲' : '▼';
            var deltaColor = d.deltaElev >= 0 ? (isLight ? '#d84315' : '#ff7043') : (isLight ? '#2e7d32' : '#66bb6a');

            window['_hydroChart_' + d.damName] = Highcharts.chart(chartId, {
                chart: { backgroundColor: bgColor, height: 400, zoomType: 'x' },
                title: {
                    text: label + ' — Comportamiento del Embalse',
                    style: { color: color, fontSize: '15px', fontWeight: '700' }
                },
                subtitle: {
                    text: 'Actual: ' + d.initialElev.toFixed(2) + ' msnm → ' + arrow + ' ' + (d.deltaElev >= 0 ? '+' : '') + d.deltaElev.toFixed(2) + ' m → Asíntota: ' + asintotaVal.toFixed(2) + ' msnm (' + res.horizonHours + 'h)',
                    style: { color: deltaColor, fontSize: '12px', fontWeight: '600' }
                },
                exporting: { enabled: true, buttons: { contextButton: { theme: { fill: bgColor } } } },
                time: { useUTC: false },
                xAxis: {
                    type: 'datetime',
                    labels: { style: { color: textColor, fontSize: '10px' }, format: '{value:%d/%m %H:%M}' },
                    gridLineColor: gridColor
                },
                yAxis: [{
                    title: { text: 'Nivel (msnm)', style: { color: textColor } },
                    labels: { style: { color: textColor }, format: '{value:.2f}' },
                    gridLineColor: gridColor,
                    plotLines: elevPlotLines
                }, {
                    title: { text: 'Gasto (m³/s)', style: { color: textColor } },
                    labels: { style: { color: textColor } },
                    opposite: true,
                    gridLineColor: isLight ? 'rgba(0,0,0,0.03)' : 'rgba(255,255,255,0.03)',
                    min: 0
                }, {
                    title: { text: 'Lluvia (mm)', style: { color: '#42a5f5' } },
                    labels: { style: { color: '#42a5f5' } },
                    opposite: true,
                    reversed: true, min: 0,
                    gridLineWidth: 0,
                    top: '0%', height: '20%', offset: 0
                }],
                plotOptions: {
                    series: { animation: { duration: 800 } },
                    column: { borderRadius: 1, borderWidth: 0, groupPadding: 0.1, pointPadding: 0.05 }
                },
                series: [
                    // Nivel
                    {
                        name: 'Nivel (msnm)', type: 'areaspline', data: elevData, color: color,
                        fillColor: { linearGradient: { x1: 0, y1: 0, x2: 0, y2: 1 },
                            stops: [[0, Highcharts.color(color).setOpacity(0.25).get()], [1, Highcharts.color(color).setOpacity(0.02).get()]] },
                        lineWidth: 2.5, marker: { enabled: false }, yAxis: 0, zIndex: 3
                    },
                    // Asíntota
                    {
                        name: 'Asíntota (' + asintotaVal.toFixed(2) + ' msnm)', type: 'line',
                        data: asintotaData,
                        color: '#ce93d8', lineWidth: 2, dashStyle: 'LongDashDot',
                        marker: { enabled: false }, yAxis: 0, zIndex: 4
                    },
                    // Aportación (columna azul)
                    {
                        name: 'Aportación (m³/s)', type: 'column', data: aportData, color: '#2196F3',
                        yAxis: 1, zIndex: 1, opacity: 0.7
                    },
                    // Extracción (columna naranja)
                    {
                        name: 'Extracción (m³/s)', type: 'column', data: extracData, color: '#FF5722',
                        yAxis: 1, zIndex: 1, opacity: 0.7
                    },
                    // Lluvia (barras invertidas arriba)
                    {
                        name: 'Lluvia (mm)', type: 'column', data: rainData, color: 'rgba(66,165,245,0.5)',
                        borderWidth: 0, pointPadding: 0, groupPadding: 0, yAxis: 2
                    }
                ],
                legend: { itemStyle: { color: legendColor, fontSize: '11px' }, backgroundColor: 'transparent' },
                credits: { enabled: false },
                tooltip: {
                    shared: true, crosshairs: true,
                    backgroundColor: tooltipBg, borderColor: color,
                    style: { color: tooltipText },
                    xDateFormat: '%d/%m/%Y %H:%M'
                }
            });
        });
    }

    window.exportHydroChart = function(damName) {
        var chart = window['_hydroChart_' + damName];
        if (chart) {
            var isL = document.body.classList.contains('fv-light');
            chart.exportChart({ type: 'image/png', filename: 'comportamiento_' + damName }, {
                chart: { backgroundColor: isL ? '#ffffff' : '#0f1923' }
            });
        }
    };

    // ══════════════════════════════════════════════════
    // TABLA FUNCIONAMIENTO DE VASOS SIMULADO
    // ══════════════════════════════════════════════════
    var _hydroTableData = null;
    var _hydroTableActiveDam = null;

    function renderHydroTable(res) {
        if (!res.dams || !res.dams.length) return;
        _hydroTableData = res;

        // Generar tabs por presa
        var tabsHtml = '';
        res.dams.forEach(function(d, i) {
            var c = damColors[d.damName] || '#ccc';
            var l = damLabels[d.damName] || d.damName;
            var active = (_hydroTableActiveDam === d.damName || (!_hydroTableActiveDam && i === 0));
            if (active) _hydroTableActiveDam = d.damName;
            tabsHtml += '<button class="hydro-table-tab" data-dam="' + d.damName + '" style="';
            tabsHtml += 'padding:5px 14px; border-radius:4px; font-size:12px; font-weight:600; cursor:pointer; border:1px solid ' + c + ';';
            tabsHtml += active
                ? 'background:' + c + '; color:#fff;'
                : 'background:transparent; color:' + c + ';';
            tabsHtml += '">' + l + '</button>';
        });
        $('#hydroTableTabs').html(tabsHtml);

        // Click en tabs
        $('.hydro-table-tab').off('click').on('click', function() {
            _hydroTableActiveDam = $(this).data('dam');
            renderHydroTable(_hydroTableData);
        });

        // Intervalo change
        $('#hydroTableInterval').off('change').on('change', function() {
            renderHydroTableBody();
        });

        renderHydroTableBody();
        $('#hydroSimTable').show();
    }

    function renderHydroTableBody() {
        var res = _hydroTableData;
        if (!res) return;
        var dam = res.dams.find(function(d) { return d.damName === _hydroTableActiveDam; });
        if (!dam) dam = res.dams[0];

        var color = damColors[dam.damName] || '#ccc';
        var interval = parseInt($('#hydroTableInterval').val()) || 3;

        // Header estilo FunVasos
        var thead = '<tr style="background:rgba(33,150,243,0.08);">';
        thead += '<th rowspan="2" style="color:#42a5f5; position:sticky; left:0; background:#131c24; z-index:3; min-width:110px;">Fecha / Hora</th>';
        thead += '<th rowspan="2" style="color:#42a5f5; text-align:right;">Elevación<br><span style="font-size:9px; font-weight:400; color:#78909c;">m.s.n.m</span></th>';
        thead += '<th rowspan="2" style="color:#42a5f5; text-align:right;">Almac.<br><span style="font-size:9px; font-weight:400; color:#78909c;">Mill. m³</span></th>';
        thead += '<th rowspan="2" style="color:#42a5f5; text-align:right;">Dif.<br><span style="font-size:9px; font-weight:400; color:#78909c;">Mill. m³</span></th>';
        thead += '<th colspan="2" style="color:#66bb6a; text-align:center; border-bottom:1px solid #37474f;">Aportaciones</th>';
        thead += '<th colspan="2" style="color:#ff7043; text-align:center; border-bottom:1px solid #37474f;">Extracciones</th>';
        thead += '<th rowspan="2" style="color:#42a5f5; text-align:right;">Lluvia<br><span style="font-size:9px; font-weight:400; color:#78909c;">mm</span></th>';
        thead += '</tr>';
        thead += '<tr style="background:rgba(33,150,243,0.05);">';
        thead += '<th style="color:#66bb6a; text-align:right; font-size:10px;">Cuenca<br><span style="font-weight:400; color:#78909c;">Mm³</span></th>';
        thead += '<th style="color:#66bb6a; text-align:right; font-size:10px;">Aguas↑<br><span style="font-weight:400; color:#78909c;">Mm³</span></th>';
        thead += '<th style="color:#ff7043; text-align:right; font-size:10px;">m³/s</th>';
        thead += '<th style="color:#ff7043; text-align:right; font-size:10px;">Mm³</th>';
        thead += '</tr>';
        $('#hydroTableHead').html(thead);

        // Body
        var hourly = dam.hourly;
        var tbody = '';
        var prevStorage = dam.initialStorage;
        var accumRain = 0, accumBasin = 0, accumUpstream = 0, accumExtraction = 0;

        for (var h = 0; h < hourly.length; h++) {
            var pt = hourly[h];
            var diff = pt.storage - prevStorage;
            var extractionQms = pt.extraction * 1e6 / 3600; // Mm³/h → m³/s
            accumRain += pt.rain;
            accumBasin += pt.basinInput;
            accumUpstream += pt.upstreamInput;
            accumExtraction += pt.extraction;

            if (h % interval === (interval - 1) || h === hourly.length - 1 || h === 0) {
                var elevDelta = pt.elev - dam.initialElev;
                var elevColor = elevDelta >= 0 ? '#ff7043' : '#66bb6a';

                tbody += '<tr style="border-bottom:1px solid rgba(55,71,79,0.3);' + (h === hourly.length - 1 ? ' background:rgba(33,150,243,0.06); font-weight:600;' : '') + '">';
                tbody += '<td style="color:#b0bec5; position:sticky; left:0; background:#131c24; z-index:1; white-space:nowrap; font-size:11px;">' + pt.time.substring(5, 16).replace('T', ' ') + ' <span style="color:#546e7a; font-size:9px;">+' + pt.hour + 'h</span></td>';
                tbody += '<td style="text-align:right; color:#e8f5e9;">' + pt.elev.toFixed(2) + ' <small style="color:' + elevColor + ';">(' + (elevDelta >= 0 ? '+' : '') + elevDelta.toFixed(2) + ')</small></td>';
                tbody += '<td style="text-align:right; color:#b0bec5;">' + pt.storage.toFixed(2) + '</td>';
                tbody += '<td style="text-align:right; color:' + (diff >= 0 ? '#66bb6a' : '#ff7043') + ';">' + (diff >= 0 ? '+' : '') + diff.toFixed(3) + '</td>';
                tbody += '<td style="text-align:right; color:#a5d6a7;">' + pt.basinInput.toFixed(4) + '</td>';
                tbody += '<td style="text-align:right; color:#81c784;">' + pt.upstreamInput.toFixed(4) + '</td>';
                tbody += '<td style="text-align:right; color:#ffab91;">' + extractionQms.toFixed(1) + '</td>';
                tbody += '<td style="text-align:right; color:#ff8a65;">' + pt.extraction.toFixed(4) + '</td>';
                tbody += '<td style="text-align:right; color:#90caf9;">' + pt.rain.toFixed(1) + '</td>';
                tbody += '</tr>';
            }
            prevStorage = pt.storage;
        }

        // Fila de totales/resumen
        var totalExtQms = accumExtraction > 0 ? (accumExtraction / hourly.length) * 1e6 / 3600 : 0;
        tbody += '<tr style="background:rgba(255,152,0,0.08); font-weight:700; border-top:2px solid #ff7043;">';
        tbody += '<td style="color:#ffab40; position:sticky; left:0; background:#131c24; z-index:1;"><i class="chart line icon"></i> RESUMEN</td>';
        tbody += '<td style="text-align:right; color:#e8f5e9;">' + dam.finalElev.toFixed(2) + '</td>';
        tbody += '<td style="text-align:right; color:#b0bec5;">' + dam.finalStorage.toFixed(2) + '</td>';
        var totalDiff = dam.finalStorage - dam.initialStorage;
        tbody += '<td style="text-align:right; color:' + (totalDiff >= 0 ? '#66bb6a' : '#ff7043') + ';">' + (totalDiff >= 0 ? '+' : '') + totalDiff.toFixed(2) + '</td>';
        tbody += '<td style="text-align:right; color:#a5d6a7;">' + accumBasin.toFixed(2) + '</td>';
        tbody += '<td style="text-align:right; color:#81c784;">' + accumUpstream.toFixed(2) + '</td>';
        tbody += '<td style="text-align:right; color:#ffab91;">' + totalExtQms.toFixed(1) + '</td>';
        tbody += '<td style="text-align:right; color:#ff8a65;">' + accumExtraction.toFixed(2) + '</td>';
        tbody += '<td style="text-align:right; color:#90caf9;">' + accumRain.toFixed(1) + '</td>';
        tbody += '</tr>';

        $('#hydroTableBody').html(tbody);
    }

    // ══════════════════════════════════════════════════════
    // SECCIÓN: TENDENCIA — DATOS REALES + PRONÓSTICO
    // ══════════════════════════════════════════════════════

    var trendColors = {
        'Angostura': '#00e676', 'Chicoasen': '#42a5f5', 'Malpaso': '#ffab40',
        'JGrijalva': '#ab47bc', 'Penitas': '#ef5350'
    };

    var trendLoaded = false;

    // Autoload cuando se activa el tab
    $(document).on('click', '.presa-tab[data-presa="tendencia"]', function() {
        if (!trendLoaded) loadTrendData();
    });

    $('#btnLoadTrend').on('click', function() { loadTrendData(); });

    function loadTrendData() {
        var realDays = parseInt($('#trendRealDays').val()) || 5;
        var forecastHours = parseInt($('#trendForecastHours').val()) || 72;
        var $btn = $('#btnLoadTrend');
        $btn.addClass('loading disabled');
        $('#trendStatus').html('<i class="spinner loading icon"></i> Calculando...').css('color', '#78909c');

        $.getJSON('@Url.Action("GetTrendData", "HydroForecast")', { realDays: realDays, forecastHours: forecastHours }, function(res) {
            $btn.removeClass('loading disabled');
            if (!res.success) {
                $('#trendStatus').text('Error: ' + res.message).css('color', '#ff5252');
                return;
            }
            trendLoaded = true;
            var fcDate = res.forecastDate || 'N/D';
            $('#trendInfo').html(
                '<i class="info circle icon" style="color:#00bcd4;"></i> ' +
                '<span style="color:#78909c;">Datos reales: <strong style="color:#e8f5e9;">' + res.realDays + ' días</strong></span> · ' +
                '<span style="color:#78909c;">Pronóstico: <strong style="color:#e8f5e9;">' + res.forecastHours + 'h</strong></span> · ' +
                '<span style="color:#78909c;">Fecha pronóstico: <strong style="color:#81c784;">' + fcDate + '</strong></span> · ' +
                '<span style="color:#78909c;">Generado: <strong style="color:#b0bec5;">' + res.generatedAt + '</strong></span>'
            );
            $('#trendStatus').html('<i class="check circle icon" style="color:#00e676;"></i> Listo').css('color', '#a5d6a7');
            renderTrendCharts(res);
        }).fail(function() {
            $btn.removeClass('loading disabled');
            $('#trendStatus').text('Error de conexión').css('color', '#ff5252');
        });
    }

    function renderTrendCharts(res) {
        var container = $('#trendChartsContainer');
        container.empty();

        if (!res.dams || !res.dams.length) {
            container.html('<div style="text-align:center; padding:40px; color:#546e7a;">Sin datos disponibles</div>');
            return;
        }

        res.dams.forEach(function(dam) {
            var chartId = 'trend-chart-' + dam.damName;
            var color = trendColors[dam.damName] || '#00e676';

            container.append(
                '<div class="chart-card" style="margin-bottom:16px; position:relative;">' +
                '  <div id="' + chartId + '" style="height:400px;"></div>' +
                '</div>'
            );

            // Separar series reales y pronóstico
            var realPts = dam.series.filter(function(s) { return !s.isForecast; });
            var fcPts = dam.series.filter(function(s) { return s.isForecast; });

            // Datos para Highcharts (timestamps)
            var realElev = realPts.map(function(s) { return [new Date(s.time).getTime(), s.elevation]; }).filter(function(p) { return p[1] != null; });
            var realAport = realPts.map(function(s) { return [new Date(s.time).getTime(), s.aportacionQ]; }).filter(function(p) { return p[1] != null; });
            var realExtrac = realPts.map(function(s) { return [new Date(s.time).getTime(), s.extractionQ]; }).filter(function(p) { return p[1] != null; });

            // Para el pronóstico, incluir el último punto real como enlace
            var lastReal = realElev.length > 0 ? realElev[realElev.length - 1] : null;
            var fcElev = fcPts.map(function(s) { return [new Date(s.time).getTime(), s.elevation]; });
            var fcAport = fcPts.map(function(s) { return [new Date(s.time).getTime(), s.aportacionQ]; });
            var fcExtrac = fcPts.map(function(s) { return [new Date(s.time).getTime(), s.extractionQ]; });

            // Conectar con el último punto real
            if (lastReal) fcElev.unshift(lastReal);
            if (realAport.length > 0) fcAport.unshift(realAport[realAport.length - 1]);
            if (realExtrac.length > 0) fcExtrac.unshift(realExtrac[realExtrac.length - 1]);

            // Zona vertical donde inicia el pronóstico
            var forecastStartTime = fcPts.length > 0 ? new Date(fcPts[0].time).getTime() : null;

            // Plotlines NAMO / NAME + ASÍNTOTA
            var plotLines = [];
            if (dam.namo) plotLines.push({ value: dam.namo, color: '#ffeb3b', width: 2, dashStyle: 'Dash', label: { text: 'NAMO ' + dam.namo.toFixed(1), style: { color: '#ffeb3b', fontSize: '10px', fontWeight: '600' }, align: 'right' }, zIndex: 5 });
            if (dam.name_e) plotLines.push({ value: dam.name_e, color: '#ff5252', width: 2, dashStyle: 'Dash', label: { text: 'NAME ' + dam.name_e.toFixed(1), style: { color: '#ff5252', fontSize: '10px', fontWeight: '600' }, align: 'right' }, zIndex: 5 });
            // Asíntota: nivel al que tiende el embalse (último valor del pronóstico)
            if (dam.finalElev) plotLines.push({ value: dam.finalElev, color: '#ce93d8', width: 2, dashStyle: 'LongDashDot', label: { text: 'Asíntota ' + dam.finalElev.toFixed(2), style: { color: '#ce93d8', fontSize: '10px', fontWeight: '600' }, align: 'left' }, zIndex: 5 });

            // Plot bands: zona pronóstico
            var plotBands = [];
            if (forecastStartTime) {
                plotBands.push({
                    from: forecastStartTime, to: Infinity,
                    color: 'rgba(0,188,212,0.04)',
                    label: { text: 'PRONÓSTICO', style: { color: 'rgba(0,188,212,0.4)', fontSize: '11px', fontWeight: '600' }, align: 'left', verticalAlign: 'top', y: 10 }
                });
            }

            // Delta texto
            var arrow = dam.deltaElev >= 0 ? '▲' : '▼';
            var deltaColor = dam.deltaElev >= 0 ? '#ff7043' : '#66bb6a';

            // Current theme
            var isLight = document.body.classList.contains('fv-light');
            var bgColor = isLight ? '#ffffff' : '#0f1923';
            var textColor = isLight ? '#555' : '#78909c';
            var gridColor = isLight ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)';
            var tooltipBg = isLight ? 'rgba(255,255,255,0.96)' : 'rgba(15,25,30,0.95)';
            var tooltipText = isLight ? '#333' : '#e8f5e9';
            var legendColor = isLight ? '#333' : '#b0bec5';
            var subtitleColor = isLight ? (dam.deltaElev >= 0 ? '#d84315' : '#2e7d32') : deltaColor;

            Highcharts.chart(chartId, {
                chart: { backgroundColor: bgColor, height: 420, zoomType: 'x' },
                title: {
                    text: dam.displayName + ' — Comportamiento del Embalse',
                    style: { color: color, fontSize: '16px', fontWeight: '700' }
                },
                subtitle: {
                    text: 'Actual: ' + dam.initialElev.toFixed(2) + ' msnm → ' + arrow + ' ' + (dam.deltaElev >= 0 ? '+' : '') + dam.deltaElev.toFixed(2) + ' m → Asíntota: ' + dam.finalElev.toFixed(2) + ' msnm',
                    style: { color: subtitleColor, fontSize: '12px', fontWeight: '600' }
                },
                exporting: { enabled: true, buttons: { contextButton: { theme: { fill: bgColor } } } },
                time: { useUTC: false },
                xAxis: {
                    type: 'datetime',
                    labels: { style: { color: textColor, fontSize: '10px' }, format: '{value:%d/%m %H:%M}' },
                    gridLineColor: gridColor,
                    plotBands: plotBands
                },
                yAxis: [{
                    title: { text: 'Nivel (msnm)', style: { color: textColor } },
                    labels: { style: { color: textColor } },
                    gridLineColor: gridColor,
                    plotLines: plotLines
                }, {
                    title: { text: 'Gasto (m³/s)', style: { color: textColor } },
                    labels: { style: { color: textColor } },
                    opposite: true,
                    gridLineColor: isLight ? 'rgba(0,0,0,0.03)' : 'rgba(255,255,255,0.03)',
                    min: 0
                }],
                legend: { itemStyle: { color: legendColor, fontSize: '11px' }, backgroundColor: 'transparent' },
                credits: { enabled: false },
                tooltip: {
                    shared: true, crosshairs: true,
                    backgroundColor: tooltipBg, borderColor: color,
                    style: { color: tooltipText },
                    xDateFormat: '%d/%m/%Y %H:%M'
                },
                plotOptions: {
                    series: { animation: { duration: 800 } },
                    column: { borderRadius: 1, borderWidth: 0, groupPadding: 0.1, pointPadding: 0.05 }
                },
                series: [
                    // — Nivel Real —
                    {
                        name: 'Nivel Real', type: 'areaspline', data: realElev, color: color,
                        fillColor: { linearGradient: { x1: 0, y1: 0, x2: 0, y2: 1 },
                            stops: [[0, Highcharts.color(color).setOpacity(0.25).get()], [1, Highcharts.color(color).setOpacity(0.02).get()]] },
                        lineWidth: 2.5, marker: { enabled: false }, yAxis: 0, zIndex: 3
                    },
                    // — Nivel Pronóstico —
                    {
                        name: 'Nivel Pronóstico', type: 'areaspline', data: fcElev, color: color,
                        fillColor: { linearGradient: { x1: 0, y1: 0, x2: 0, y2: 1 },
                            stops: [[0, Highcharts.color(color).setOpacity(0.12).get()], [1, Highcharts.color(color).setOpacity(0.01).get()]] },
                        lineWidth: 2, dashStyle: 'ShortDash', marker: { enabled: false }, yAxis: 0, zIndex: 2
                    },
                    // — Asíntota (línea horizontal al nivel final pronosticado) —
                    {
                        name: 'Asíntota (' + dam.finalElev.toFixed(2) + ' msnm)', type: 'line',
                        data: (function() {
                            var allTimes = realElev.concat(fcElev);
                            if (allTimes.length < 2) return [];
                            return [[allTimes[0][0], dam.finalElev], [allTimes[allTimes.length - 1][0], dam.finalElev]];
                        })(),
                        color: '#ce93d8', lineWidth: 2, dashStyle: 'LongDashDot',
                        marker: { enabled: false }, enableMouseTracking: true,
                        yAxis: 0, zIndex: 4
                    },
                    // — Aportaciones Real (columna) —
                    {
                        name: 'Aportación Real (m³/s)', type: 'column', data: realAport, color: '#2196F3',
                        yAxis: 1, zIndex: 1, opacity: 0.7
                    },
                    // — Aportaciones Pronóstico (columna punteada) —
                    {
                        name: 'Aportación Pronóstico', type: 'column', data: fcAport,
                        color: Highcharts.color('#2196F3').setOpacity(0.4).get(),
                        borderColor: '#2196F3', borderWidth: 1,
                        yAxis: 1, zIndex: 1
                    },
                    // — Extracciones Real (columna) —
                    {
                        name: 'Extracción Real (m³/s)', type: 'column', data: realExtrac, color: '#FF5722',
                        yAxis: 1, zIndex: 1, opacity: 0.7
                    },
                    // — Extracciones Pronóstico (columna punteada) —
                    {
                        name: 'Extracción Pronóstico', type: 'column', data: fcExtrac,
                        color: Highcharts.color('#FF5722').setOpacity(0.4).get(),
                        borderColor: '#FF5722', borderWidth: 1,
                        yAxis: 1, zIndex: 1
                    }
                ]
            });
        });
    }

    // ══════════════════════════════════════════════════════
    // SECCIÓN: CONFIGURACIÓN DE EMBALSES (NAMO/NAME/NAMINO)
    // ══════════════════════════════════════════════════════

    window.openEmbalseConfigModal = function() {
        loadEmbalseConfigTable();
        $('#embalseConfigModal').modal({ closable: false }).modal('show');
    };

    window.closeEmbalseConfigModal = function() {
        $('#embalseConfigModal').modal('hide');
        loadEmbalseConfig(); // refresh the in-memory config
        reRenderCurrentPresa();
    };

    function loadEmbalseConfigTable() {
        $.getJSON('/FunVasos/GetEmbalseConfigAll', function(resp) {
            if (!resp.success) return;
            var html = '';
            resp.data.forEach(function(cfg) {
                html += buildEmbalseRow(cfg, false);
            });
            $('#embalseConfigBody').html(html);
        });
    }

    function buildEmbalseRow(cfg, isNew) {
        var activeIcon = cfg.isActive ? 'toggle on' : 'toggle off';
        var activeColor = cfg.isActive ? '#00e676' : '#546e7a';
        var rowOpacity = cfg.isActive ? '1' : '0.5';
        var rid = isNew ? 'new_' + Date.now() : cfg.id;
        var v = function(x) { return x != null ? x : ''; };

        return '<tr style="opacity:' + rowOpacity + ';" id="ecRow_' + rid + '">'
            // Identificación
            + '<td>' + (isNew
                ? '<input type="text" value="" placeholder="Nombre" class="ec-input ec-input-lg" id="ecDisplay_' + rid + '">'
                : '<span style="color:#e8f5e9; font-weight:600;"><i class="tint icon" style="color:' + (cfg.color || '#42a5f5') + ';"></i> ' + cfg.nombreDisplay + '</span>')
            + '</td>'
            + '<td>' + (isNew
                ? '<input type="text" value="" placeholder="clave" class="ec-input ec-input-md" id="ecPKey_' + rid + '">'
                : '<small style="color:#546e7a;">' + cfg.presaKey + '</small>')
            + '</td>'
            + '<td style="border-right:1px solid #1e3a5f;">'
            + '<input type="color" value="' + (cfg.color || '#00e676') + '" class="ec-input ec-color" id="ecColor_' + rid + '">'
            + '</td>'
            // Niveles
            + '<td style="text-align:center;"><input type="number" step="0.01" value="' + v(cfg.namo) + '" class="ec-input ec-input-md" id="ecNamo_' + rid + '"></td>'
            + '<td style="text-align:center;"><input type="number" step="0.01" value="' + v(cfg.name) + '" class="ec-input ec-input-md" id="ecName_' + rid + '"></td>'
            + '<td style="text-align:center; border-right:1px solid #1e3a5f;"><input type="number" step="0.01" value="' + v(cfg.namino) + '" class="ec-input ec-input-md" id="ecNamino_' + rid + '"></td>'
            // Claves
            + '<td style="text-align:center;"><input type="text" value="' + v(cfg.hydroKey) + '" class="ec-input ec-input-md" id="ecHydro_' + rid + '"></td>'
            + '<td style="text-align:center;"><input type="text" value="' + v(cfg.cuencaCode) + '" class="ec-input ec-input-sm" id="ecCuenca_' + rid + '"></td>'
            + '<td style="text-align:center; border-right:1px solid #1e3a5f;"><input type="text" value="' + v(cfg.bhgKey) + '" class="ec-input ec-input-lg" id="ecBhg_' + rid + '"></td>'
            // Excel
            + '<td style="text-align:center;"><input type="number" value="' + v(cfg.excelHeaderRow) + '" class="ec-input ec-input-sm" id="ecExHdr_' + rid + '"></td>'
            + '<td style="text-align:center;"><input type="number" value="' + v(cfg.excelDataStartRow) + '" class="ec-input ec-input-sm" id="ecExStart_' + rid + '"></td>'
            + '<td style="text-align:center; border-right:1px solid #1e3a5f;"><input type="number" value="' + v(cfg.excelDataEndRow) + '" class="ec-input ec-input-sm" id="ecExEnd_' + rid + '"></td>'
            // Tipo
            + '<td style="text-align:center;"><input type="checkbox" class="ec-check" id="ecTapon_' + rid + '"' + (cfg.isTaponType ? ' checked' : '') + '></td>'
            + '<td style="text-align:center; border-right:1px solid #1e3a5f;"><input type="number" value="' + v(cfg.totalUnits) + '" class="ec-input ec-input-sm" id="ecUnits_' + rid + '"></td>'
            // Estado
            + '<td style="text-align:center;">'
            + (isNew
                ? '<input type="checkbox" class="ec-check" id="ecActive_' + rid + '" checked>'
                : '<i class="' + activeIcon + ' icon" style="color:' + activeColor + '; font-size:20px; cursor:pointer;" '
                  + 'onclick="toggleEmbalseActive(' + cfg.id + ', ' + (!cfg.isActive).toString() + ')"></i>')
            + '</td>'
            + '<td style="text-align:center;">'
            + '<button class="ui tiny green button" style="padding:5px 10px;" '
            + 'onclick="saveEmbalseRow(\'' + rid + '\', ' + (isNew ? 'true' : 'false') + ')">'
            + '<i class="save icon"></i></button>'
            + (isNew ? ' <button class="ui tiny red button" style="padding:5px 10px;" onclick="$(\'#ecRow_' + rid + '\').remove();"><i class="trash icon"></i></button>' : '')
            + '</td>'
            + '</tr>';
    }

    window.addNewEmbalseRow = function() {
        var empty = { id: 0, presaKey: '', nombreDisplay: '', namo: null, name: null, namino: null,
            isActive: true, sortOrder: 99, color: '#00e676', hydroKey: '', cuencaCode: '', bhgKey: '',
            excelHeaderRow: null, excelDataStartRow: null, excelDataEndRow: null,
            isTaponType: false, totalUnits: 0 };
        $('#embalseConfigBody').append(buildEmbalseRow(empty, true));
    };

    window.saveEmbalseRow = function(rid, isNew) {
        var id = isNew ? 0 : parseInt(rid);
        var presaKey = isNew ? ($('#ecPKey_' + rid).val() || '').trim() : null;
        var nombreDisplay = isNew ? ($('#ecDisplay_' + rid).val() || '').trim() : null;

        if (isNew && (!presaKey || !nombreDisplay)) {
            alert('Presa Key y Nombre son requeridos para un nuevo embalse.');
            return;
        }

        // For existing rows, we need the original presaKey and nombreDisplay
        if (!isNew) {
            var $row = $('#ecRow_' + rid);
            presaKey = $row.find('small').first().text().trim();
            nombreDisplay = $row.find('span').first().text().trim();
        }

        var data = {
            id: id,
            presaKey: presaKey,
            nombreDisplay: nombreDisplay,
            namo: parseFloat($('#ecNamo_' + rid).val()) || null,
            name: parseFloat($('#ecName_' + rid).val()) || null,
            namino: parseFloat($('#ecNamino_' + rid).val()) || null,
            isActive: isNew ? $('#ecActive_' + rid).is(':checked') : null,
            sortOrder: 99,
            color: $('#ecColor_' + rid).val() || '#00e676',
            hydroKey: $('#ecHydro_' + rid).val() || null,
            cuencaCode: $('#ecCuenca_' + rid).val() || null,
            bhgKey: $('#ecBhg_' + rid).val() || null,
            excelHeaderRow: parseInt($('#ecExHdr_' + rid).val()) || null,
            excelDataStartRow: parseInt($('#ecExStart_' + rid).val()) || null,
            excelDataEndRow: parseInt($('#ecExEnd_' + rid).val()) || null,
            isTaponType: $('#ecTapon_' + rid).is(':checked'),
            totalUnits: parseInt($('#ecUnits_' + rid).val()) || 0
        };

        // For existing rows, get the current isActive state
        if (!isNew) {
            var $toggle = $('#ecRow_' + rid).find('.toggle.icon');
            data.isActive = $toggle.hasClass('toggle on');
        }

        $.ajax({
            url: '/FunVasos/SaveEmbalseConfig',
            type: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': _antiForgeryToken },
            data: JSON.stringify(data),
            success: function(r) {
                if (r.success) {
                    if (isNew) {
                        // Reload entire table to get proper row with correct ID
                        loadEmbalseConfigTable();
                    } else {
                        var $row = $('#ecRow_' + rid);
                        // Update the tint icon color
                        $row.find('.tint.icon').css('color', data.color);
                        $row.css('background', 'rgba(0,230,118,0.15)');
                        setTimeout(function() { $row.css('background', ''); }, 1200);
                    }
                } else {
                    alert('Error: ' + r.message);
                }
            }
        });
    };

    window.toggleEmbalseActive = function(id, newState) {
        $.ajax({
            url: '/FunVasos/ToggleEmbalse',
            type: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': _antiForgeryToken },
            data: JSON.stringify({ id: id, isActive: newState }),
            success: function(r) {
                if (r.success) loadEmbalseConfigTable();
                else alert('Error: ' + r.message);
            }
        });
    };

});
</script>
}

