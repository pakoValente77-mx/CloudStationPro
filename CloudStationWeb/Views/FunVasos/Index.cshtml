@model CloudStationWeb.Models.FunVasosViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Funcionamiento de Vasos";
}
@functions {
    string SafeId(string name)
    {
        if (string.IsNullOrEmpty(name)) return name;
        var normalized = name.Normalize(System.Text.NormalizationForm.FormD);
        var sb = new System.Text.StringBuilder();
        foreach (var c in normalized)
        {
            var uc = CharUnicodeCategory(c);
            if (uc != UnicodeCategory.NonSpacingMark)
                sb.Append(c);
        }
        return sb.ToString().Normalize(System.Text.NormalizationForm.FormC).Replace(" ", "_");
    }
    static UnicodeCategory CharUnicodeCategory(char c) => char.GetUnicodeCategory(c);
}

@section Styles {
<style>
    .fv-container {
        padding: 15px;
        max-width: 100%;
    }

    .compact-header {
        background: rgba(15, 25, 30, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 15px;
        border: 1px solid rgba(0, 230, 118, 0.2);
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5), inset 0 0 10px rgba(0, 230, 118, 0.05);
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        position: relative;
        z-index: 1000 !important;
    }

    .header-title {
        font-size: 18px;
        font-weight: 800;
        color: #e8f5e9;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-right: 15px;
        text-shadow: 0 0 10px rgba(0, 230, 118, 0.5);
    }

    .header-title i { color: #00e676; }

    /* Tabs for presas */
    .presa-tabs {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 12px;
    }

    .presa-tab {
        padding: 8px 18px;
        border-radius: 8px;
        border: 1px solid rgba(0, 230, 118, 0.3);
        background: rgba(15, 25, 30, 0.7);
        color: #b0bec5;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.3s ease;
    }

    .presa-tab:hover { background: rgba(0, 230, 118, 0.15); color: #e8f5e9; }
    .presa-tab.active {
        background: linear-gradient(135deg, rgba(0, 230, 118, 0.3), rgba(0, 176, 255, 0.3));
        color: #fff;
        border-color: #00e676;
        box-shadow: 0 0 12px rgba(0, 230, 118, 0.3);
    }

    /* Summary cards */
    .summary-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-bottom: 15px;
    }

    .summary-card {
        background: rgba(15, 25, 30, 0.8);
        backdrop-filter: blur(8px);
        border-radius: 10px;
        padding: 14px;
        border: 1px solid rgba(255,255,255,0.08);
        text-align: center;
    }

    .summary-card .label { color: #78909c; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
    .summary-card .value { color: #e8f5e9; font-size: 22px; font-weight: 700; }
    .summary-card .unit { color: #546e7a; font-size: 11px; margin-top: 2px; }

    .summary-card.elev .value { color: #00e676; }
    .summary-card.almac .value { color: #00b0ff; }
    .summary-card.aport .value { color: #ffab40; }
    .summary-card.extrac .value { color: #ff5252; }
    .summary-card.gen .value { color: #e040fb; }

    /* Table section */
    .fv-table-wrapper {
        background: rgba(15, 25, 30, 0.8);
        backdrop-filter: blur(8px);
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.08);
        overflow-x: auto;
        overflow-y: auto;
        max-height: 600px;
        margin-bottom: 15px;
    }

    .fv-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .fv-table thead th {
        background: #0d1f1a;
        color: #b0bec5;
        padding: 8px 10px;
        text-align: center;
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        position: sticky;
        top: 0;
        z-index: 2;
        border-bottom: 1px solid rgba(0, 230, 118, 0.2);
        white-space: nowrap;
    }

    .fv-table thead tr.subheader th {
        background: #0b1916;
        font-size: 10px;
        color: #78909c;
        padding: 4px 10px;
        position: sticky;
        top: 36px;
        z-index: 2;
    }

    .fv-table tbody td {
        padding: 6px 10px;
        text-align: center;
        color: #cfd8dc;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        white-space: nowrap;
    }

    .fv-table tbody tr:hover { background: rgba(0, 230, 118, 0.06); }

    .fv-table .hora-col { color: #00e676; font-weight: 700; }

    /* Charts */
    .charts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
        gap: 12px;
        margin-bottom: 15px;
    }

    .chart-card {
        background: rgba(15, 25, 30, 0.8);
        backdrop-filter: blur(8px);
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.08);
        padding: 14px;
    }

    .chart-card .chart-title {
        color: #e8f5e9;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-ref-config {
        margin-left: auto;
        background: rgba(0, 230, 118, 0.1);
        border: 1px solid rgba(0, 230, 118, 0.25);
        color: #00e676;
        border-radius: 5px;
        padding: 3px 8px;
        cursor: pointer;
        font-size: 11px;
        font-weight: 600;
        text-transform: none;
        letter-spacing: 0;
        transition: all 0.2s;
    }
    .btn-ref-config:hover { background: rgba(0, 230, 118, 0.25); color: #fff; }

    .ec-input {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.15);
        color: #e8f5e9;
        padding: 5px 8px;
        border-radius: 4px;
        font-size: 12px;
        text-align: center;
    }
    .ec-input:focus { border-color: #42a5f5; outline: none; }

    .nivel-toggle-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid;
        user-select: none;
    }
    .nivel-toggle-chip.active { opacity: 1; }
    .nivel-toggle-chip:not(.active) { opacity: 0.35; }
    .nivel-toggle-chip .nivel-val { font-weight: 400; font-size: 11px; opacity: 0.8; }

    /* Combined chart (Comportamiento del Embalse) */
    .combo-chart-card {
        background: rgba(15, 25, 30, 0.85);
        backdrop-filter: blur(12px);
        border-radius: 12px;
        border: 1px solid rgba(0, 230, 118, 0.15);
        padding: 16px;
        margin-bottom: 15px;
        position: relative;
    }

    .combo-chart-card .combo-title {
        color: #e8f5e9;
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        text-align: center;
        margin-bottom: 10px;
    }

    .combo-chart-card .btn-maximize,
    .chart-card .btn-maximize {
        background: rgba(0, 230, 118, 0.12);
        border: 1px solid rgba(0, 230, 118, 0.3);
        color: #00e676;
        border-radius: 6px;
        padding: 5px 10px;
        cursor: pointer;
        font-size: 12px;
        transition: all 0.2s;
        z-index: 2;
    }
    .combo-chart-card .btn-maximize {
        position: absolute;
        top: 12px;
        right: 14px;
    }
    .combo-chart-card .btn-maximize:hover,
    .chart-card .btn-maximize:hover {
        background: rgba(0, 230, 118, 0.25);
        color: #fff;
    }

    .btn-action-sm {
        background: rgba(0, 230, 118, 0.12);
        border: 1px solid rgba(0, 230, 118, 0.3);
        color: #00e676;
        border-radius: 6px;
        padding: 4px 9px;
        cursor: pointer;
        font-size: 11px;
        transition: all 0.2s;
        white-space: nowrap;
    }
    .btn-action-sm:hover {
        background: rgba(0, 230, 118, 0.25);
        color: #fff;
    }
    .btn-action-sm.btn-export {
        background: rgba(33, 150, 243, 0.12);
        border-color: rgba(33, 150, 243, 0.3);
        color: #2196F3;
    }
    .btn-action-sm.btn-export:hover {
        background: rgba(33, 150, 243, 0.25);
        color: #fff;
    }

    /* Fullscreen modal overlay */
    .chart-fullscreen-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(5, 10, 15, 0.96);
        z-index: 10000;
        padding: 20px;
        overflow: auto;
    }
    .chart-fullscreen-overlay.active { display: flex; flex-direction: column; }
    .chart-fullscreen-overlay .fs-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }
    .chart-fullscreen-overlay .fs-title {
        color: #00e676;
        font-size: 16px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .chart-fullscreen-overlay .btn-close-fs {
        background: rgba(239, 83, 80, 0.15);
        border: 1px solid rgba(239, 83, 80, 0.4);
        color: #ef5350;
        border-radius: 6px;
        padding: 6px 14px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
    }
    .chart-fullscreen-overlay .btn-close-fs:hover { background: rgba(239, 83, 80, 0.35); color: #fff; }
    .chart-fullscreen-overlay .fs-chart-container {
        flex: 1;
        min-height: 0;
    }

    .no-data-msg {
        text-align: center;
        color: #78909c;
        padding: 60px 20px;
        font-size: 16px;
    }

    .no-data-msg i { font-size: 48px; display: block; margin-bottom: 15px; color: #455a64; }

    /* Tab "Todas" view */
    .all-presas-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 15px;
    }

    .presa-section-title {
        font-size: 15px;
        font-weight: 800;
        color: #00e676;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 10px 14px;
        background: rgba(0, 230, 118, 0.08);
        border-radius: 8px 8px 0 0;
        border-bottom: 2px solid rgba(0, 230, 118, 0.3);
    }

    /* Cascade 3D */
    #cascade3d-wrapper {
        width: 100%;
        height: calc(100vh - 200px);
        min-height: 550px;
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        background: #040c14;
        border: 1px solid rgba(0,230,118,0.15);
        box-shadow: 0 8px 32px rgba(0,0,0,0.6), inset 0 0 20px rgba(0,230,118,0.03);
    }
    #cascade3d-wrapper:fullscreen,
    #cascade3d-wrapper:-webkit-full-screen {
        border-radius: 0;
        border: none;
        height: 100vh;
    }
    #cascade3d-canvas {
        display: block;
        width: 100%;
        height: 100%;
    }
    .c3d-overlay-info {
        position: absolute;
        top: 12px;
        left: 14px;
        z-index: 10;
        background: rgba(4,12,20,0.75);
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid rgba(0,230,118,0.25);
        backdrop-filter: blur(8px);
    }
    .c3d-overlay-info span {
        color: #00e676;
        font-size: 13px;
        font-weight: 600;
    }
    .c3d-controls {
        position: absolute;
        top: 12px;
        right: 14px;
        z-index: 10;
        display: flex;
        gap: 10px;
        align-items: center;
        background: rgba(4,12,20,0.75);
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid rgba(0,230,118,0.25);
        backdrop-filter: blur(8px);
    }
    .c3d-controls .button { transition: all 0.2s ease; min-width: auto; }
    .c3d-controls .button.disabled { pointer-events: none; }
    .c3d-hint {
        position: absolute;
        bottom: 64px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        color: rgba(255,255,255,0.3);
        font-size: 11px;
        pointer-events: none;
        transition: opacity 3s;
    }

    /* Bottom Data Banner */
    .c3d-bottom-banner {
        position: absolute;
        bottom: 28px;
        left: 0;
        right: 0;
        z-index: 12;
        display: flex;
        gap: 0;
        background: rgba(4, 12, 20, 0.88);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-top: 1px solid rgba(0, 230, 118, 0.25);
        padding: 1px 8px;
        overflow-x: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(0,230,118,0.3) transparent;
    }
    .c3d-bottom-banner::-webkit-scrollbar { height: 3px; }
    .c3d-bottom-banner::-webkit-scrollbar-thumb { background: rgba(0,230,118,0.3); border-radius: 2px; }
    .c3d-banner-item {
        flex: 1;
        min-width: 130px;
        padding: 4px 10px;
        border-right: 1px solid rgba(255,255,255,0.08);
    }
    .c3d-banner-item:last-child { border-right: none; }
    .c3d-banner-name {
        font-size: 11px;
        font-weight: 800;
        color: #00e676;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 2px;
        white-space: nowrap;
    }
    .c3d-banner-row {
        display: flex;
        gap: 4px;
        align-items: baseline;
        line-height: 1.3;
    }
    .c3d-banner-label {
        font-size: 10px;
        color: rgba(255,255,255,0.4);
        white-space: nowrap;
    }
    .c3d-banner-val {
        font-size: 11px;
        color: #e8f5e9;
        font-weight: 600;
        white-space: nowrap;
    }
    .c3d-banner-val small { font-size: 9px; color: rgba(255,255,255,0.35); }
    .c3d-banner-val.c3d-gen { color: #ffd54f; }
    .c3d-banner-label.c3d-no-gen { color: rgba(255,255,255,0.2); font-style: italic; }
    .c3d-banner-gulf { border-left: 1px solid rgba(79,195,247,0.3); }

    /* ===== THEME TOGGLE ===== */
    .theme-toggle-btn {
        background: rgba(0,230,118,0.1); border: 1px solid rgba(0,230,118,0.3); color: #00e676;
        border-radius: 8px; padding: 6px 14px; cursor: pointer; font-size: 12px; font-weight: 600;
        display: flex; align-items: center; gap: 6px; transition: all 0.3s; margin-left: auto;
    }
    .theme-toggle-btn:hover { background: rgba(0,230,118,0.2); color: #fff; }

    /* ===== LIGHT THEME ===== */
    body.fv-light .compact-header { background: rgba(255,255,255,0.95); border-color: rgba(33,150,243,0.3); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
    body.fv-light .header-title { color: #1a237e; text-shadow: none; }
    body.fv-light .header-title i { color: #1565c0; }
    body.fv-light .compact-header label { color: #555 !important; }
    body.fv-light .compact-header input[type="date"] { background: #f5f5f5 !important; border-color: rgba(0,0,0,0.15) !important; color: #333 !important; }
    body.fv-light .theme-toggle-btn { background: rgba(33,150,243,0.1); border-color: rgba(33,150,243,0.3); color: #1565c0; }
    body.fv-light .summary-card { background: rgba(255,255,255,0.95); border-color: rgba(0,0,0,0.1); }
    body.fv-light .summary-card .label { color: #666; }
    body.fv-light .summary-card .unit { color: #999; }
    body.fv-light .chart-card, body.fv-light .combo-chart-card { background: rgba(255,255,255,0.95); border-color: rgba(0,0,0,0.1); }
    body.fv-light .combo-chart-card .combo-title, body.fv-light .chart-card .chart-title { color: #333; }
    body.fv-light .fv-table-wrapper { background: rgba(255,255,255,0.95); border-color: rgba(0,0,0,0.1); }
    body.fv-light .fv-table thead th { background: #f5f5f5; color: #333; border-bottom-color: rgba(0,0,0,0.1); }
    body.fv-light .fv-table thead tr.subheader th { background: #fafafa; color: #666; }
    body.fv-light .fv-table tbody td { color: #444; border-bottom-color: rgba(0,0,0,0.06); }
    body.fv-light .fv-table tbody tr:hover { background: rgba(33,150,243,0.06); }
    body.fv-light .presa-tab { background: rgba(255,255,255,0.9); border-color: rgba(33,150,243,0.3); color: #555; }
    body.fv-light .presa-tab:hover { background: rgba(33,150,243,0.1); color: #333; }
    body.fv-light .presa-tab.active { background: linear-gradient(135deg,rgba(33,150,243,0.2),rgba(0,230,118,0.2)); color: #1a237e; border-color: #1565c0; }
    body.fv-light .presa-section-title { color: #1565c0; background: rgba(33,150,243,0.08); }
    body.fv-light .btn-action-sm { background: rgba(33,150,243,0.1); border-color: rgba(33,150,243,0.3); color: #1565c0; }
    body.fv-light .no-data-msg { color: #666; }
    body.fv-light .no-data-msg i { color: #999; }
    body.fv-light h3, body.fv-light h4 { color: #333 !important; }
</style>
}

<div class="fv-container">
    <!-- Header -->
    <div class="compact-header">
        <div class="header-title">
            <i class="water icon"></i> Funcionamiento de Vasos
        </div>

        <div style="display:flex; align-items:center; gap:10px;">
            <label style="color:#b0bec5; font-size:12px; font-weight:600;">Desde:</label>
            <input type="date" id="fechaInicio" value="@Model.FechaInicio.ToString("yyyy-MM-dd")"
                   style="background:rgba(0,0,0,0.3); border:1px solid rgba(0,230,118,0.3); color:#e8f5e9; padding:6px 12px; border-radius:6px; font-size:13px;" />
            <label style="color:#b0bec5; font-size:12px; font-weight:600;">Hasta:</label>
            <input type="date" id="fechaFin" value="@Model.FechaFin.ToString("yyyy-MM-dd")"
                   style="background:rgba(0,0,0,0.3); border:1px solid rgba(0,230,118,0.3); color:#e8f5e9; padding:6px 12px; border-radius:6px; font-size:13px;" />
            <button class="ui tiny inverted teal button" id="btnConsultar" style="margin-left:4px;">
                <i class="search icon"></i> Consultar
            </button>
        </div>
        <button class="theme-toggle-btn" id="btnFvThemeToggle">
            <i class="sun icon" id="fvThemeIcon"></i>
            <span id="fvThemeLabel">Tema Claro</span>
        </button>
    </div>

    @if (Model.Presas.Count == 0)
    {
        <div class="no-data-msg">
            <i class="database icon"></i>
            No hay datos disponibles para esta fecha.<br/>
            <span style="font-size:13px;">Suba un archivo de Funcionamiento de Vasos en el módulo <a href="/Documents" style="color:#00e676;">Repositorio</a>.</span>
        </div>
    }
    else
    {
        <!-- Presa Tabs -->
        <div class="presa-tabs">
            <div class="presa-tab active" data-presa="todas">Todas</div>
            @if (!User.IsInRole("SoloVasos"))
            {
            <div class="presa-tab" data-presa="cascada3d" style="background:linear-gradient(135deg,rgba(0,230,118,0.15),rgba(33,150,243,0.15)); border:1px solid rgba(0,230,118,0.3);"><i class="water icon"></i> Cascada 3D</div>
            <div class="presa-tab" data-presa="promapor" style="background:linear-gradient(135deg,rgba(255,171,64,0.15),rgba(233,30,99,0.15)); border:1px solid rgba(255,171,64,0.3);"><i class="chart line icon"></i> PromApor SHG</div>
            }
            <div class="presa-tab" data-presa="niveleshorarios" style="background:linear-gradient(135deg,rgba(76,175,80,0.15),rgba(255,235,59,0.15)); border:1px solid rgba(76,175,80,0.3);"><i class="table icon"></i> Niveles Horarios</div>
            @if (!User.IsInRole("SoloVasos"))
            {
            <div class="presa-tab" data-presa="hydrosim" style="background:linear-gradient(135deg,rgba(244,67,54,0.18),rgba(255,152,0,0.18)); border:1px solid rgba(244,67,54,0.4);"><i class="lightning icon"></i> Simulación Hidro</div>
            <div class="presa-tab" data-presa="tendencia" style="background:linear-gradient(135deg,rgba(0,188,212,0.18),rgba(156,39,176,0.18)); border:1px solid rgba(0,188,212,0.4);"><i class="chart area icon"></i> Tendencia</div>
            }
            @foreach (var p in Model.Presas)
            {
                <div class="presa-tab" data-presa="@SafeId(p.Presa)">@p.Presa</div>
            }
        </div>

        <!-- Tab: TODAS -->
        <div id="tab-todas" class="tab-content">
            @foreach (var p in Model.Presas)
            {
                <div style="margin-bottom:20px;">
                    <div class="presa-section-title">
                        <i class="tint icon"></i> @p.Presa
                        @if (p.UltimaHora > 0)
                        {
                            <span style="font-size:11px; color:#78909c; font-weight:400; margin-left:10px;">
                                Última hora: @p.UltimaHora:00
                            </span>
                        }
                    </div>

                    <!-- Summary for this presa -->
                    <div class="summary-cards" style="margin-top:8px;">
                        <div class="summary-card elev">
                            <div class="label">Elevación</div>
                            <div class="value">@(p.UltimaElevacion?.ToString("F2") ?? "—")</div>
                            <div class="unit">m.s.n.m</div>
                        </div>
                        <div class="summary-card almac">
                            <div class="label">Almacenamiento</div>
                            <div class="value">@(p.UltimoAlmacenamiento?.ToString("F2") ?? "—")</div>
                            <div class="unit">Mill. m³</div>
                        </div>
                        <div class="summary-card aport">
                            <div class="label">Aportaciones</div>
                            <div class="value">@(p.TotalAportacionesV?.ToString("F2") ?? "—")</div>
                            <div class="unit">Mill. m³</div>
                        </div>
                        <div class="summary-card extrac">
                            <div class="label">Extracciones</div>
                            <div class="value">@(p.TotalExtraccionesV?.ToString("F2") ?? "—")</div>
                            <div class="unit">Mill. m³</div>
                        </div>
                        @if (p.Presa != "Tapón Juan Grijalva")
                        {
                            <div class="summary-card gen">
                                <div class="label">Generación</div>
                                <div class="value">@(p.TotalGeneracion?.ToString("F1") ?? "—")</div>
                                <div class="unit">MWH total</div>
                            </div>
                        }
                    </div>

                    <!-- Table -->
                    @await Html.PartialAsync("_PresaTable", p)
                </div>
            }
        </div>

        <!-- Tab: CASCADA 3D -->
        <div id="tab-cascada3d" class="tab-content" style="display:none;">
            <div id="cascade3d-wrapper">
                <div class="c3d-controls">
                    <span style="color:#00e676; font-size:13px; font-weight:600;"><i class="water icon"></i> Sistema Hidroeléctrico Grijalva — Cascada en Tiempo Real</span>
                    <span id="c3dTimestamp" style="color:#4fc3f7; font-size:12px; letter-spacing:0.5px;"></span>
                    <button class="ui tiny inverted blue button" onclick="exportCascade3DImage()">
                        <i class="camera icon"></i> Exportar Imagen
                    </button>
                    <button class="ui tiny inverted teal button" onclick="toggle3DFullscreen()">
                        <i class="expand icon"></i> Pantalla Completa
                    </button>
                </div>
                <canvas id="cascade3d-canvas"></canvas>
                <div class="c3d-hint" id="c3dHint">
                    <i class="mouse pointer icon"></i> Arrastra para rotar &bull; Scroll para zoom
                </div>
                <!-- Bottom Data Banner -->
                <div class="c3d-bottom-banner" id="c3dBanner">
                    @foreach (var p in Model.Presas)
                    {
                        var pKey = SafeId(p.Presa);
                        var isTapon = p.Presa == "Tapón Juan Grijalva";
                        var lastRow = p.Datos.LastOrDefault();
                        <div class="c3d-banner-item" data-presa-key="@pKey">
                            <div class="c3d-banner-name">@p.Presa</div>
                            <div class="c3d-banner-row">
                                <span class="c3d-banner-label">Elev:</span>
                                <span class="c3d-banner-val c3d-val-elev">@(p.UltimaElevacion?.ToString("F2") ?? "—") <small>msnm</small></span>
                            </div>
                            <div class="c3d-banner-row">
                                <span class="c3d-banner-label">Almac:</span>
                                <span class="c3d-banner-val c3d-val-almac">@(p.UltimoAlmacenamiento?.ToString("F2") ?? "—") <small>Mm³</small></span>
                            </div>
                            @if (!isTapon)
                            {
                                <div class="c3d-banner-row">
                                    <span class="c3d-banner-label">Gen:</span>
                                    <span class="c3d-banner-val c3d-gen c3d-val-gen">@(p.TotalGeneracion?.ToString("F1") ?? "—") <small>MWh</small></span>
                                </div>
                                <div class="c3d-banner-row">
                                    <span class="c3d-banner-label">Uds:</span>
                                    <span class="c3d-banner-val c3d-val-uds">@(lastRow?.NumUnidades?.ToString() ?? "0") generando</span>
                                </div>
                            }
                            else
                            {
                                <div class="c3d-banner-row"><span class="c3d-banner-label c3d-no-gen">Sin generación</span></div>
                            }
                        </div>
                    }
                    <div class="c3d-banner-item c3d-banner-gulf">
                        <div class="c3d-banner-name" style="color:#4fc3f7;">Golfo de México</div>
                        <div class="c3d-banner-row"><span class="c3d-banner-label">Desembocadura</span></div>
                        <div class="c3d-banner-row"><span class="c3d-banner-label">Río Grijalva</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab: PromApor SHG (Aportado original vs promedios centrales) -->
        <div id="tab-promapor" class="tab-content" style="display:none;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:18px; padding:10px 0;">
                @foreach (var p in Model.Presas)
                {
                    <div class="chart-card" style="position:relative;">
                        <div style="position:absolute; top:8px; right:8px; z-index:3; display:flex; gap:6px;">
                            <button class="btn-maximize" type="button" onclick="maximizePromApor('@SafeId(p.Presa)', '@(p.Presa == "Tapón Juan Grijalva" ? "Tapón Juan del Grijalva" : "C.H. " + p.Presa)')" title="Maximizar">
                                <i class="expand arrows alternate icon"></i>
                            </button>
                            <button class="btn-maximize" type="button" onclick="exportPromApor('@SafeId(p.Presa)')" title="Exportar imagen" style="border-color:rgba(33,150,243,0.3); background:rgba(33,150,243,0.12); color:#2196F3;">
                                <i class="download icon"></i>
                            </button>
                        </div>
                        <div id="chart-promapor-@SafeId(p.Presa)" style="height:340px;"></div>
                    </div>
                }
            </div>
        </div>

        <!-- Tab: Niveles Horarios -->
        <div id="tab-niveleshorarios" class="tab-content" style="display:none;">
            <div style="padding:10px 0;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
                    <h3 style="color:#e8f5e9; margin:0; font-size:18px; font-weight:600; letter-spacing:0.5px;">
                        <i class="table icon" style="color:#4caf50;"></i> REPORTE DE NIVELES HORARIOS
                    </h3>
                    <div style="display:flex; align-items:center; gap:12px;">
                        <span style="color:#78909c; font-size:13px;">
                            FECHA: @Model.FechaFin.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-MX"))
                        </span>
                        <button class="btn-action-sm" type="button" onclick="exportNivelesHorarios()" title="Exportar a Excel">
                            <i class="file excel icon"></i> Excel
                        </button>
                    </div>
                </div>

                <div style="display:grid; grid-template-columns:3fr 2fr; gap:20px;">
                    <!-- Tabla de niveles -->
                    <div class="chart-card" style="overflow-x:auto; overflow-y:auto; max-height:600px; padding:12px;">
                        <table class="ui very basic inverted compact table" id="nivelesHorariosTable" style="font-size:12px; width:100%;">
                            <thead id="nivelesHorariosHead">
                                <!-- Dynamic: generated by JS from EmbalseConfig -->
                            </thead>
                            <tbody id="nivelesHorariosBody"></tbody>
                        </table>
                    </div>

                    <!-- Gráficas de nivel (dinámicas, para embalses con NAMO) -->
                    <div style="display:flex; flex-direction:column; gap:16px;" id="nivelChartsContainer">
                        <!-- Generated dynamically by JS -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab: SIMULACIÓN HIDROLÓGICA -->
        <div id="tab-hydrosim" class="tab-content" style="display:none;">
            <div style="padding:10px 0;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
                    <h3 style="color:#ff7043; margin:0; font-size:18px; font-weight:600; letter-spacing:0.5px;">
                        <i class="lightning icon" style="color:#ff5722;"></i> SIMULACIÓN HIDROLÓGICA — Pronóstico de Niveles
                    </h3>
                    <div style="display:flex; align-items:center; gap:12px;">
                        <select id="hydroHorizon" style="background:rgba(0,0,0,0.4); border:1px solid rgba(244,67,54,0.3); color:#e8f5e9; padding:6px 12px; border-radius:6px; font-size:13px;">
                            <option value="24">24 horas (1 día)</option>
                            <option value="48">48 horas (2 días)</option>
                            <option value="72" selected>72 horas (3 días)</option>
                            <option value="120">120 horas (5 días)</option>
                            <option value="168">168 horas (7 días)</option>
                            <option value="240">240 horas (10 días)</option>
                            <option value="360">360 horas (15 días)</option>
                        </select>
                        <button class="ui tiny inverted orange button" id="btnRunHydroSim">
                            <i class="play icon"></i> Ejecutar Simulación
                        </button>
                        <span id="hydroSimStatus" style="color:#78909c; font-size:12px;"></span>
                    </div>
                </div>

                <!-- Tabla de Datos de Entrada -->
                <div id="hydroInputData" style="margin-bottom:16px;">
                    <div class="chart-card" style="padding:12px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                            <h4 style="color:#42a5f5; margin:0; font-size:14px; font-weight:600;">
                                <i class="database icon"></i> Datos de Entrada del Modelo
                            </h4>
                            <button class="ui tiny inverted blue basic button" id="btnRefreshInputData" style="font-size:11px;">
                                <i class="sync icon"></i> Actualizar
                            </button>
                        </div>
                        <div id="hydroInputLoading" style="text-align:center; padding:20px; color:#78909c;">
                            <i class="spinner loading icon"></i> Cargando datos de entrada...
                        </div>
                        <div id="hydroInputContent" style="display:none;">
                            <!-- Info del pronóstico -->
                            <div id="hydroForecastInfo" style="margin-bottom:10px; font-size:12px; color:#78909c;"></div>
                            <!-- Tabla condiciones iniciales -->
                            <div style="overflow-x:auto;">
                                <table class="ui very basic inverted compact table" style="font-size:12px; width:100%;">
                                    <thead>
                                        <tr style="background:rgba(33,150,243,0.08);">
                                            <th style="color:#42a5f5;">Presa</th>
                                            <th style="color:#42a5f5;">Cuenca</th>
                                            <th style="color:#42a5f5;">Fecha Dato</th>
                                            <th style="color:#42a5f5;">Hora</th>
                                            <th style="color:#42a5f5;">Elevación (msnm)</th>
                                            <th style="color:#42a5f5;">Almac. (Mm³)</th>
                                            <th style="color:#42a5f5;">Aport. (m³/s)</th>
                                            <th style="color:#ff7043;">Extrac. (m³/s) <i class="edit icon" style="font-size:10px; opacity:0.7;" title="Editable"></i></th>
                                            <th style="color:#42a5f5;">CN</th>
                                            <th style="color:#42a5f5;">Lluvia Acum. (mm)</th>
                                        </tr>
                                    </thead>
                                    <tbody id="hydroInputTableBody"></tbody>
                                </table>
                            </div>
                            <!-- Gráfica mini de lluvia por cuenca -->
                            <div id="hydroInputRainChart" style="height:180px; margin-top:12px;"></div>
                        </div>
                        <div id="hydroInputError" style="display:none; color:#ff5252; font-size:12px; padding:10px;"></div>
                    </div>
                </div>

                <!-- Tabla de Extracciones Programadas (por día) -->
                <div id="hydroExtractionSchedule" style="margin-bottom:16px;">
                    <div class="chart-card" style="padding:12px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                            <h4 style="color:#ff7043; margin:0; font-size:14px; font-weight:600;">
                                <i class="calendar alternate icon"></i> Programa de Extracciones (m³/s por día)
                            </h4>
                            <div style="display:flex; gap:8px; align-items:center;">
                                <button class="ui tiny inverted orange basic button" id="btnFillExtraction" style="font-size:11px;" title="Copiar valor del día 1 a todos los días">
                                    <i class="clone icon"></i> Rellenar
                                </button>
                                <button class="ui tiny inverted basic button" id="btnResetExtraction" style="font-size:11px;" title="Restaurar valores iniciales">
                                    <i class="undo icon"></i> Reset
                                </button>
                            </div>
                        </div>
                        <div style="overflow-x:auto;">
                            <table class="ui very basic inverted compact table" id="extractionScheduleTable" style="font-size:12px; width:100%;">
                                <thead id="extractionScheduleHead"></thead>
                                <tbody id="extractionScheduleBody"></tbody>
                            </table>
                        </div>
                        <div style="margin-top:8px; font-size:11px; color:#546e7a;">
                            <i class="info circle icon"></i> Ingrese el gasto de extracción (m³/s) para cada presa y día. El simulador aplicará estos valores al balance hídrico horario.
                        </div>
                    </div>
                </div>

                <!-- Tabla de Aportaciones Programadas (por día) -->
                <div id="hydroAportationSchedule" style="margin-bottom:16px;">
                    <div class="chart-card" style="padding:12px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                            <h4 style="color:#4fc3f7; margin:0; font-size:14px; font-weight:600;">
                                <i class="tint icon"></i> Programa de Aportaciones (m³/s por día)
                            </h4>
                            <div style="display:flex; gap:8px; align-items:center;">
                                <button class="ui tiny inverted blue basic button" id="btnFillAportation" style="font-size:11px;" title="Copiar valor del día 1 a todos los días">
                                    <i class="clone icon"></i> Rellenar
                                </button>
                                <button class="ui tiny inverted basic button" id="btnResetAportation" style="font-size:11px;" title="Restaurar valores iniciales">
                                    <i class="undo icon"></i> Reset
                                </button>
                            </div>
                        </div>
                        <div style="overflow-x:auto;">
                            <table class="ui very basic inverted compact table" id="aportationScheduleTable" style="font-size:12px; width:100%;">
                                <thead id="aportationScheduleHead"></thead>
                                <tbody id="aportationScheduleBody"></tbody>
                            </table>
                        </div>
                        <div style="margin-top:8px; font-size:11px; color:#546e7a;">
                            <i class="info circle icon"></i> Ingrese aportaciones manuales (m³/s). Si se deja un valor, reemplaza la aportación calculada por lluvia para esa presa. Deje en 0 para usar el cálculo automático.
                        </div>
                    </div>
                </div>

                <!-- Parámetros del Modelo (CN y Coeficiente de Escurrimiento) -->
                <div id="hydroModelParams" style="margin-bottom:16px;">
                    <div class="chart-card" style="padding:12px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                            <h4 style="color:#ab47bc; margin:0; font-size:14px; font-weight:600;">
                                <i class="sliders horizontal icon"></i> Parámetros del Modelo
                            </h4>
                            <button class="ui tiny inverted purple basic button" id="btnResetParams" style="font-size:11px;" title="Restaurar valores por defecto de la BD">
                                <i class="undo icon"></i> Reset
                            </button>
                        </div>
                        <table class="ui very basic inverted compact table" id="modelParamsTable" style="font-size:12px; width:auto;">
                            <thead>
                                <tr style="background:rgba(171,71,188,0.08);">
                                    <th style="color:#ab47bc; min-width:100px;">Presa</th>
                                    <th style="color:#ab47bc; text-align:center;" title="Número de Curva SCS-NRCS (30-100)">CN (Curva)</th>
                                    <th style="color:#ab47bc; text-align:center;" title="Coeficiente de escurrimiento / drenaje">Coef. Escurr.</th>
                                </tr>
                            </thead>
                            <tbody id="modelParamsBody"></tbody>
                        </table>
                        <div style="margin-top:8px; font-size:11px; color:#546e7a;">
                            <i class="info circle icon"></i> <b>CN</b>: Número de Curva SCS (controla la abstracción de lluvia; mayor CN = más escurrimiento). <b>Coef. Escurrimiento</b>: multiplica el volumen escurrido por cuenca (por presa).
                        </div>
                    </div>
                </div>

                <!-- Summary cards de simulación -->
                <div id="hydroSimSummary" style="display:none;">
                    <div style="display:flex; gap:8px; margin-bottom:12px; flex-wrap:wrap;" id="hydroSummaryCards"></div>
                </div>

                <!-- Gráficas de simulación -->
                <div id="hydroSimCharts" style="display:grid; grid-template-columns:1fr 1fr; gap:16px;"></div>

                <!-- Tabla resumen estilo Funcionamiento de Vasos -->
                <div id="hydroSimTable" style="display:none; margin-top:16px;">
                    <div class="chart-card" style="padding:12px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                            <h4 style="color:#e8f5e9; margin:0; font-size:14px; font-weight:600;">
                                <i class="table icon"></i> Funcionamiento de Vasos Simulado
                            </h4>
                            <div style="display:flex; gap:6px; align-items:center;">
                                <label style="font-size:11px; color:#78909c;">Intervalo:</label>
                                <select id="hydroTableInterval" style="background:#1a2530; border:1px solid #37474f; color:#b0bec5; border-radius:4px; padding:2px 6px; font-size:11px;">
                                    <option value="1">Cada hora</option>
                                    <option value="3" selected>Cada 3h</option>
                                    <option value="6">Cada 6h</option>
                                    <option value="12">Cada 12h</option>
                                    <option value="24">Cada 24h</option>
                                </select>
                            </div>
                        </div>
                        <!-- Tabs por presa -->
                        <div id="hydroTableTabs" style="display:flex; gap:4px; margin-bottom:10px; flex-wrap:wrap;"></div>
                        <!-- Tabla -->
                        <div style="overflow-x:auto; max-height:500px; overflow-y:auto;">
                            <table class="ui very basic inverted compact table" style="font-size:11px; width:100%; border-collapse:collapse;">
                                <thead id="hydroTableHead" style="position:sticky; top:0; z-index:2;"></thead>
                                <tbody id="hydroTableBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab: TENDENCIA (Datos reales + Pronóstico) -->
        <div id="tab-tendencia" class="tab-content" style="display:none;">
            <div style="padding:10px 0;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; flex-wrap:wrap; gap:10px;">
                    <h3 style="color:#00bcd4; margin:0; font-size:18px; font-weight:600; letter-spacing:0.5px;">
                        <i class="chart area icon" style="color:#00acc1;"></i> TENDENCIA — Nivel de Embalses
                    </h3>
                    <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
                        <label style="color:#78909c; font-size:12px;">Días reales:</label>
                        <select id="trendRealDays" style="background:rgba(0,0,0,0.4); border:1px solid rgba(0,188,212,0.3); color:#e8f5e9; padding:5px 10px; border-radius:6px; font-size:12px;">
                            <option value="3">3 días</option>
                            <option value="5" selected>5 días</option>
                            <option value="7">7 días</option>
                            <option value="10">10 días</option>
                            <option value="15">15 días</option>
                        </select>
                        <label style="color:#78909c; font-size:12px;">Pronóstico:</label>
                        <select id="trendForecastHours" style="background:rgba(0,0,0,0.4); border:1px solid rgba(0,188,212,0.3); color:#e8f5e9; padding:5px 10px; border-radius:6px; font-size:12px;">
                            <option value="24">24h (1 día)</option>
                            <option value="48">48h (2 días)</option>
                            <option value="72" selected>72h (3 días)</option>
                            <option value="120">120h (5 días)</option>
                            <option value="168">168h (7 días)</option>
                        </select>
                        <button class="ui tiny inverted teal button" id="btnLoadTrend">
                            <i class="sync icon"></i> Cargar Tendencia
                        </button>
                        <span id="trendStatus" style="color:#78909c; font-size:12px;"></span>
                    </div>
                </div>

                <!-- Info -->
                <div id="trendInfo" style="margin-bottom:12px; font-size:12px; color:#546e7a;"></div>

                <!-- Contenedor de gráficas por embalse -->
                <div id="trendChartsContainer">
                    <div style="text-align:center; padding:60px 0; color:#546e7a;">
                        <i class="chart area icon" style="font-size:48px; opacity:0.3;"></i>
                        <div style="margin-top:12px;">Haga clic en <strong style="color:#00bcd4;">Cargar Tendencia</strong> para generar las gráficas.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Individual presa tabs -->
        @foreach (var p in Model.Presas)
        {
            <div id="tab-@SafeId(p.Presa)" class="tab-content" style="display:none;">
                <!-- Summary cards -->
                <div class="summary-cards">
                    <div class="summary-card elev">
                        <div class="label">Elevación</div>
                        <div class="value">@(p.UltimaElevacion?.ToString("F2") ?? "—")</div>
                        <div class="unit">m.s.n.m</div>
                    </div>
                    <div class="summary-card almac">
                        <div class="label">Almacenamiento</div>
                        <div class="value">@(p.UltimoAlmacenamiento?.ToString("F2") ?? "—")</div>
                        <div class="unit">Mill. m³</div>
                    </div>
                    <div class="summary-card aport">
                        <div class="label">Aportaciones</div>
                        <div class="value">@(p.TotalAportacionesV?.ToString("F2") ?? "—")</div>
                        <div class="unit">Mill. m³</div>
                    </div>
                    <div class="summary-card extrac">
                        <div class="label">Extracciones</div>
                        <div class="value">@(p.TotalExtraccionesV?.ToString("F2") ?? "—")</div>
                        <div class="unit">Mill. m³</div>
                    </div>
                    @if (p.Presa != "Tapón Juan Grijalva")
                    {
                        <div class="summary-card gen">
                            <div class="label">Generación</div>
                            <div class="value">@(p.TotalGeneracion?.ToString("F1") ?? "—")</div>
                            <div class="unit">MWH total</div>
                        </div>
                    }
                </div>

                <!-- Table -->
                @await Html.PartialAsync("_PresaTable", p)

                <!-- Combined Chart: Comportamiento del Embalse -->
                <div class="combo-chart-card">
                    <div class="combo-title">
                        <i class="chart area icon"></i> Comportamiento del Embalse de @(p.Presa == "Tapón Juan Grijalva" ? "Juan de Grijalva" : "la C.H. " + p.Presa)
                    </div>
                    <div style="position:absolute; top:10px; right:12px; z-index:2; display:flex; gap:6px;">
                        <button class="btn-action-sm" type="button" onclick="openRefModal('@SafeId(p.Presa)', '@p.Presa')" title="Configurar líneas de referencia">
                            <i class="sliders horizontal icon"></i> Ref.
                        </button>
                        <button class="btn-action-sm" type="button" onclick="maximizeChart('@SafeId(p.Presa)', '@(p.Presa == "Tapón Juan Grijalva" ? "Juan de Grijalva" : "C.H. " + p.Presa)')" title="Maximizar">
                            <i class="expand arrows alternate icon"></i>
                        </button>
                        <button class="btn-action-sm btn-export" type="button" onclick="exportIndivChart('@SafeId(p.Presa)', 'combo')" title="Exportar PNG">
                            <i class="download icon"></i>
                        </button>
                    </div>
                    <div id="chart-combo-@SafeId(p.Presa)" style="height:380px;"></div>
                </div>

                <!-- Charts -->
                <div class="charts-grid">
                    <div class="chart-card" style="position:relative;">
                        <div class="chart-title">
                            <i class="chart line icon" style="color:#00e676;"></i> Elevación del Vaso
                        </div>
                        <div style="position:absolute; top:8px; right:8px; z-index:3; display:flex; gap:5px;">
                            <button class="btn-action-sm" type="button" onclick="openRefModal('@SafeId(p.Presa)', '@p.Presa')" title="Configurar líneas de referencia">
                                <i class="sliders horizontal icon"></i>
                            </button>
                            <button class="btn-action-sm" type="button" onclick="maximizeIndivChart('@SafeId(p.Presa)', 'elev', 'Elevación del Vaso')" title="Maximizar">
                                <i class="expand arrows alternate icon"></i>
                            </button>
                            <button class="btn-action-sm btn-export" type="button" onclick="exportIndivChart('@SafeId(p.Presa)', 'elev')" title="Exportar PNG">
                                <i class="download icon"></i>
                            </button>
                        </div>
                        <div id="chart-elev-@SafeId(p.Presa)" style="height:280px;"></div>
                    </div>
                    <div class="chart-card" style="position:relative;">
                        <div class="chart-title"><i class="chart bar icon" style="color:#00b0ff;"></i> Aportaciones vs Extracciones (m³/s)</div>
                        <div style="position:absolute; top:8px; right:8px; z-index:3; display:flex; gap:5px;">
                            <button class="btn-action-sm" type="button" onclick="maximizeIndivChart('@SafeId(p.Presa)', 'qflow', 'Aportaciones vs Extracciones')" title="Maximizar">
                                <i class="expand arrows alternate icon"></i>
                            </button>
                            <button class="btn-action-sm btn-export" type="button" onclick="exportIndivChart('@SafeId(p.Presa)', 'qflow')" title="Exportar PNG">
                                <i class="download icon"></i>
                            </button>
                        </div>
                        <div id="chart-qflow-@SafeId(p.Presa)" style="height:280px;"></div>
                    </div>
                    @if (p.Presa != "Tapón Juan Grijalva")
                    {
                        <div class="chart-card" style="position:relative;">
                            <div class="chart-title"><i class="bolt icon" style="color:#e040fb;"></i> Generación (MWH)</div>
                            <div style="position:absolute; top:8px; right:8px; z-index:3; display:flex; gap:5px;">
                                <button class="btn-action-sm" type="button" onclick="maximizeIndivChart('@SafeId(p.Presa)', 'gen', 'Generación (MWH)')" title="Maximizar">
                                    <i class="expand arrows alternate icon"></i>
                                </button>
                                <button class="btn-action-sm btn-export" type="button" onclick="exportIndivChart('@SafeId(p.Presa)', 'gen')" title="Exportar PNG">
                                    <i class="download icon"></i>
                                </button>
                            </div>
                            <div id="chart-gen-@SafeId(p.Presa)" style="height:280px;"></div>
                        </div>
                    }
                    <div class="chart-card" style="position:relative;">
                        <div class="chart-title"><i class="tint icon" style="color:#ffab40;"></i> Almacenamiento (Mill. m³)</div>
                        <div style="position:absolute; top:8px; right:8px; z-index:3; display:flex; gap:5px;">
                            <button class="btn-action-sm" type="button" onclick="maximizeIndivChart('@SafeId(p.Presa)', 'almac', 'Almacenamiento (Mill. m³)')" title="Maximizar">
                                <i class="expand arrows alternate icon"></i>
                            </button>
                            <button class="btn-action-sm btn-export" type="button" onclick="exportIndivChart('@SafeId(p.Presa)', 'almac')" title="Exportar PNG">
                                <i class="download icon"></i>
                            </button>
                        </div>
                        <div id="chart-almac-@SafeId(p.Presa)" style="height:280px;"></div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Fullscreen chart modal -->
<div class="chart-fullscreen-overlay" id="chartFullscreen">
    <div class="fs-header">
        <span class="fs-title" id="fsTitleText"></span>
        <button class="btn-close-fs" onclick="closeFullscreen()"><i class="compress icon"></i> Cerrar</button>
    </div>
    <div class="fs-chart-container" id="fsChartContainer"></div>
</div>

<!-- Modal: Configurar Referencias del Embalse -->
<div class="ui small inverted modal" id="refModal">
    <div class="header" style="background:rgba(0,230,118,0.12); border-bottom:1px solid rgba(0,230,118,0.3);">
        <i class="sliders horizontal icon" style="color:#00e676;"></i> Líneas de Referencia — <span id="refPresaTitle"></span>
    </div>
    <div class="content" style="background:#0a1520;">
        <div style="margin-bottom:16px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                <h5 style="color:#78909c; margin:0; font-size:11px; text-transform:uppercase; letter-spacing:1px;">Niveles Fijos (NAMO / NAME / NAMINO)</h5>
                <button type="button" class="ui tiny basic inverted button" onclick="openEmbalseConfigModal()" style="padding:4px 10px; font-size:11px;">
                    <i class="cog icon"></i> Configurar Niveles
                </button>
            </div>
            <div style="display:flex; gap:10px; flex-wrap:wrap;" id="refNivelesToggle"></div>
        </div>
        <hr style="border-color:rgba(255,255,255,0.08); margin:14px 0;">
        <h5 style="color:#78909c; margin:0 0 10px; font-size:11px; text-transform:uppercase; letter-spacing:1px;">Asíntotas de Referencia Personalizadas</h5>
        <div id="refTableContainer">
            <table class="ui very basic inverted compact table" id="refTable" style="font-size:12px;">
                <thead>
                    <tr>
                        <th style="color:#b0bec5;">Nombre</th>
                        <th style="color:#b0bec5;">Valor (msnm)</th>
                        <th style="color:#b0bec5;">Color</th>
                        <th style="color:#b0bec5;">Visible</th>
                        <th style="color:#b0bec5;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="refTableBody"></tbody>
            </table>
        </div>
        <div style="margin-top:12px; padding:12px; background:rgba(0,230,118,0.06); border-radius:8px; border:1px solid rgba(0,230,118,0.15);">
            <h5 style="color:#00e676; margin:0 0 8px; font-size:12px;"><i class="plus icon"></i> Agregar / Editar Referencia</h5>
            <input type="hidden" id="refEditId" value="0">
            <div style="display:grid; grid-template-columns:1fr 120px 80px; gap:8px; align-items:end;">
                <div>
                    <label style="color:#78909c; font-size:11px; display:block; margin-bottom:3px;">Nombre</label>
                    <input type="text" id="refNombre" placeholder="Ej: Nivel Crítico" maxlength="200"
                           style="width:100%; background:rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.15); color:#e8f5e9; padding:7px 10px; border-radius:5px; font-size:12px;">
                </div>
                <div>
                    <label style="color:#78909c; font-size:11px; display:block; margin-bottom:3px;">Valor (msnm)</label>
                    <input type="number" step="0.01" id="refValor" placeholder="0.00"
                           style="width:100%; background:rgba(0,0,0,0.4); border:1px solid rgba(255,255,255,0.15); color:#e8f5e9; padding:7px 10px; border-radius:5px; font-size:12px;">
                </div>
                <div>
                    <label style="color:#78909c; font-size:11px; display:block; margin-bottom:3px;">Color</label>
                    <input type="color" id="refColor" value="#ffff00"
                           style="width:100%; height:33px; border:1px solid rgba(255,255,255,0.15); border-radius:5px; cursor:pointer; background:transparent;">
                </div>
            </div>
            <div style="margin-top:10px; display:flex; gap:8px;">
                <button type="button" class="ui tiny green button" id="btnSaveRef"><i class="save icon"></i> Guardar</button>
                <button type="button" class="ui tiny basic inverted button" id="btnResetRef"><i class="eraser icon"></i> Limpiar</button>
            </div>
        </div>
    </div>
    <div class="actions" style="background:rgba(0,230,118,0.06); border-top:1px solid rgba(0,230,118,0.15);">
        <button type="button" class="ui inverted green button" id="btnApplyCloseRef">
            <i class="check icon"></i> Aplicar y Cerrar
        </button>
    </div>
</div>

