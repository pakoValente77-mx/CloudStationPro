    function renderNivelesToggle(presaKey) {
        var nivRef = NIVELES_REF[presaKey];
        var vis = nivelesVisibles[presaKey];
        if (!nivRef || !vis) { $('#refNivelesToggle').html('<span style="color:#546e7a; font-size:12px;">Sin niveles de referencia para esta presa.</span>'); return; }
        var html = '';
        var items = [
            { key: 'namo', label: 'NAMO', val: nivRef.namo, color: '#ff5252', bg: 'rgba(255,82,82,0.15)', border: 'rgba(255,82,82,0.5)' },
            { key: 'name_e', label: 'NAME', val: nivRef.name_e, color: '#ff9800', bg: 'rgba(255,152,0,0.15)', border: 'rgba(255,152,0,0.5)' },
            { key: 'namino', label: 'NAMINO', val: nivRef.namino, color: '#42a5f5', bg: 'rgba(66,165,245,0.15)', border: 'rgba(66,165,245,0.5)' }
        ];
        items.forEach(function(item) {
            var active = vis[item.key] ? 'active' : '';
            html += '<div class="nivel-toggle-chip ' + active + '" data-nivel="' + item.key + '" '
                + 'style="background:' + item.bg + '; border-color:' + item.border + '; color:' + item.color + ';" '
                + 'onclick="toggleNivel(\'' + presaKey + '\', \'' + item.key + '\', this)">'
                + '<i class="' + (vis[item.key] ? 'eye' : 'eye slash') + ' icon" style="margin:0;"></i> '
                + item.label + ' <span class="nivel-val">' + item.val.toFixed(2) + '</span>'
                + '</div>';
        });
        $('#refNivelesToggle').html(html);
    }

    window.toggleNivel = function(presaKey, nivelKey, el) {
        nivelesVisibles[presaKey][nivelKey] = !nivelesVisibles[presaKey][nivelKey];
        var isVis = nivelesVisibles[presaKey][nivelKey];
        $(el).toggleClass('active', isVis);
        $(el).find('i').attr('class', isVis ? 'eye icon' : 'eye slash icon');
    };

    function loadRefTable(presaKey) {
        var refs = customRefs[presaKey] || [];
        var html = '';
        if (refs.length === 0) {
            html = '<tr><td colspan="5" style="color:#546e7a; text-align:center; padding:12px;">No hay asíntotas personalizadas configuradas.</td></tr>';
        } else {
            refs.forEach(function(ref) {
                html += '<tr>'
                    + '<td style="color:#e8f5e9;">' + escHtml(ref.nombre) + '</td>'
                    + '<td style="color:#e8f5e9; text-align:center;">' + parseFloat(ref.valor).toFixed(2) + '</td>'
                    + '<td style="text-align:center;"><span style="display:inline-block; width:20px; height:14px; border-radius:3px; background:' + escHtml(ref.color) + ';"></span></td>'
                    + '<td style="text-align:center;">'
                    + '  <div class="ui fitted toggle checkbox" style="transform:scale(0.8);">'
                    + '    <input type="checkbox" ' + (ref.visible ? 'checked' : '') + ' onchange="toggleRefVisible(' + ref.id + ', this.checked)">'
                    + '    <label></label>'
                    + '  </div>'
                    + '</td>'
                    + '<td style="text-align:center;">'
                    + '  <button class="ui tiny inverted yellow icon button" onclick="editRef(' + ref.id + ')" title="Editar"><i class="edit icon"></i></button>'
                    + '  <button class="ui tiny inverted red icon button" onclick="deleteRef(' + ref.id + ')" title="Eliminar"><i class="trash icon"></i></button>'
                    + '</td>'
                    + '</tr>';
            });
        }
        $('#refTableBody').html(html);
        $('#refTableBody .ui.checkbox').checkbox();
    }

    function escHtml(s) { return $('<span>').text(s).html(); }

    window.resetRefForm = function() {
        $('#refEditId').val('0');
        $('#refNombre').val('');
        $('#refValor').val('');
        $('#refColor').val('#ffff00');
    };

    window.saveReferencia = function() {
        var nombre = $('#refNombre').val().trim();
        var valor = $('#refValor').val();
        if (!nombre || !valor) { alert('Ingresa nombre y valor.'); return; }
        if (!currentRefPresa) { alert('No hay presa seleccionada.'); return; }
        var payload = {
            id: 0,
            presaKey: currentRefPresa,
            nombre: nombre,
            valor: parseFloat(valor),
            color: $('#refColor').val(),
            visible: true
        };
        var editId = parseInt($('#refEditId').val());
        if (editId > 0) payload.id = editId;
        console.log('[FunVasos] Guardando referencia:', payload);
        $.ajax({
            type: 'POST',
            url: '@Url.Action("SaveReferencia", "FunVasos")',
            contentType: 'application/json',
            data: JSON.stringify(payload),
            headers: { 'RequestVerificationToken': _antiForgeryToken },
            success: function(r) {
                console.log('[FunVasos] Respuesta save:', r);
                if (r.success) {
                    if (!customRefs[currentRefPresa]) customRefs[currentRefPresa] = [];
                    var ref = r.referencia;
                    var idx = customRefs[currentRefPresa].findIndex(function(x) { return x.id === ref.id; });
                    if (idx >= 0) customRefs[currentRefPresa][idx] = ref;
                    else customRefs[currentRefPresa].push(ref);
                    resetRefForm();
                    loadRefTable(currentRefPresa);
                    // Re-render charts immediately so user sees the line
                    reRenderPresa(currentRefPresa);
                } else { alert('Error al guardar: ' + (r.message || 'Error desconocido')); }
            },
            error: function(xhr, status, err) {
                console.error('[FunVasos] Error AJAX save:', xhr.status, xhr.responseText);
                alert('Error al guardar referencia (HTTP ' + xhr.status + '). Revisa la consola del navegador.');
            }
        });
    };

    window.editRef = function(id) {
        var refs = customRefs[currentRefPresa] || [];
        var ref = refs.find(function(x) { return x.id === id; });
        if (!ref) return;
        $('#refEditId').val(ref.id);
        $('#refNombre').val(ref.nombre);
        $('#refValor').val(ref.valor);
        $('#refColor').val(ref.color || '#ffff00');
    };

    window.deleteRef = function(id) {
        if (!confirm('¿Eliminar esta referencia permanentemente?')) return;
        $.ajax({
            type: 'POST',
            url: '@Url.Action("DeleteReferencia", "FunVasos")' + '?id=' + id,
            headers: { 'RequestVerificationToken': _antiForgeryToken },
            success: function(r) {
                if (r.success) {
                    customRefs[currentRefPresa] = (customRefs[currentRefPresa] || []).filter(function(x) { return x.id !== id; });
                    loadRefTable(currentRefPresa);
                    reRenderPresa(currentRefPresa);
                } else { alert('Error al eliminar: ' + (r.message || '')); }
            },
            error: function(xhr) { alert('Error HTTP ' + xhr.status + ' al eliminar.'); }
        });
    };

    window.toggleRefVisible = function(id, visible) {
        $.ajax({
            type: 'POST',
            url: '@Url.Action("ToggleReferencia", "FunVasos")',
            contentType: 'application/json',
            data: JSON.stringify({ id: id, visible: visible }),
            headers: { 'RequestVerificationToken': _antiForgeryToken },
            success: function(r) {
                if (r.success) {
                    var refs = customRefs[currentRefPresa] || [];
                    var ref = refs.find(function(x) { return x.id === id; });
                    if (ref) ref.visible = visible;
                    reRenderPresa(currentRefPresa);
                }
            },
            error: function(xhr) { console.error('[FunVasos] Toggle error:', xhr.status); }
        });
    };

    // Re-render charts for a specific presa key
    function reRenderPresa(presaKey) {
        if (presaKey && presaKey !== 'todas' && presaKey !== 'cascada3d' && presasData[presaKey]) {
            renderCharts(presaKey);
        }
    }

    window.reRenderCurrentPresa = function() {
        var active = $('.presa-tab.active').data('presa');
        if (active && active !== 'todas' && active !== 'cascada3d') {
            renderCharts(active);
        } else if (currentRefPresa) {
            reRenderPresa(currentRefPresa);
        }
    };

    // ========== PROMAPOR SHG: Maximizar & Exportar ==========
    var promAporCharts = {};  // { presaKey: Highcharts.Chart instance }

    window.maximizePromApor = function(presaKey, presaTitle) {
        $('#fsTitleText').text('Aportado original vs promedios centrales — ' + presaTitle);
        $('#chartFullscreen').addClass('active');
        $('body').css('overflow', 'hidden');
        currentFsPresa = '__promapor__' + presaKey;
        setTimeout(function() {
            var h = $('#fsChartContainer').height();
            renderSinglePromApor('fsChartContainer', presaKey, h);
        }, 100);
    };

    window.exportPromApor = function(presaKey) {
        var chart = promAporCharts[presaKey];
        if (chart) {
            chart.exportChart({ type: 'image/png', filename: 'PromApor_' + presaKey }, {
                chart: { backgroundColor: '#0f1923' }
            });
        }
    };

    // ========== PROMAPOR SHG: Promedio Central Móvil ==========
    var PRESA_DISPLAY = {};
    @foreach (var p in Model.Presas)
    {
        <text>PRESA_DISPLAY['@SafeId(p.Presa)'] = '@Html.Raw(p.Presa == "Tapón Juan Grijalva" ? "Tapón Juan del Grijalva" : "C.H. " + p.Presa)';
        </text>
    }

    // Calcular promedio móvil central de 3 puntos (una pasada)
    function centralMovingAverage(data) {
        if (!data || data.length < 3) return [];
        var result = [];
        for (var i = 1; i < data.length - 1; i++) {
            if (data[i - 1] != null && data[i] != null && data[i + 1] != null) {
                result.push(Math.round(((data[i - 1] + data[i] + data[i + 1]) / 3) * 100) / 100);
            } else {
                result.push(null);
            }
        }
        return result;
    }

    // Renderizar todas las gráficas de PromApor SHG
    function buildPromAporSeries(presaKey) {
        var seriesConfig = [
            { name: 'Aportado original', color: '#0000CC', marker: 'diamond' },
            { name: '1er. Promedio',     color: '#E91E63', marker: 'square' },
            { name: '2° Promedio',       color: '#00CC00', marker: 'triangle' },
            { name: '3er. Promedio',     color: '#CC0000', marker: 'square' },
            { name: '4° Promedio',       color: '#9C27B0', marker: 'diamond' }
        ];

        var d = presasData[presaKey];
        if (!d || !d.aportQ) return null;

        var TOTAL_HOURS = 25;
        var categories = [];
        for (var h = 0; h < TOTAL_HOURS; h++) categories.push(h.toString());

        var original = [];
        for (var h = 0; h < TOTAL_HOURS; h++) {
            var v = (h < d.aportQ.length && d.aportQ[h] != null) ? d.aportQ[h] : 0;
            original.push(v);
        }

        var series = [];
        series.push({
            type: 'spline',
            name: seriesConfig[0].name,
            data: original.slice(),
            color: seriesConfig[0].color,
            marker: { symbol: seriesConfig[0].marker, radius: 4, enabled: true },
            lineWidth: 2
        });

        var current = original;
        for (var pass = 1; pass <= 4; pass++) {
            var avg = centralMovingAverage(current);
            if (avg.length < 2) break;
            var offsetData = [];
            for (var i = 0; i < TOTAL_HOURS; i++) {
                var idx = i - pass;
                if (idx >= 0 && idx < avg.length) {
                    offsetData.push(avg[idx]);
                } else {
                    offsetData.push(null);
                }
            }
            series.push({
                type: 'spline',
                name: seriesConfig[pass].name,
                data: offsetData,
                color: seriesConfig[pass].color,
                marker: { symbol: seriesConfig[pass].marker, radius: 4, enabled: true },
                lineWidth: 2
            });
            current = avg;
        }
        return { categories: categories, series: series };
    }

    function renderPromAporToContainer(containerId, presaKey, chartHeight) {
        var built = buildPromAporSeries(presaKey);
        if (!built) return null;
        var displayName = PRESA_DISPLAY[presaKey] || presaKey;
        return Highcharts.chart(containerId, {
            chart: { backgroundColor: 'transparent', height: chartHeight || null },
            title: {
                text: 'Aportado original vs promedios centrales<br/>' + displayName,
                style: { color: '#e8f5e9', fontSize: '14px', fontWeight: '600' }
            },
            credits: { enabled: false },
            xAxis: {
                categories: built.categories,
                min: 0,
                max: 24,
                tickInterval: 1,
                title: { text: 'Tiempo, horas', style: { color: '#78909c' } },
                labels: { style: { color: '#78909c' } },
                gridLineColor: 'rgba(255,255,255,0.05)',
                lineColor: 'rgba(255,255,255,0.1)'
            },
            yAxis: {
                title: { text: 'Aportado, m3/s', style: { color: '#78909c' } },
                labels: { style: { color: '#78909c' }, format: '{value:.2f}' },
                gridLineColor: 'rgba(255,255,255,0.05)'
            },
            legend: {
                enabled: true,
                itemStyle: { color: '#b0bec5', fontWeight: '400', fontSize: '11px' },
                itemHoverStyle: { color: '#fff' }
            },
            tooltip: {
                shared: true,
                backgroundColor: 'rgba(15,25,30,0.95)',
                borderColor: '#00e676',
                style: { color: '#e8f5e9' },
                valueDecimals: 2,
                valueSuffix: ' m³/s'
            },
            exporting: { enabled: false },
            series: built.series
        });
    }

    // Renderizar una sola para fullscreen
    function renderSinglePromApor(containerId, presaKey, h) {
        renderPromAporToContainer(containerId, presaKey, h);
    }

    function renderPromAporCharts() {
        Object.keys(presasData).forEach(function(presaKey) {
            var chart = renderPromAporToContainer('chart-promapor-' + sanitizeId(presaKey), presaKey, null);
            if (chart) promAporCharts[presaKey] = chart;
        });
    }

    // Delegated event handlers for modal buttons (robust even after Fomantic moves DOM)
    $(document).on('click', '#btnSaveRef', function(e) {
        e.preventDefault();
        e.stopPropagation();
        console.log('[FunVasos] btnSaveRef clicked');
        saveReferencia();
    });
    $(document).on('click', '#btnResetRef', function(e) {
        e.preventDefault();
        resetRefForm();
    });
    $(document).on('click', '#btnApplyCloseRef', function(e) {
        e.preventDefault();
        $('#refModal').modal('hide');
        reRenderCurrentPresa();
    });

    // ========== NIVELES HORARIOS ==========
    var NAMO_NIVELES = { Chicoasen: 392.50, Penitas: 87.40 };
    var nivelCharts = {};

    window.renderNivelesHorarios = function() {
        var tbody = $('#nivelesHorariosBody');
        tbody.empty();

        var ang = presasData['Angostura'];
        var chi = presasData['Chicoasen'];
        var mal = presasData['Malpaso'];
        var pen = presasData['Penitas'];

        // Build hour⇒value maps (works for both single-day and range)
        function buildHourMap(pd) {
            if (!pd) return {};
            var map = {};
            for (var i = 0; i < pd.labels.length; i++) {
                // label could be "HH:00" or "dd/MM HH:00"
                var lbl = pd.labels[i];
                var parts = lbl.split(' ');
                var hourStr = parts.length > 1 ? parts[parts.length - 1] : parts[0];
                var h = parseInt(hourStr);
                if (!isNaN(h)) map[h] = pd.elevacion[i];
            }
            return map;
        }

        var angMap = buildHourMap(ang);
        var chiMap = buildHourMap(chi);
        var malMap = buildHourMap(mal);
        var penMap = buildHourMap(pen);

        for (var h = 1; h <= 24; h++) {
            var aVal = angMap[h];
            var cVal = chiMap[h];
            var mVal = malMap[h];
            var pVal = penMap[h];

            var cDif = (cVal != null) ? (NAMO_NIVELES.Chicoasen - cVal) : null;
            var pDif = (pVal != null) ? (NAMO_NIVELES.Penitas - pVal) : null;

            var fmt = function(v) { return v != null ? v.toFixed(2) : ''; };

            var row = '<tr>' +
                '<td style="text-align:center; color:#4caf50; font-weight:600;">' + h + '</td>' +
                '<td style="text-align:center;">' + fmt(aVal) + '</td>' +
                '<td style="text-align:center;">' + fmt(cVal) + '</td>' +
                '<td style="text-align:center; color:' + (cDif != null && cDif > 0 ? '#ffab40' : '#00e676') + ';">' + fmt(cDif) + '</td>' +
                '<td style="text-align:center;">' + fmt(mVal) + '</td>' +
                '<td style="text-align:center;">' + fmt(pVal) + '</td>' +
                '<td style="text-align:center; color:' + (pDif != null && pDif > 0 ? '#ffab40' : '#00e676') + ';">' + fmt(pDif) + '</td>' +
                '</tr>';
            tbody.append(row);
        }

        renderNivelCharts();
    };

    function renderNivelCharts() {
        renderNivelChartFor('chicoasen', 'Chicoasen', 'Chicoasén', '#42a5f5', NAMO_NIVELES.Chicoasen);
        renderNivelChartFor('penitas', 'Penitas', 'Peñitas', '#ffab40', NAMO_NIVELES.Penitas);
    }

    function renderNivelChartFor(chartKey, dataKey, displayName, color, namoVal) {
        var pd = presasData[dataKey];
        if (!pd) return;

        // Build arrays for 24 hours
        var categories = [];
        var data = [];
        var hourMap = {};
        for (var i = 0; i < pd.labels.length; i++) {
            var lbl = pd.labels[i];
            var parts = lbl.split(' ');
            var hourStr = parts.length > 1 ? parts[parts.length - 1] : parts[0];
            var h = parseInt(hourStr);
            if (!isNaN(h)) hourMap[h] = pd.elevacion[i];
        }
        for (var h = 1; h <= 24; h++) {
            categories.push(h + ':00');
            data.push(hourMap[h] != null ? hourMap[h] : null);
        }

        var chart = Highcharts.chart('chart-nivel-' + chartKey, {
            chart: { backgroundColor: 'transparent', height: 250, spacingTop: 30 },
            title: { text: displayName, style: { color: color, fontSize: '14px', fontWeight: '600' } },
            exporting: { enabled: false },
            xAxis: { categories: categories, labels: { style: { color: '#78909c', fontSize: '9px' }, step: 2 } },
            yAxis: {
                title: { text: 'Nivel (msnm)', style: { color: '#78909c', fontSize: '10px' } },
                softMax: namoVal + 0.5,
                plotLines: [{
                    value: namoVal,
                    color: '#ff5252',
                    width: 2,
                    dashStyle: 'Dash',
                    zIndex: 5,
                    label: { text: 'NAMO: ' + namoVal.toFixed(2) + ' msnm', align: 'right', style: { color: '#ff5252', fontSize: '10px', fontWeight: '600' } }
                }]
            },
            series: [{
                name: 'Nivel',
                type: 'spline',
                data: data,
                color: color,
                lineWidth: 2,
                marker: { radius: 3 }
            }],
            legend: { enabled: false },
            credits: { enabled: false },
            tooltip: { valueSuffix: ' msnm', valueDecimals: 2 }
        });
        nivelCharts[chartKey] = chart;
    }

    window.maximizeNivelChart = function(which) {
        var chart = nivelCharts[which];
        if (!chart) return;
        var displayName = which === 'chicoasen' ? 'Chicoasén' : 'Peñitas';
        var color = which === 'chicoasen' ? '#42a5f5' : '#ffab40';
        var namoVal = which === 'chicoasen' ? NAMO_NIVELES.Chicoasen : NAMO_NIVELES.Penitas;
        var dataKey = which === 'chicoasen' ? 'Chicoasen' : 'Penitas';

        $('#fsTitleText').text('Nivel - ' + displayName);
        $('#chartFullscreen').addClass('active');
        $('body').css('overflow', 'hidden');
        currentFsPresa = '__nivel__' + which;
        setTimeout(function() {
            var h = $('#fsChartContainer').height();
            renderNivelChartTo('fsChartContainer', dataKey, displayName, color, namoVal, h);
        }, 100);
    };

    function renderNivelChartTo(containerId, dataKey, displayName, color, namoVal, height) {
        var pd = presasData[dataKey];
        if (!pd) return;
        var categories = [];
        var data = [];
        var hourMap = {};
        for (var i = 0; i < pd.labels.length; i++) {
            var lbl = pd.labels[i];
            var parts = lbl.split(' ');
            var hourStr = parts.length > 1 ? parts[parts.length - 1] : parts[0];
            var hh = parseInt(hourStr);
            if (!isNaN(hh)) hourMap[hh] = pd.elevacion[i];
        }
        for (var hh = 1; hh <= 24; hh++) {
            categories.push(hh + ':00');
            data.push(hourMap[hh] != null ? hourMap[hh] : null);
        }
        Highcharts.chart(containerId, {
            chart: { backgroundColor: '#0f1923', height: height },
            title: { text: displayName + ' – Nivel Horario', style: { color: color, fontSize: '18px' } },
            exporting: { enabled: false },
            xAxis: { categories: categories, labels: { style: { color: '#78909c' } } },
            yAxis: {
                title: { text: 'Nivel (msnm)', style: { color: '#78909c' } },
                softMax: namoVal + 0.5,
                plotLines: [{ value: namoVal, color: '#ff5252', width: 2, dashStyle: 'Dash', zIndex: 5,
                    label: { text: 'NAMO: ' + namoVal.toFixed(2) + ' msnm', align: 'right', style: { color: '#ff5252', fontSize: '12px', fontWeight: '600' } } }]
            },
            series: [{ name: 'Nivel', type: 'spline', data: data, color: color, lineWidth: 3, marker: { radius: 4 } }],
            legend: { enabled: false },
            credits: { enabled: false },
            tooltip: { valueSuffix: ' msnm', valueDecimals: 2 }
        });
    }

    window.exportNivelChart = function(which) {
        var chart = nivelCharts[which];
        if (chart) {
            chart.exportChart({ type: 'image/png', filename: 'Nivel_' + which }, { chart: { backgroundColor: '#0f1923' } });
        }
    };

    window.exportNivelesHorarios = function() {
        var fecha = '@Model.FechaFin.ToString("yyyy-MM-dd")';
        window.location.href = '@Url.Action("ExportNivelesHorarios", "FunVasos")?fecha=' + fecha;
    };
});
</script>
}

