    // ========== MODAL: REFERENCIAS PERSONALIZADAS ==========
    var _antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

    window.openRefModal = function(presaKey, presaTitle) {
        currentRefPresa = presaKey;
        $('#refPresaTitle').text(presaTitle);
        resetRefForm();
        renderNivelesToggle(presaKey);
        loadRefTable(presaKey);
        $('#refModal').modal({ closable: false }).modal('show');
