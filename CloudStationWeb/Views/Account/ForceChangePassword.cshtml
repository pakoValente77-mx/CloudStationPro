@{
    ViewData["Title"] = "Cambio de Contraseña Obligatorio";
    Layout = null;
    int daysExpired = ViewBag.DaysExpired ?? 0;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cambio de Contraseña - PIH</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/semantic-ui@2.5.0/dist/semantic.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            background: #0a0a1a;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        .change-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 460px;
            backdrop-filter: blur(20px);
        }
        .change-card .logo {
            text-align: center;
            margin-bottom: 24px;
        }
        .change-card .logo i {
            font-size: 48px;
            color: #f59e0b;
        }
        .change-card h2 {
            color: #fff;
            text-align: center;
            font-size: 20px;
            margin-bottom: 8px;
        }
        .change-card .subtitle {
            color: rgba(255,255,255,0.5);
            text-align: center;
            font-size: 13px;
            margin-bottom: 28px;
            line-height: 1.5;
        }
        .change-card .warning-box {
            background: rgba(245,158,11,0.1);
            border: 1px solid rgba(245,158,11,0.25);
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 24px;
            color: #fbbf24;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .change-card .warning-box i { font-size: 18px; }
        .field-group {
            margin-bottom: 18px;
        }
        .field-group label {
            display: block;
            color: rgba(255,255,255,0.6);
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .field-group input {
            width: 100%;
            padding: 12px 14px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }
        .field-group input:focus {
            border-color: #f59e0b;
        }
        .btn-change {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #f59e0b, #d97706);
            border: none;
            border-radius: 12px;
            color: #000;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 8px;
            transition: opacity 0.2s;
        }
        .btn-change:hover { opacity: 0.9; }
        .error-msg {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.3);
            border-radius: 10px;
            padding: 10px 14px;
            color: #fca5a5;
            font-size: 13px;
            margin-bottom: 16px;
        }
        .success-msg {
            background: rgba(16,185,129,0.1);
            border: 1px solid rgba(16,185,129,0.3);
            border-radius: 10px;
            padding: 10px 14px;
            color: #6ee7b7;
            font-size: 13px;
            margin-bottom: 16px;
        }
        .policy-list {
            color: rgba(255,255,255,0.4);
            font-size: 11px;
            margin-top: 16px;
            padding-left: 16px;
            line-height: 1.8;
        }
        .logout-link {
            display: block;
            text-align: center;
            margin-top: 16px;
            color: rgba(255,255,255,0.3);
            font-size: 12px;
            text-decoration: none;
        }
        .logout-link:hover { color: rgba(255,255,255,0.6); }
    </style>
</head>
<body>
    <div class="change-card">
        <div class="logo">
            <i class="shield alternate icon"></i>
        </div>
        <h2>Cambio de Contraseña Obligatorio</h2>
        <p class="subtitle">
            Su contraseña ha expirado (más de 30 días sin cambio).
            Por seguridad, debe establecer una nueva contraseña para continuar.
        </p>

        <div class="warning-box">
            <i class="exclamation triangle icon"></i>
            <span>Su contraseña expiró hace @daysExpired día(s). No podrá acceder al sistema hasta cambiarla.</span>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="error-msg">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="success-msg">@TempData["Success"]</div>
        }

        <form method="post" asp-action="ForceChangePassword" asp-controller="Account">
            @Html.AntiForgeryToken()
            <div class="field-group">
                <label>Contraseña Actual</label>
                <input type="password" name="currentPassword" autocomplete="current-password" required />
            </div>
            <div class="field-group">
                <label>Nueva Contraseña</label>
                <input type="password" name="newPassword" autocomplete="new-password" required />
            </div>
            <div class="field-group">
                <label>Confirmar Nueva Contraseña</label>
                <input type="password" name="confirmNewPassword" autocomplete="new-password" required />
            </div>
            <button type="submit" class="btn-change">
                <i class="key icon"></i> Cambiar Contraseña
            </button>
        </form>

        <ul class="policy-list">
            <li>Mínimo 8 caracteres</li>
            <li>Incluir mayúsculas y minúsculas</li>
            <li>Incluir al menos un número</li>
            <li>Incluir al menos un carácter especial (!@@#$%^&*)</li>
            <li>La contraseña debe cambiarse cada 30 días</li>
        </ul>

        <form method="post" asp-action="Logout" asp-controller="Account" style="text-align:center; margin-top:12px;">
            @Html.AntiForgeryToken()
            <button type="submit" class="logout-link" style="background:none; border:none; cursor:pointer;">
                <i class="sign out icon"></i> Cerrar Sesión
            </button>
        </form>
    </div>
</body>
</html>
