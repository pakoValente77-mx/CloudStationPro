@{
    Layout = null;
    ViewData["Title"] = "Solicitud Enviada";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PIH - Solicitud Enviada</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="stylesheet" href="/lib/fomantic-ui/dist/semantic.min.css">
    <link href="/lib/fonts/inter/inter.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0b0e14 0%, #1a1f2e 50%, #0d1117 100%);
            position: relative;
        }

        body::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background:
                radial-gradient(ellipse at 30% 40%, rgba(16, 185, 129, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 60%, rgba(245, 158, 11, 0.06) 0%, transparent 50%);
        }

        .pending-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 440px;
            padding: 20px;
        }

        .pending-card {
            background: rgba(20, 24, 33, 0.85);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 52px 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7);
            text-align: center;
            animation: cardAppear 0.6s ease-out;
        }

        @@keyframes cardAppear {
            from { opacity: 0; transform: translateY(20px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .success-icon {
            width: 72px; height: 72px;
            background: linear-gradient(135deg, #10b981, #059669);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3);
            animation: pulse 2s ease-in-out infinite;
        }

        @@keyframes pulse {
            0%, 100% { box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3); }
            50% { box-shadow: 0 8px 40px rgba(16, 185, 129, 0.5); }
        }

        .success-icon i { font-size: 32px; color: #fff; }

        h2 {
            font-size: 22px;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 12px;
        }

        .message {
            color: rgba(255, 255, 255, 0.6);
            font-size: 14px;
            line-height: 1.7;
            margin-bottom: 32px;
        }

        .steps {
            text-align: left;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 32px;
        }

        .step {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 14px;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.6);
        }

        .step:last-child { margin-bottom: 0; }

        .step-num {
            min-width: 24px; height: 24px;
            background: rgba(245, 158, 11, 0.15);
            color: #f59e0b;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
        }

        .btn-back {
            display: inline-block;
            padding: 14px 36px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            color: #fff;
            text-decoration: none;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            font-weight: 600;
            transition: all 0.25s;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
        }

        .btn-back:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 25px rgba(59, 130, 246, 0.4);
            color: #fff;
        }

        .footer-text {
            text-align: center;
            margin-top: 24px;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.25);
        }
    </style>
</head>
<body>
    <div class="pending-container">
        <div class="pending-card">
            <div class="success-icon">
                <i class="check icon"></i>
            </div>

            <h2>Solicitud Enviada</h2>
            <p class="message">
                Su solicitud de acceso ha sido registrada exitosamente.<br>
                Un administrador revisará su solicitud y le otorgará acceso.
            </p>

            <div class="steps">
                <div class="step">
                    <div class="step-num">1</div>
                    <div>Su solicitud ha sido enviada al equipo de administración.</div>
                </div>
                <div class="step">
                    <div class="step-num">2</div>
                    <div>El administrador revisará sus datos y motivo de acceso.</div>
                </div>
                <div class="step">
                    <div class="step-num">3</div>
                    <div>Una vez aprobada, podrá iniciar sesión con sus credenciales.</div>
                </div>
            </div>

            <a href="@Url.Action("Login", "Account")" class="btn-back">
                <i class="arrow left icon"></i> Volver al Inicio
            </a>

            <div class="footer-text">
                © 2026 Plataforma Integral Hidrometeorológica • CFE
            </div>
        </div>
    </div>
</body>
</html>
