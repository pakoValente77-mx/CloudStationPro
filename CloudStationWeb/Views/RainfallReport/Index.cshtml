@{
    ViewData["Title"] = "Reporte de Precipitación";
    Layout = "_Layout";
}

<style>
    .rain-report { max-width: 900px; margin: 80px auto 40px; font-family: 'Segoe UI', sans-serif; }
    .rain-header { background: linear-gradient(135deg, #1b5e20, #388e3c); border-radius: 12px; padding: 20px 28px; display: flex; align-items: center; gap: 20px; margin-bottom: 20px; }
    .rain-header img { height: 60px; }
    .rain-header .titles { color: #fff; }
    .rain-header .titles h2 { margin: 0; font-size: 1.5em; }
    .rain-header .titles .period { opacity: 0.85; font-size: 0.95em; margin-top: 4px; }
    .rain-controls { display: flex; gap: 12px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; }
    .rain-controls select, .rain-controls input { background: #1a1a2e; color: #fff; border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; padding: 8px 14px; font-size: 14px; }
    .rain-controls .btn-load { background: #388e3c; color: #fff; border: none; border-radius: 6px; padding: 8px 20px; cursor: pointer; font-weight: 600; }
    .rain-controls .btn-load:hover { background: #2e7d32; }

    .subcuenca-group { margin-bottom: 8px; }
    .subcuenca-header { background: linear-gradient(90deg, #2e7d32, #43a047); color: #fff; padding: 8px 16px; border-radius: 6px 6px 0 0; font-weight: 600; font-size: 1.05em; }
    .station-table { width: 100%; border-collapse: collapse; background: #f5f5f5; }
    .station-table tr { border-bottom: 1px solid #e0e0e0; }
    .station-table td { padding: 6px 12px; font-size: 0.95em; color: #333; }
    .station-table td:first-child { width: 45%; }
    .station-table td:nth-child(2) { width: 40%; }
    .station-table td:last-child { width: 15%; text-align: right; font-weight: 600; padding-right: 16px; }
    .bar-cell { padding: 6px 4px !important; }
    .bar-bg { background: #e0e0e0; border-radius: 3px; height: 16px; overflow: hidden; }
    .bar-fill { background: linear-gradient(90deg, #43a047, #66bb6a); height: 100%; border-radius: 3px; min-width: 2px; transition: width 0.5s ease; }
    .subcuenca-avg { background: #e8f5e9; color: #2e7d32; padding: 6px 16px; border-radius: 0 0 6px 6px; font-weight: 600; font-size: 0.9em; margin-bottom: 12px; }
    .org-header { background: #1b5e20; color: #fff; padding: 8px 16px; font-weight: bold; font-size: 1em; margin-top: 4px; }
    .col-header { background: #388e3c; color: #fff; padding: 6px 16px; display: flex; justify-content: space-between; font-weight: 600; font-size: 0.9em; }
    .rain-footer { background: #f5f5f5; border-radius: 6px; padding: 10px 16px; color: #666; font-size: 0.85em; margin-top: 10px; }
    .loading-overlay { text-align: center; padding: 60px; color: #aaa; font-size: 1.2em; }
    .no-data { text-align: center; padding: 40px; color: #999; }
    .print-only { display: none; }
    .rain-summary { display: flex; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
    .rain-card { background: #1a1a2e; border-radius: 8px; padding: 12px 20px; flex: 1; min-width: 150px; }
    .rain-card .label { color: #aaa; font-size: 0.8em; }
    .rain-card .value { color: #fff; font-size: 1.6em; font-weight: 700; }

    @@media print {
        .rain-controls, .pih-sidebar, .pih-sidebar-overlay, #pih-navbar, .no-print { display: none !important; }
        .rain-report { margin: 0; max-width: 100%; }
        .print-only { display: block; }
        .rain-card { background: #f0f0f0 !important; }
        .rain-card .value { color: #333 !important; }
        .rain-card .label { color: #666 !important; }
        body { background: #fff !important; }
    }
</style>

<div class="rain-report">
    <!-- Controls -->
    <div class="rain-controls no-print">
        <select id="selTipo">
            <option value="parcial" selected>Parcial (06:00 → ahora)</option>
            <option value="24h">24 horas (ayer 06:00 → hoy 06:00)</option>
        </select>
        <input type="date" id="selFecha" />
        <button class="btn-load" onclick="loadReport()"><i class="sync icon"></i> Actualizar</button>
        <button class="btn-load" style="background:#1565c0;" onclick="window.print()"><i class="print icon"></i> Imprimir</button>
    </div>

    <!-- Header -->
    <div class="rain-header" id="reportHeader">
        <div>
            <svg width="60" height="60" viewBox="0 0 100 100"><rect width="100" height="100" rx="12" fill="#fff" opacity="0.15"/><text x="50" y="38" text-anchor="middle" fill="#fff" font-size="14" font-weight="bold">CFE</text><text x="50" y="58" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="8">COMISIÓN FEDERAL</text><text x="50" y="68" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="8">DE ELECTRICIDAD</text></svg>
        </div>
        <div class="titles">
            <h2 id="reportTitle">Reporte de precipitación</h2>
            <div class="period" id="reportPeriod">Cargando...</div>
        </div>
    </div>

    <!-- Summary cards -->
    <div class="rain-summary" id="summaryCards"></div>

    <!-- Column headers -->
    <div class="org-header">SPH Grijalva</div>
    <div class="col-header">
        <span>Estación</span>
        <span>Prec. (mm)</span>
    </div>

    <!-- Report body -->
    <div id="reportBody">
        <div class="loading-overlay"><i class="spinner loading icon"></i> Cargando datos...</div>
    </div>

    <!-- Footer -->
    <div class="rain-footer">
        <strong>Observación:</strong> Los datos reportados son PRELIMINARES, los datos oficiales se validan a las 07:00 horas.
    </div>
</div>

@section Scripts {
<script>
var reportData = null;

$(function() {
    // Default: hoy
    var today = new Date();
    var yyyy = today.getFullYear();
    var mm = String(today.getMonth() + 1).padStart(2, '0');
    var dd = String(today.getDate()).padStart(2, '0');
    $('#selFecha').val(yyyy + '-' + mm + '-' + dd);
    loadReport();
});

function loadReport() {
    var tipo = $('#selTipo').val();
    var fecha = $('#selFecha').val();
    var url = '/api/lluvia/reporte?tipo=' + tipo;
    if (fecha) url += '&fecha=' + fecha;

    $('#reportBody').html('<div class="loading-overlay"><i class="spinner loading icon"></i> Cargando datos...</div>');

    $.ajax({
        url: url,
        type: 'GET',
        success: function(data) {
            reportData = data;
            renderReport(data);
        },
        error: function(xhr) {
            $('#reportBody').html('<div class="no-data"><i class="exclamation triangle icon"></i> Error al cargar datos: ' + (xhr.responseJSON?.title || xhr.statusText) + '</div>');
        }
    });
}

function renderReport(data) {
    // Title & period
    $('#reportTitle').text(data.titulo || 'Reporte de precipitación');
    $('#reportPeriod').text('De ' + data.periodoInicioLocal + ' a ' + data.periodoFinLocal);

    // Summary cards
    var totalEst = data.totalEstaciones || 0;
    var conLluvia = data.estacionesConLluvia || 0;
    var maxMm = 0;
    var promGeneral = 0;
    if (data.subcuencas && data.subcuencas.length > 0) {
        data.subcuencas.forEach(function(sc) {
            sc.estaciones.forEach(function(e) {
                if (e.acumuladoMm > maxMm) maxMm = e.acumuladoMm;
            });
        });
        var allProms = data.subcuencas.map(function(sc) { return sc.promedioMm; });
        promGeneral = (allProms.reduce(function(a,b){ return a+b; }, 0) / allProms.length).toFixed(1);
    }

    $('#summaryCards').html(
        '<div class="rain-card"><div class="label">Estaciones CFE</div><div class="value">' + totalEst + '</div></div>' +
        '<div class="rain-card"><div class="label">Con lluvia</div><div class="value" style="color:#81c784;">' + conLluvia + '</div></div>' +
        '<div class="rain-card"><div class="label">Máximo</div><div class="value" style="color:#fbbf24;">' + maxMm.toFixed(1) + ' mm</div></div>' +
        '<div class="rain-card"><div class="label">Promedio</div><div class="value" style="color:#64b5f6;">' + promGeneral + ' mm</div></div>'
    );

    // Body
    if (!data.subcuencas || data.subcuencas.length === 0) {
        $('#reportBody').html('<div class="no-data"><i class="tint icon"></i> Sin datos de precipitación en este periodo.</div>');
        return;
    }

    // Find global max for bar scaling
    var globalMax = 1;
    data.subcuencas.forEach(function(sc) {
        sc.estaciones.forEach(function(e) {
            if (e.acumuladoMm > globalMax) globalMax = e.acumuladoMm;
        });
    });

    var html = '';
    data.subcuencas.forEach(function(sc) {
        html += '<div class="subcuenca-group">';
        html += '<div class="subcuenca-header"><i class="tint icon"></i> Subcuenca: ' + escHtml(sc.subcuenca) + '</div>';
        html += '<table class="station-table"><tbody>';

        sc.estaciones.forEach(function(e) {
            var pct = (e.acumuladoMm / globalMax * 100).toFixed(1);
            html += '<tr>';
            html += '<td>' + escHtml(e.nombre) + '</td>';
            html += '<td class="bar-cell"><div class="bar-bg"><div class="bar-fill" style="width:' + pct + '%;"></div></div></td>';
            html += '<td>' + e.acumuladoMm.toFixed(1) + '</td>';
            html += '</tr>';
        });

        html += '</tbody></table>';
        html += '<div class="subcuenca-avg">Promedio Subcuenca: ' + sc.promedioMm.toFixed(1) + ' mm</div>';
        html += '</div>';
    });

    $('#reportBody').html(html);
}

function escHtml(s) {
    var d = document.createElement('div');
    d.textContent = s || '';
    return d.innerHTML;
}
</script>
}
